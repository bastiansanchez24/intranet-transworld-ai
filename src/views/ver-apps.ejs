<link rel="stylesheet" href="/css/apps.css">
<% if (typeof isAdministrador !== 'undefined' && isAdministrador) { %>
<link rel="stylesheet" href="/css/profile-photo-crop.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">
<% } %>
<%
  function appInitials(name) {
    if (!name) return '?';
    const parts = String(name).trim().split(/\s+/).filter(Boolean);
    if (parts.length >= 2) return (parts[0][0] + parts[1][0]).toUpperCase();
    return parts[0].slice(0, 2).toUpperCase();
  }
  function jsSafe(str) {
    return String(str == null ? '' : str).replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/\r?\n/g, ' ');
  }
%>

<div class="contenedor">

  <div class="page-header page-header--toolbar">
    <div class="page-header__text">
      <h2 class="page-title">Aplicaciones de Transworld</h2>
      <p class="page-description">Descarga las aplicaciones y herramientas corporativas oficiales.</p>
    </div>

    <% if (typeof isAdministrador !== 'undefined' && isAdministrador) { %>
    <div class="page-header-actions">
      <button type="button" class="apps-add-btn" onclick="toggleFormulario()">
        <span aria-hidden="true">+</span> Ingresar nueva app
      </button>
    </div>
    <% } %>
  </div>

  <% if (typeof ok !== 'undefined' && ok) { %>
    <div class="apps-flash"><%= ok %></div>
  <% } %>

  <div class="apps-grid">
    <% if (typeof apps !== 'undefined' && apps.length > 0) { %>
      <% apps.forEach((app, index) => {
        const iniciales = appInitials(app.name);
        const tileGreen = (index % 2 === 1);
        const nombreJs = jsSafe(app.name);
        const iconUrl = app.icon_url || '';
      %>
        <article class="app-card">
          <div class="app-card__header">
            <% if (iconUrl) { %>
              <div class="app-card__tile app-card__tile--image" aria-hidden="true">
                <img src="<%= iconUrl %>" alt="">
              </div>
            <% } else { %>
              <div class="app-card__tile<%= tileGreen ? ' app-card__tile--green' : '' %>" aria-hidden="true"><%= iniciales %></div>
            <% } %>
            <div class="app-card__heading">
              <h3 class="app-card__name"><%= app.name %></h3>
              <p class="app-card__meta">Última actualización · <%= app.updated_at ? new Date(app.updated_at).toLocaleDateString('es-CL') : '—' %></p>
            </div>
          </div>

          <p class="app-card__desc"><%= app.description %></p>

          <div class="app-card__downloads">
            <span class="app-card__downloads-label">Descargas</span>
            <% if (app.url_pc || app.url_apk || app.qr_ios) { %>
              <div class="app-card__badges">
                <% if (app.url_pc) { %>
                  <a href="<%= app.url_pc %>" target="_blank" rel="noopener noreferrer" class="app-badge app-badge--pc" title="Descargar para PC"><%- include('partials/icon', { name: 'monitor' }) %> PC</a>
                <% } %>
                <% if (app.url_apk) { %>
                  <button type="button" class="app-badge app-badge--apk" title="Descargar para Android" onclick="manejarDescargaAndroid('<%= app.url_apk %>', '<%= app.qr_apk ? app.qr_apk : '' %>', '<%= nombreJs %>')"><%- include('partials/icon', { name: 'smartphone' }) %> APK</button>
                <% } %>
                <% if (app.qr_ios) { %>
                  <button type="button" class="app-badge app-badge--qr" title="Ver QR iOS" onclick="abrirModalQR('<%= app.qr_ios %>', '<%= nombreJs %> · iOS')"><span aria-hidden="true">▦</span> QR iOS</button>
                <% } %>
              </div>
            <% } else { %>
              <span class="app-card__no-files">Sin archivos disponibles</span>
            <% } %>
          </div>

          <% if (typeof isAdministrador !== 'undefined' && isAdministrador) { %>
          <div class="app-card__footer">
            <button type="button" class="app-action app-action--notify"
                    title="<%= app.notified === false ? 'Enviar cambios por correo a Ventas/Marketing' : 'No hay cambios pendientes' %>"
                    onclick="abrirModalNotificar('<%= app.id %>', '<%= nombreJs %>')"
                    <%= app.notified === false ? '' : 'disabled' %>>
              Notificar
            </button>
            <button type="button" class="app-action app-action--edit" title="Editar app"
                    onclick="abrirModalEditar('<%= app.id %>', '<%= nombreJs %>', '<%= jsSafe(app.description) %>', '<%= app.url_pc || '' %>', '<%= app.url_apk || '' %>', '<%= jsSafe(iconUrl) %>')">
              Editar
            </button>
            <form action="/apps/eliminar/<%= app.id %>" method="POST" class="app-card__delete-form" onsubmit="return confirm('¿Estás seguro que deseas eliminar la aplicación? Esta acción es irreversible.');">
              <button type="submit" class="app-action app-action--delete" title="Eliminar app">Eliminar</button>
            </form>
          </div>
          <% } %>
        </article>
      <% }) %>
    <% } else { %>
      <div class="apps-empty-state">No hay aplicaciones registradas.</div>
    <% } %>
  </div>

  <!-- Modal QR -->
  <div class="modal-overlay" id="modal-qr" role="dialog" aria-modal="true" aria-labelledby="qr-titulo">
    <div class="modal-content qr-modal__content">
      <div class="qr-modal__grid">
        <aside class="qr-modal__aside">
          <h3 class="qr-modal__title" id="qr-titulo">Escanea el código</h3>
          <p class="qr-modal__text">Apunta la cámara de tu teléfono a este código para instalar la aplicación.</p>
          <div class="qr-modal__actions">
            <button type="button" id="qr-btn-descarga" class="app-btn-primary" onclick="forzarDescargaQR()">Descargar imagen QR</button>
            <a id="qr-btn-enlace" href="#" target="_blank" rel="noopener noreferrer" class="app-btn-neutral" style="display: none;">Ir al enlace directo</a>
          </div>
        </aside>
        <div class="qr-modal__main">
          <button type="button" class="qr-modal__close" onclick="cerrarModal('modal-qr')" aria-label="Cerrar">&times;</button>
          <div class="qr-modal__card">
            <img id="qr-imagen" src="" alt="Código QR de instalación">
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if (typeof isAdministrador !== 'undefined' && isAdministrador) { %>

  <!-- Modal Nueva App -->
  <div class="modal-overlay" id="modal-nueva" role="dialog" aria-modal="true" aria-labelledby="nueva-titulo">
    <div class="modal-content app-modal__content">
      <form action="/apps/nueva" method="POST" enctype="multipart/form-data">
        <div class="app-modal__grid">
          <aside class="app-modal__aside">
            <h3 class="app-modal__title" id="nueva-titulo">Ingresar nueva app</h3>
            <p class="app-modal__subtitle">Completa los datos y enlaces de descarga para cada plataforma.</p>

            <div class="app-icon-upload">
              <label>Icono de la aplicación</label>
              <div class="app-icon-preview-wrap">
                <div class="app-icon-preview" id="nueva-icon-preview">
                  <img id="nueva-icon-preview-img" alt="" hidden>
                  <div class="app-icon-placeholder" id="nueva-icon-placeholder">
                    <span>AA</span>
                  </div>
                </div>
                <div class="app-icon-actions">
                  <button type="button" class="app-btn-icon-select" id="nueva-icon-select">Subir icono</button>
                  <span class="app-icon-hint">JPG, PNG o WebP · Máx. 5 MB</span>
                </div>
              </div>
              <input type="file" id="nueva-icon" name="icon" accept="image/*" hidden>
            </div>

            <div class="app-field">
              <label for="nueva-nombre">Nombre de la aplicación *</label>
              <input type="text" id="nueva-nombre" name="name" required placeholder="Ej: Transworld Lead App">
            </div>
            <div class="app-field">
              <label for="nueva-desc">Descripción *</label>
              <textarea id="nueva-desc" name="description" required placeholder="Describe para qué sirve la aplicación..."></textarea>
            </div>
          </aside>

          <div class="app-modal__main">
            <button type="button" class="app-modal__close" onclick="cerrarModal('modal-nueva')" aria-label="Cerrar">&times;</button>

            <div class="app-platforms">
              <div class="app-platform">
                <h4 class="app-platform__head"><%- include('partials/icon', { name: 'monitor' }) %> Software para PC</h4>
                <div class="app-field">
                  <label>Enlace de descarga (opcional)</label>
                  <input type="url" name="url_pc" placeholder="Link de descarga (ej. MediaFire)">
                </div>
              </div>

              <div class="app-platform">
                <h4 class="app-platform__head"><%- include('partials/icon', { name: 'smartphone' }) %> Software para Android</h4>
                <div class="app-field">
                  <label>Enlace versión APK (opcional)</label>
                  <input type="url" name="url_apk" placeholder="Link de descarga (ej. MediaFire)">
                </div>
                <div class="app-field">
                  <label>Subir código QR Android (opcional)</label>
                  <input class="app-file-input" type="file" name="qr_apk" accept="image/png, image/jpeg, image/webp">
                </div>
              </div>

              <div class="app-platform app-platform--full">
                <h4 class="app-platform__head"><%- include('partials/icon', { name: 'tablet' }) %> Software para iOS</h4>
                <div class="app-field">
                  <label>Subir código QR iOS (opcional)</label>
                  <input class="app-file-input" type="file" name="qr_ios" accept="image/png, image/jpeg, image/webp">
                </div>
              </div>
            </div>

            <div class="app-modal__footer">
              <button type="button" class="app-btn-neutral" onclick="cerrarModal('modal-nueva')">Cancelar</button>
              <button type="submit" class="app-btn-primary">Guardar app</button>
            </div>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Editar App -->
  <div class="modal-overlay" id="modal-editar" role="dialog" aria-modal="true" aria-labelledby="editar-titulo">
    <div class="modal-content app-modal__content">
      <form id="form-editar" method="POST" enctype="multipart/form-data">
        <div class="app-modal__grid">
          <aside class="app-modal__aside">
            <h3 class="app-modal__title" id="editar-titulo">Editar aplicación</h3>
            <p class="app-modal__subtitle">Actualiza la información y los enlaces de descarga de la aplicación.</p>

            <div class="app-icon-upload">
              <label>Icono de la aplicación</label>
              <div class="app-icon-preview-wrap">
                <div class="app-icon-preview" id="edit-icon-preview">
                  <img id="edit-icon-preview-img" alt="" hidden>
                  <div class="app-icon-placeholder" id="edit-icon-placeholder">
                    <span id="edit-icon-initials">AA</span>
                  </div>
                </div>
                <div class="app-icon-actions">
                  <button type="button" class="app-btn-icon-select" id="edit-icon-select">Subir icono</button>
                  <span class="app-icon-hint">JPG, PNG o WebP · Máx. 5 MB</span>
                </div>
              </div>
              <input type="file" id="edit-icon" name="icon" accept="image/*" hidden>
            </div>

            <div class="app-field">
              <label for="edit-nombre">Nombre</label>
              <input type="text" id="edit-nombre" name="name" required>
            </div>
            <div class="app-field">
              <label for="edit-desc">Descripción</label>
              <textarea id="edit-desc" name="description" required></textarea>
            </div>
          </aside>

          <div class="app-modal__main">
            <button type="button" class="app-modal__close" onclick="cerrarModal('modal-editar')" aria-label="Cerrar">&times;</button>

            <div class="app-platforms">
              <div class="app-platform">
                <h4 class="app-platform__head"><%- include('partials/icon', { name: 'monitor' }) %> Software para PC</h4>
                <div class="app-field">
                  <label>Enlace de descarga (opcional)</label>
                  <input type="url" name="url_pc" id="edit-pc">
                </div>
              </div>

              <div class="app-platform">
                <h4 class="app-platform__head"><%- include('partials/icon', { name: 'smartphone' }) %> Software para Android</h4>
                <div class="app-field">
                  <label>Enlace versión APK (opcional)</label>
                  <input type="url" name="url_apk" id="edit-apk">
                </div>
                <div class="app-field">
                  <label>Actualizar QR Android (opcional)</label>
                  <input class="app-file-input" type="file" name="qr_apk" accept="image/png, image/jpeg, image/webp">
                </div>
              </div>

              <div class="app-platform app-platform--full">
                <h4 class="app-platform__head"><%- include('partials/icon', { name: 'tablet' }) %> Software para iOS</h4>
                <div class="app-field">
                  <label>Actualizar QR iOS (opcional)</label>
                  <input class="app-file-input" type="file" name="qr_ios" accept="image/png, image/jpeg, image/webp">
                </div>
              </div>
            </div>

            <div class="app-modal__footer">
              <button type="button" class="app-btn-neutral" onclick="cerrarModal('modal-editar')">Cancelar</button>
              <button type="submit" class="app-btn-primary">Actualizar cambios</button>
            </div>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Notificar -->
  <div class="modal-overlay" id="modal-notificar" role="dialog" aria-modal="true" aria-labelledby="notificar-titulo">
    <div class="modal-content app-notify__content">
      <button type="button" class="app-modal__close" onclick="cerrarModal('modal-notificar')" aria-label="Cerrar">&times;</button>
      <h3 class="app-notify__title" id="notificar-titulo">Enviar actualización</h3>
      <p class="app-notify__hint">
        <strong>Asunto del correo:</strong> <span id="preview-asunto" class="app-notify__subject"></span>
      </p>
      <p class="app-notify__hint">Describe los cambios realizados para notificar a los equipos.</p>

      <form id="form-notificar" method="POST">
        <textarea name="cambios_texto" class="app-notify__textarea" required placeholder="Ej: Se corrigió el error de inicio de sesión y se añadió el manual de usuario v2..."></textarea>
        <div class="app-notify__footer">
          <button type="submit" class="app-btn-primary">Enviar correo masivo</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Crop icono nueva -->
  <div class="foto-crop-overlay" id="nuevaIconCropOverlay" role="dialog" aria-modal="true" aria-labelledby="nuevaIconCropTitle" hidden>
    <div class="foto-crop-modal">
      <div class="foto-crop-header">
        <h3 id="nuevaIconCropTitle">Recortar icono</h3>
        <button type="button" class="foto-crop-close" id="nuevaIconCropClose" aria-label="Cerrar">&times;</button>
      </div>
      <p class="foto-crop-hint">Arrastra y ajusta el encuadre. El icono se mostrará cuadrado en la tarjeta.</p>
      <div class="foto-crop-body">
        <div class="foto-crop-stage">
          <img id="nuevaIconCropImage" src="" alt="Vista previa para recortar">
        </div>
      </div>
      <p id="nuevaIconCropError" class="foto-crop-error" role="alert"></p>
      <div class="foto-crop-footer">
        <button type="button" class="btn-crop-cancel" id="nuevaIconCropCancel">Cancelar</button>
        <button type="button" class="btn-crop-save" id="nuevaIconCropSave">Aplicar recorte</button>
      </div>
    </div>
  </div>

  <!-- Crop icono editar -->
  <div class="foto-crop-overlay" id="editIconCropOverlay" role="dialog" aria-modal="true" aria-labelledby="editIconCropTitle" hidden>
    <div class="foto-crop-modal">
      <div class="foto-crop-header">
        <h3 id="editIconCropTitle">Recortar icono</h3>
        <button type="button" class="foto-crop-close" id="editIconCropClose" aria-label="Cerrar">&times;</button>
      </div>
      <p class="foto-crop-hint">Arrastra y ajusta el encuadre. El icono se mostrará cuadrado en la tarjeta.</p>
      <div class="foto-crop-body">
        <div class="foto-crop-stage">
          <img id="editIconCropImage" src="" alt="Vista previa para recortar">
        </div>
      </div>
      <p id="editIconCropError" class="foto-crop-error" role="alert"></p>
      <div class="foto-crop-footer">
        <button type="button" class="btn-crop-cancel" id="editIconCropCancel">Cancelar</button>
        <button type="button" class="btn-crop-save" id="editIconCropSave">Aplicar recorte</button>
      </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  <script src="/js/profile-photo-cropper.js"></script>
  <% } %>

</div>

<script>
  // Abrir/cerrar el modal de nueva app
  function toggleFormulario() {
    if (window.nuevaAppIconCropper) {
      window.nuevaAppIconCropper.clearPhoto();
      const placeholder = document.getElementById('nueva-icon-placeholder');
      if (placeholder) {
        const span = placeholder.querySelector('span');
        if (span) span.textContent = 'AA';
      }
    }
    IntranetModal.open('modal-nueva');
  }

  // Cerrar cualquier modal
  function cerrarModal(id) {
    IntranetModal.close(id);
  }

  // Descarga Android (QR en PC / enlace directo en móvil)
  function manejarDescargaAndroid(urlDescarga, urlQr, nombreApp) {
    const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || window.innerWidth <= 768;

    if (isMobile || !urlQr || urlQr.trim() === '') {
      window.open(urlDescarga, '_blank');
    } else {
      abrirModalQR(urlQr, nombreApp + ' · Android', urlDescarga);
    }
  }

  // Modal QR genérico
  let qrActualUrl = '';
  function abrirModalQR(urlImagen, nombreApp, urlDirecta = null) {
    qrActualUrl = urlImagen;
    document.getElementById('qr-imagen').src = urlImagen;
    document.getElementById('qr-titulo').innerText = 'QR para ' + nombreApp;

    const btnEnlace = document.getElementById('qr-btn-enlace');
    if (urlDirecta && urlDirecta !== 'null' && urlDirecta !== '') {
      btnEnlace.href = urlDirecta;
      btnEnlace.style.display = 'inline-flex';
    } else {
      btnEnlace.style.display = 'none';
    }

    IntranetModal.open('modal-qr');
  }

  // Descargar imagen QR
  function forzarDescargaQR() {
    if (!qrActualUrl) return;
    const link = document.createElement('a');
    link.href = qrActualUrl;
    link.setAttribute('download', 'Codigo_QR.png');
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }

  function appInitialsClient(name) {
    if (!name) return '?';
    const parts = String(name).trim().split(/\s+/).filter(Boolean);
    if (parts.length >= 2) return (parts[0][0] + parts[1][0]).toUpperCase();
    return parts[0].slice(0, 2).toUpperCase();
  }

  function setEditIconPreview(iconUrl, iniciales) {
    const previewImg = document.getElementById('edit-icon-preview-img');
    const placeholder = document.getElementById('edit-icon-placeholder');
    const initialsEl = document.getElementById('edit-icon-initials');
    const selectBtn = document.getElementById('edit-icon-select');
    if (!previewImg || !placeholder) return;

    if (initialsEl) initialsEl.textContent = iniciales || 'AA';

    if (iconUrl) {
      previewImg.src = iconUrl;
      previewImg.hidden = false;
      placeholder.hidden = true;
      if (selectBtn) selectBtn.textContent = 'Cambiar icono';
    } else {
      previewImg.hidden = true;
      previewImg.removeAttribute('src');
      placeholder.hidden = false;
      if (selectBtn) selectBtn.textContent = 'Subir icono';
    }
  }

  // Modal Editar
  function abrirModalEditar(id, nombre, desc, pc, apk, iconUrl) {
    const formEditar = document.getElementById('form-editar');
    if (!formEditar) return;

    formEditar.action = '/apps/editar/' + id;
    document.getElementById('edit-nombre').value = nombre;
    document.getElementById('edit-desc').value = desc;
    document.getElementById('edit-pc').value = pc || '';
    document.getElementById('edit-apk').value = apk || '';

    if (window.editAppIconCropper) {
      window.editAppIconCropper.clearPhoto();
    }
    setEditIconPreview(iconUrl || '', appInitialsClient(nombre));

    IntranetModal.open('modal-editar');
  }

  // Modal Notificar
  function abrirModalNotificar(id, nombre) {
    const form = document.getElementById('form-notificar');
    document.getElementById('notificar-titulo').innerText = 'Notificar cambios: ' + nombre;
    document.getElementById('preview-asunto').innerText = nombre + ': Nueva actualización.';

    form.action = '/apps/notificar/' + id;
    IntranetModal.open('modal-notificar');
  }

  <% if (typeof isAdministrador !== 'undefined' && isAdministrador) { %>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof ProfilePhotoCropper === 'undefined') return;

    const cropperConfig = {
      maxSizeMb: 5,
      outputSize: 256,
      aspectRatio: 1,
      selectLabel: 'Subir icono',
      changeLabel: 'Cambiar icono',
      outputFilename: 'icono-app.jpg',
    };

    window.nuevaAppIconCropper = ProfilePhotoCropper.init({
      ...cropperConfig,
      fileInputId: 'nueva-icon',
      previewImgId: 'nueva-icon-preview-img',
      previewPlaceholderId: 'nueva-icon-placeholder',
      selectBtnId: 'nueva-icon-select',
      overlayId: 'nuevaIconCropOverlay',
      cropImgId: 'nuevaIconCropImage',
      closeBtnId: 'nuevaIconCropClose',
      cancelBtnId: 'nuevaIconCropCancel',
      saveBtnId: 'nuevaIconCropSave',
      errorElId: 'nuevaIconCropError',
    });

    window.editAppIconCropper = ProfilePhotoCropper.init({
      ...cropperConfig,
      fileInputId: 'edit-icon',
      previewImgId: 'edit-icon-preview-img',
      previewPlaceholderId: 'edit-icon-placeholder',
      selectBtnId: 'edit-icon-select',
      overlayId: 'editIconCropOverlay',
      cropImgId: 'editIconCropImage',
      closeBtnId: 'editIconCropClose',
      cancelBtnId: 'editIconCropCancel',
      saveBtnId: 'editIconCropSave',
      errorElId: 'editIconCropError',
    });

    const nuevaNombre = document.getElementById('nueva-nombre');
    const nuevaPlaceholder = document.querySelector('#nueva-icon-placeholder span');
    if (nuevaNombre && nuevaPlaceholder) {
      nuevaNombre.addEventListener('input', function () {
        const img = document.getElementById('nueva-icon-preview-img');
        if (img && !img.hidden && img.getAttribute('src')) return;
        nuevaPlaceholder.textContent = appInitialsClient(nuevaNombre.value);
      });
    }

    const editNombre = document.getElementById('edit-nombre');
    const editInitials = document.getElementById('edit-icon-initials');
    if (editNombre && editInitials) {
      editNombre.addEventListener('input', function () {
        const img = document.getElementById('edit-icon-preview-img');
        if (img && !img.hidden && img.getAttribute('src')) return;
        editInitials.textContent = appInitialsClient(editNombre.value);
      });
    }
  });
  <% } %>
</script>
