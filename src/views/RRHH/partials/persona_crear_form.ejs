<form action="/RRHH/crear" method="POST" id="formCrearColaborador">
  <div class="modal-form-grid-2">
    <div class="campo">
      <label for="crear_first_name">Nombre <span class="required-mark">*</span></label>
      <input type="text" id="crear_first_name" name="first_name" required placeholder="Ej: Juan">
    </div>
    <div class="campo">
      <label for="crear_last_name">Apellido <span class="required-mark">*</span></label>
      <input type="text" id="crear_last_name" name="last_name" required placeholder="Ej: Pérez">
    </div>
  </div>

  <div class="campo">
    <label for="crear_email">Correo Electrónico</label>
    <input type="email" id="crear_email" name="email" placeholder="nombre@empresa.com" autocomplete="email">
    <span class="hint">Opcional. Si indicas un correo válido, se creará la cuenta de intranet y se enviará la contraseña temporal.</span>
    <span class="field-error" id="crear_email-error" role="alert"></span>
  </div>

  <div class="campo">
    <label for="crear_telefono_local">Teléfono</label>
    <div class="phone-field" data-phone-chile id="crear_phone_field">
      <span class="phone-field__prefix" aria-hidden="true">+56</span>
      <input type="tel" id="crear_telefono_local" class="phone-field__local" placeholder="9 1234 5678" maxlength="11" inputmode="numeric" autocomplete="tel-national" aria-label="Número celular sin código de país">
      <input type="hidden" name="phone" id="crear_telefono">
    </div>
    <span class="field-error" id="crear_telefono-error" role="alert"></span>
  </div>

  <div class="campo">
    <label for="crear_area_trabajo_id">Área de Trabajo <span class="required-mark">*</span></label>
        <select id="crear_area_trabajo_id" name="work_area_id" required>
      <option value="">-- Selecciona un área --</option>
      <% (areas || []).forEach(area => { %>
        <option value="<%= area.id %>"><%= area.area_name %></option>
      <% }) %>
    </select>
  </div>

  <div class="modal-form-grid-2">
    <div class="campo">
      <label for="crear_fecha_nacimiento" id="crear_fecha_nacimiento_label">Fecha de Nacimiento <span class="required-mark" id="crear_fecha_nacimiento_mark">*</span></label>
      <input type="date" id="crear_fecha_nacimiento" name="birth_date" required>
      <span class="hint" id="crear_fecha_nacimiento_hint" hidden>Opcional si indicas un correo electrónico.</span>
    </div>
    <div class="campo">
      <label for="crear_role">Rol de Intranet</label>
      <input type="text" id="crear_role" value="Deshabilitado" readonly style="background:#f3f4f6; color:#6b7280; cursor:not-allowed;">
      <span class="hint">Se asignará automáticamente el rol Usuario cuando el colaborador verifique su correo.</span>
    </div>
  </div>

  <div class="modal-form-grid-2">
    <div class="campo">
      <label for="crear_employment_country">País de contrato <span class="required-mark">*</span></label>
      <select id="crear_employment_country" name="employment_country" required>
        <option value="CL" selected>Chile</option>
        <option value="PE">Perú</option>
      </select>
      <span class="hint">Determina las reglas de vacaciones aplicables.</span>
    </div>
    <div class="campo">
      <label for="crear_hire_date">Fecha de ingreso</label>
      <input type="date" id="crear_hire_date" name="hire_date">
      <span class="hint">Necesaria para calcular el saldo de vacaciones.</span>
    </div>
  </div>

  <div class="modal-form-actions">
    <button type="button" class="btn-modal-cancelar" onclick="cerrarModalCrear()">Cancelar</button>
    <button type="submit" class="btn-modal-guardar">Guardar Colaborador</button>
  </div>
</form>
