<%
  const puedeEditar = typeof isAdministrador !== 'undefined' && isAdministrador;
  const mostrarRol = typeof mostrarColumnaRol !== 'undefined' ? mostrarColumnaRol : puedeEditar;
%>

<link rel="stylesheet" href="/css/personal.css">
<link rel="stylesheet" href="/css/phone-chile.css">
<% if (puedeEditar) { %>
<link rel="stylesheet" href="/css/horizontal-forms.css">
<link rel="stylesheet" href="/css/profile-photo-crop.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">
<% } %>

<%
  function pillRol(rol) {
    if (!rol) return 'pill pill-rol-deshabilitado';
    const r = rol.toLowerCase();
    if (r === 'administrador' || r === 'admin') return 'pill pill-rol-admin';
    if (r === 'deshabilitado') return 'pill pill-rol-deshabilitado';
    return 'pill pill-rol-usuario';
  }
%>

<%
  const successMsg = (typeof success !== 'undefined' && success) ? success : null;
  const errorMsg   = (typeof error   !== 'undefined' && error)   ? error   : null;
%>

<div id="popup" class="popup-notification <%= successMsg ? 'success show' : errorMsg ? 'error show' : '' %>">
  <span><%= successMsg || errorMsg || '' %></span>
  <button type="button" class="popup-close" onclick="hidePopup()">×</button>
</div>

<div class="contenedor-personal">
  <div class="page-header page-header--toolbar">
    <div class="page-header__text">
      <h2 class="page-title">Colaboradores de Transworld Chile</h2>
      <p class="page-description"><span id="contadorColaboradores"><%= personas ? personas.length : 0 %></span> colaboradores en el registro</p>
    </div>
    <div class="page-header-actions">
      <a href="/RRHH" class="link-volver">← Volver al menú</a>
      <% if (puedeEditar) { %>
      <button type="button" class="btn-agregar-persona" onclick="abrirModalCrear()">
        <span aria-hidden="true">+</span> Agregar persona
      </button>
      <% } %>
    </div>
  </div>

  <div class="panel">
    <% if (!personas || personas.length === 0) { %>
      <p class="personal-empty">No hay colaboradores registrados.</p>
    <% } else { %>
      <div class="personal-toolbar">
        <label class="personal-search" for="buscarColaborador">
          <span class="personal-search-icon" aria-hidden="true"><%- include('../partials/icon', { name: 'search' }) %></span>
          <input
            type="search"
            id="buscarColaborador"
            placeholder="Buscar por nombre, correo o teléfono..."
            autocomplete="off"
          >
        </label>
        <select id="filtroArea" class="personal-filtro-area" aria-label="Filtrar por área">
          <option value="">Todas las áreas</option>
          <% if (areas && areas.length) { %>
            <% areas.forEach(area => { %>
              <option value="<%= area.area_name %>"><%= area.area_name %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <p id="personalSinResultados" class="personal-sin-resultados" role="status">
        No se encontraron colaboradores con los filtros aplicados.
      </p>
      <table class="tabla-personal" id="tablaPersonal">
        <thead>
          <tr>
            <th>Foto</th>
            <th class="sortable sortable-active" onclick="sortTable(this)">Nombre <span class="sort-arrow">↑</span></th>
            <th class="sortable" onclick="sortTable(this)">Área <span class="sort-arrow">↕</span></th>
            <th class="sortable" onclick="sortTable(this)">Correo <span class="sort-arrow">↕</span></th>
            <th class="sortable" onclick="sortTable(this)">Teléfono <span class="sort-arrow">↕</span></th>
            <th class="sortable" onclick="sortTable(this)">Cumpleaños <span class="sort-arrow">↕</span></th>
            <% if (mostrarRol) { %>
              <th class="sortable" onclick="sortTable(this)">Rol <span class="sort-arrow">↕</span></th>
            <% } %>
            <% if (puedeEditar) { %>
              <th class="sortable" style="text-align:center;" onclick="sortTable(this)">Correo verificado <span class="sort-arrow">↕</span></th>
              <th class="sortable" style="text-align:center;" onclick="sortTable(this)">Intranet <span class="sort-arrow">↕</span></th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% personas.forEach((p, idx) => { %>
            <%
              const firstName  = p.first_name  || '';
              const lastName   = p.last_name   || '';
              const nombreCompleto = [firstName, lastName].filter(Boolean).join(' ') || '-';
              const sortApellido = (lastName || firstName || '').toLowerCase();
              const inicial    = (firstName || lastName).charAt(0).toUpperCase();
              const paletaAvatar = 'avatar-fallback--c' + ((idx % 6) + 1);
              const areaNombre = p.area || '-';
              const correo   = p.email    || '-';
              const telefono = p.phone || '-';
              const telefonoHref = p.telefonoHref || null;
              const rol = p.role || 'Usuario';
              const cumpleSort = p.ordenCumple !== undefined ? p.ordenCumple : 9999;
              const cumpleFmt  = p.fechaCumpleFmt || '-';
              const enIntranet = p.is_intranet_user === true || p.is_intranet_user === 't' || p.is_intranet_user === 1;
              const tieneCorreo = Boolean(p.email && String(p.email).trim());
              const correoVerificado = p.email_confirmed === true || p.email_confirmed === 't' || p.email_confirmed === 1;
            %>
            <tr
              data-area="<%= areaNombre %>"
              data-search="<%= [nombreCompleto, correo !== '-' ? correo : '', telefono !== '-' ? telefono : ''].join(' ').toLowerCase() %>"
            >
              <td>
                <% if (p.photo) { %>
                  <img src="<%= p.photo %>" alt="Foto" class="avatar">
                <% } else { %>
                  <div class="avatar-fallback <%= paletaAvatar %>"><%= inicial %></div>
                <% } %>
              </td>

              <td class="col-nombre" data-sort="<%= sortApellido %>">
                <% if (puedeEditar) { %>
                  <a href="#" class="link-nombre-colaborador link-editar-colaborador" data-id="<%= p.id %>" title="Editar colaborador"><%= nombreCompleto %></a>
                <% } else { %>
                  <span class="nombre-solo"><%= nombreCompleto %></span>
                <% } %>
              </td>

              <td>
                <span class="<%= getWorkAreaPillClass(areaNombre) %>"><%= areaNombre %></span>
              </td>

              <td class="col-correo"><%= correo %></td>
              <td class="col-telefono">
                <% if (telefonoHref) { %>
                  <a href="<%= telefonoHref %>" class="link-nombre-colaborador"><%= telefono %></a>
                <% } else { %>
                  <%= telefono %>
                <% } %>
              </td>

              <td class="col-cumple" data-sort="<%= cumpleSort %>">
                <% if (cumpleFmt !== '-') { %>
                  <%= cumpleFmt %>
                <% } else { %>
                  <span style="color:var(--subtle);">-</span>
                <% } %>
              </td>

              <% if (mostrarRol) { %>
                <td>
                  <span class="<%= pillRol(rol) %>"><%= rol %></span>
                </td>
              <% } %>

              <% if (puedeEditar) { %>
                <td style="text-align:center;" data-sort="<%= !tieneCorreo ? 2 : correoVerificado ? 0 : 1 %>">
                  <% if (!tieneCorreo) { %>
                    <span style="color:var(--subtle);" title="Sin correo registrado">-</span>
                  <% } else if (correoVerificado) { %>
                    <span class="intranet-si" title="Correo verificado">✔</span>
                  <% } else { %>
                    <span class="intranet-no" title="Correo pendiente de verificación">✘</span>
                  <% } %>
                </td>
                <td style="text-align:center;" data-sort="<%= enIntranet ? 0 : 1 %>">
                  <% if (enIntranet) { %>
                    <span class="intranet-si" title="Registrado en intranet">✔</span>
                  <% } else { %>
                    <span class="intranet-no" title="No registrado en intranet">✘</span>
                  <% } %>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<% if (puedeEditar) { %>
  <div id="modalCrearColaborador" class="modal-overlay modal-crear-colaborador" aria-hidden="true">
    <div class="modal-content">
      <button type="button" class="modal-close" onclick="cerrarModalCrear()" aria-label="Cerrar">&times;</button>
      <h2>Agregar Colaborador</h2>
      <p class="modal-crear-desc">Puede agregar a un colaborador con su correo electrónico, o también puede agregar el cumpleaños de un colaborador.</p>
      <div id="crearColaboradorError" class="modal-crear-error" role="alert"></div>
      <%- include('partials/persona_crear_form') %>
    </div>
  </div>

  <div id="modalEditarColaborador" class="modal-overlay modal-editar-colaborador" aria-hidden="true">
    <div class="modal-content">
      <button type="button" class="modal-close" onclick="cerrarModalEditar()" aria-label="Cerrar">&times;</button>
      <div id="editarColaboradorError" class="modal-crear-error" role="alert" style="margin: 16px 20px 0;"></div>
      <div id="modalEditarColaboradorBody">
        <p class="modal-loading">Cargando colaborador…</p>
      </div>
    </div>
  </div>
<% } %>

<script src="/js/email-validate.js"></script>
<script src="/js/phone-chile.js"></script>
<% if (puedeEditar) { %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="/js/profile-photo-cropper.js"></script>
<script src="/js/persona-editar-form.js"></script>
<% } %>
<script>
  const sortDir = { 1: true };

  function filtrarColaboradores() {
    const buscarInput = document.getElementById('buscarColaborador');
    const filtroArea = document.getElementById('filtroArea');
    const tbody = document.querySelector('#tablaPersonal tbody');
    const sinResultados = document.getElementById('personalSinResultados');
    const contador = document.getElementById('contadorColaboradores');
    if (!tbody) return;

    const query = (buscarInput ? buscarInput.value : '').trim().toLowerCase();
    const area = filtroArea ? filtroArea.value : '';
    let visibles = 0;

    tbody.querySelectorAll('tr').forEach((row) => {
      const texto = row.dataset.search || '';
      const areaRow = row.dataset.area || '';
      const coincideBusqueda = !query || texto.includes(query);
      const coincideArea = !area || areaRow === area;
      const mostrar = coincideBusqueda && coincideArea;
      row.style.display = mostrar ? '' : 'none';
      if (mostrar) visibles += 1;
    });

    if (contador) contador.textContent = String(visibles);
    if (sinResultados) sinResultados.classList.toggle('show', visibles === 0);
  }

  function initFiltrosPersonal() {
    const buscarInput = document.getElementById('buscarColaborador');
    const filtroArea = document.getElementById('filtroArea');
    if (buscarInput) buscarInput.addEventListener('input', filtrarColaboradores);
    if (filtroArea) filtroArea.addEventListener('change', filtrarColaboradores);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFiltrosPersonal);
  } else {
    initFiltrosPersonal();
  }

  function sortTable(th) {
    const colIdx = Array.from(th.parentElement.children).indexOf(th);
    const tbody = document.querySelector('#tablaPersonal tbody');
    const rows  = Array.from(tbody.querySelectorAll('tr'));
    const asc   = !sortDir[colIdx];
    sortDir[colIdx] = asc;

    document.querySelectorAll('#tablaPersonal th.sortable').forEach(h => h.classList.remove('sortable-active'));
    th.classList.add('sortable-active');

    rows.sort((a, b) => {
      const cellA = a.querySelectorAll('td')[colIdx];
      const cellB = b.querySelectorAll('td')[colIdx];
      const valA  = (cellA.dataset.sort ?? cellA.innerText).trim().toLowerCase();
      const valB  = (cellB.dataset.sort ?? cellB.innerText).trim().toLowerCase();
      const numA  = parseFloat(valA), numB = parseFloat(valB);
      if (!isNaN(numA) && !isNaN(numB)) return asc ? numA - numB : numB - numA;
      if (valA < valB) return asc ? -1 : 1;
      if (valA > valB) return asc ? 1 : -1;
      return 0;
    });

    rows.forEach(r => tbody.appendChild(r));
  }

  function hidePopup() {
    const popup = document.getElementById('popup');
    if (popup) popup.classList.remove('show');
  }

  function toggleCrearFieldError(el, message) {
    if (!el) return;
    if (message) {
      el.textContent = message;
      el.classList.add('show');
    } else {
      el.textContent = '';
      el.classList.remove('show');
    }
  }

  function limpiarQueryCrear() {
    const url = new URL(window.location.href);
    url.searchParams.delete('crearError');
    url.searchParams.delete('abrirCrear');
    window.history.replaceState({}, document.title, url.pathname + url.search);
  }

  function mostrarErrorCrear(message) {
    const el = document.getElementById('crearColaboradorError');
    if (!el) return;
    if (message) {
      el.textContent = message;
      el.classList.add('show');
    } else {
      el.textContent = '';
      el.classList.remove('show');
    }
  }

  function abrirModalCrear() {
    IntranetModal.open('modalCrearColaborador');
  }

  function cerrarModalCrear() {
    IntranetModal.close('modalCrearColaborador');
    mostrarErrorCrear('');
    limpiarQueryCrear();
  }

  let destroyEditarForm = null;

  function limpiarQueryEditar() {
    const url = new URL(window.location.href);
    url.searchParams.delete('editar');
    url.searchParams.delete('editarError');
    window.history.replaceState({}, document.title, url.pathname + url.search);
  }

  function mostrarErrorEditar(message) {
    const el = document.getElementById('editarColaboradorError');
    if (!el) return;
    if (message) {
      el.textContent = message;
      el.classList.add('show');
    } else {
      el.textContent = '';
      el.classList.remove('show');
    }
  }

  async function abrirModalEditar(id, errorMsg) {
    const body = document.getElementById('modalEditarColaboradorBody');
    if (!body) return;

    mostrarErrorEditar(errorMsg || '');
    body.innerHTML = '<p class="modal-loading">Cargando colaborador…</p>';
    IntranetModal.open('modalEditarColaborador');

    try {
      const res = await fetch(`/RRHH/editar/${encodeURIComponent(id)}?partial=1`, {
        credentials: 'same-origin',
      });
      if (!res.ok) throw new Error('No se pudo cargar el colaborador');
      body.innerHTML = await res.text();
      if (destroyEditarForm) destroyEditarForm();
      destroyEditarForm = typeof initPersonaEditarForm === 'function'
        ? initPersonaEditarForm()
        : null;
    } catch (err) {
      body.innerHTML = '<p class="modal-loading">No se pudo cargar el formulario de edición.</p>';
      mostrarErrorEditar('Error al cargar los datos del colaborador.');
    }
  }

  function cerrarModalEditar() {
    IntranetModal.close('modalEditarColaborador');
    if (destroyEditarForm) {
      destroyEditarForm();
      destroyEditarForm = null;
    }
    const body = document.getElementById('modalEditarColaboradorBody');
    if (body) body.innerHTML = '<p class="modal-loading">Cargando colaborador…</p>';
    mostrarErrorEditar('');
    limpiarQueryEditar();
  }

  function initFormCrearColaborador() {
    const form = document.getElementById('formCrearColaborador');
    if (!form) return;

    const emailInput = document.getElementById('crear_email');
    const emailError = document.getElementById('crear_email-error');
    const fechaInput = document.getElementById('crear_fecha_nacimiento');
    const fechaMark = document.getElementById('crear_fecha_nacimiento_mark');
    const fechaHint = document.getElementById('crear_fecha_nacimiento_hint');
    const telefonoField = document.getElementById('crear_phone_field');
    const telefonoLocal = document.getElementById('crear_telefono_local');
    const telefonoError = document.getElementById('crear_telefono-error');
    const FECHA_REQUERIDA_MSG = 'La fecha de nacimiento es obligatoria para colaboradores sin correo.';

    function syncFechaRequired() {
      if (!fechaInput) return;
      const obligatoria = EmailValidate.isEmpty(emailInput);
      fechaInput.required = obligatoria;
      if (fechaMark) fechaMark.hidden = !obligatoria;
      if (fechaHint) fechaHint.hidden = obligatoria;
      if (!obligatoria) fechaInput.setCustomValidity('');
    }

    EmailValidate.initField(emailInput);
    PhoneChile.initField(telefonoField);

    emailInput?.addEventListener('input', () => {
      toggleCrearFieldError(
        emailError,
        !EmailValidate.isValid(emailInput) ? EmailValidate.ERROR_MSG : '',
      );
      syncFechaRequired();
    });

    telefonoLocal?.addEventListener('input', () => {
      const invalid =
        !PhoneChile.isFieldEmpty(telefonoField) &&
        !PhoneChile.isFieldValid(telefonoField);
      toggleCrearFieldError(telefonoError, invalid ? PhoneChile.ERROR_MSG : '');
    });

    syncFechaRequired();

    form.addEventListener('submit', (event) => {
      let hasError = false;

      if (!EmailValidate.isValid(emailInput)) {
        hasError = true;
        toggleCrearFieldError(emailError, EmailValidate.ERROR_MSG);
        emailInput.reportValidity();
      }

      if (
        !PhoneChile.isFieldEmpty(telefonoField) &&
        !PhoneChile.isFieldValid(telefonoField)
      ) {
        hasError = true;
        toggleCrearFieldError(telefonoError, PhoneChile.ERROR_MSG);
        telefonoLocal.reportValidity();
      }

      if (EmailValidate.isEmpty(emailInput) && !String(fechaInput?.value || '').trim()) {
        hasError = true;
        fechaInput.setCustomValidity(FECHA_REQUERIDA_MSG);
        fechaInput.reportValidity();
      }

      if (hasError) event.preventDefault();
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const popup = document.getElementById('popup');
    if (popup && popup.classList.contains('show')) {
      setTimeout(hidePopup, 4500);
    }

    <% if (puedeEditar) { %>
      initFormCrearColaborador();

      document.querySelectorAll('.link-editar-colaborador').forEach((link) => {
        link.addEventListener('click', (event) => {
          event.preventDefault();
          const id = link.dataset.id;
          if (id) abrirModalEditar(id);
        });
      });

      const crearErrorInicial = <%- JSON.stringify(typeof crearError !== 'undefined' && crearError ? crearError : '') %>;
      const abrirCrearModal = <%= (typeof abrirCrearModal !== 'undefined' && abrirCrearModal) ? 'true' : 'false' %>;
      const editarIdInicial = <%- JSON.stringify(typeof editarId !== 'undefined' && editarId ? editarId : '') %>;
      const editarErrorInicial = <%- JSON.stringify(typeof editarError !== 'undefined' && editarError ? editarError : '') %>;

      if (abrirCrearModal) {
        abrirModalCrear();
        if (crearErrorInicial) mostrarErrorCrear(crearErrorInicial);
      } else if (editarIdInicial) {
        abrirModalEditar(editarIdInicial, editarErrorInicial);
      }
    <% } %>
  });
</script>
