<style>
  .rrhh-section-title {
    color: #003a70;
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 20px 0;
  }

  .rrhh-section-title:not(:first-of-type) {
    margin-top: 35px;
  }

  .grid-opciones-exec {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 25px;
    margin-bottom: 10px;
  }

  .card-opcion-exec {
    background: var(--color-surface, #ffffff);
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 12px;
    padding: 30px 25px;
    text-decoration: none;
    display: flex;
    align-items: flex-start;
    gap: 20px;
    transition: all 0.3s ease;
    box-shadow: var(--shadow-card, 0 2px 5px rgba(0, 0, 0, 0.02));
    color: var(--color-text, #333333);
    position: relative;
  }

  .card-opcion-exec:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 20px rgba(0, 0, 0, 0.08);
    border-color: var(--color-border-strong, #cbd5e0);
    background: var(--color-surface-muted, #f8fafc);
  }

  .card-icon-wrapper {
    background: #eef4ff;
    color: #175cd3;
    width: 55px;
    height: 55px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    flex-shrink: 0;
    border: 1px solid #d1e0ff;
    overflow: hidden;
  }

  .card-icon-wrapper img {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    min-width: 0;
  }

  .card-title {
    color: var(--color-heading, #003a70);
    font-size: 1.25rem;
    font-weight: 800;
    margin: 0;
  }

  .card-desc {
    color: var(--color-text-muted, #718096);
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0;
  }

  .link-type-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 0.5px;
  }

  .badge-interno {
    background: #eef4ff;
    color: #175cd3;
    border: 1px solid #d1e0ff;
  }

  .badge-externo {
    background: #ecfdf3;
    color: #027a48;
    border: 1px solid #abefc6;
  }

  .external-icon {
    font-size: 0.8rem;
    margin-left: 3px;
  }
</style>

<div class="contenedor">
  <div class="page-header">
    <h2 class="page-title">Recursos Humanos</h2>
    <p class="page-description">
      Accede a las herramientas internas y portales externos de gestión.
    </p>
  </div>

  <h3 class="rrhh-section-title">Plataformas Internas</h3>
  <div class="grid-opciones-exec">
    <a href="/RRHH/organigrama" class="card-opcion-exec">
      <span class="link-type-badge badge-interno">Interno</span>
      <div class="card-icon-wrapper"><%- include('../partials/icon', { name: 'building' }) %></div>
      <div class="card-content">
        <h3 class="card-title">Organigrama</h3>
        <p class="card-desc">Estructura general y departamentos.</p>
      </div>
    </a>

    <a href="/RRHH/personal" class="card-opcion-exec">
      <span class="link-type-badge badge-interno">Interno</span>
      <div class="card-icon-wrapper"><%- include('../partials/icon', { name: 'users' }) %></div>
      <div class="card-content">
        <h3 class="card-title">Personal</h3>
        <p class="card-desc">Directorio de contacto de colaboradores.</p>
      </div>
    </a>

    <a href="/RRHH/vacaciones" class="card-opcion-exec">
      <span class="link-type-badge badge-interno">Interno</span>
      <div class="card-icon-wrapper"><%- include('../partials/icon', { name: 'umbrella' }) %></div>
      <div class="card-content">
        <h3 class="card-title">Vacaciones</h3>
        <p class="card-desc">Solicita y gestiona vacaciones (Chile y Perú).</p>
      </div>
    </a>
  </div>

  <h3 class="rrhh-section-title">Portales Externos</h3>
  <div class="grid-opciones-exec">
    <a href="https://transworld.rexmas.com/" target="_blank" rel="noopener noreferrer" class="card-opcion-exec">
      <span class="link-type-badge badge-externo">Externo <span class="external-icon">↗</span></span>
      <div class="card-icon-wrapper">
        <img src="/img/logo_rex.png" alt="Rex+">
      </div>
      <div class="card-content">
        <h3 class="card-title">Rex+</h3>
        <p class="card-desc">Portal del colaborador y liquidaciones.</p>
      </div>
    </a>

    <a href="https://www.achs.cl/" target="_blank" rel="noopener noreferrer" class="card-opcion-exec">
      <span class="link-type-badge badge-externo">Externo <span class="external-icon">↗</span></span>
      <div class="card-icon-wrapper">
        <img src="/img/achs.png" alt="ACHS">
      </div>
      <div class="card-content">
        <h3 class="card-title">ACHS</h3>
        <p class="card-desc">Seguridad y salud ocupacional.</p>
      </div>
    </a>

    <a href="https://www.cajalosandes.cl/" target="_blank" rel="noopener noreferrer" class="card-opcion-exec">
      <span class="link-type-badge badge-externo">Externo <span class="external-icon">↗</span></span>
      <div class="card-icon-wrapper">
        <img src="/img/cajalosandes.png" alt="Caja Los Andes">
      </div>
      <div class="card-content">
        <h3 class="card-title">Caja Los Andes</h3>
        <p class="card-desc">Beneficios, convenios y ahorros.</p>
      </div>
    </a>
  </div>
</div>
