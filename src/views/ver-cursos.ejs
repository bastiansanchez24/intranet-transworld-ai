<style>
    .cursos-container { 
        max-width: 900px; 
        margin: 0 auto; 
        padding: 20px; 
        font-family: 'Montserrat', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
    }
    
    /* --- ESTILOS PARA EL HEADER Y PUNTAJE --- */
    .header-seccion {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #eee;
        padding-bottom: 15px;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .header-info {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: 1;
    }
    
    .puntaje-badge {
        background: linear-gradient(135deg, #003a70, #0056b3);
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 4px 10px rgba(0, 58, 112, 0.2);
        flex-shrink: 0; 
        width: max-content; 
    }
    
    .puntaje-valor {
        font-size: 1.8rem;
        font-weight: 800;
        line-height: 1;
        color: #ffd700;
    }
    
    .puntaje-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
        opacity: 0.9;
        display: flex;
        flex-direction: column;
    }

    /* --- ESTILOS PARA LAS TARJETAS DE CURSOS --- */
    .curso-card { 
        background: white;
        border-radius: 10px; padding: 20px; margin-bottom: 15px; 
        box-shadow: 0 4px 10px rgba(0,0,0,0.05); border-left: 5px solid #28a745; 
        display: flex; justify-content: space-between;
        align-items: center; 
        flex-wrap: wrap; gap: 15px; transition: transform 0.2s, box-shadow 0.2s;
    }
    .curso-card:hover { transform: translateY(-2px); box-shadow: 0 6px 15px rgba(0,0,0,0.1); }
    
    .curso-info { flex: 1; min-width: 250px; }
    .curso-title { font-size: 1.2rem; color: #003a70; margin: 0 0 8px 0; font-weight: 700; }
    .curso-meta { font-size: 0.9rem; color: #666; display: flex; gap: 15px; }
    .curso-meta span { display: flex; align-items: center; gap: 5px; }
    
    .curso-stats { display: flex; gap: 15px; text-align: center; }
    .stat-box { background: #f8f9fa; padding: 10px 15px; border-radius: 8px; border: 1px solid #eee; min-width: 70px; }
    .stat-value { font-size: 1.4rem; font-weight: bold; color: #333; margin: 0; }
    .stat-label { font-size: 0.7rem; color: #777; text-transform: uppercase; margin: 0; font-weight: 600; letter-spacing: 0.5px;}
    .stat-nota { color: #28a745; }
    
    .empty-state { text-align: center; padding: 60px 20px; background: white; border-radius: 10px; color: #666; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
    
    .link-volver { display: inline-block; padding: 10px 20px; background: #f1f3f5; color: #333; text-decoration: none; border-radius: 6px; font-weight: 600; transition: background 0.2s; }
    .link-volver:hover { background: #e2e6ea; }
    
    .btn-academia { display: inline-block; background: #003a70; color: white; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-weight: bold; margin-top: 15px; transition: background 0.3s; }
    .btn-academia:hover { background: #002a52; }
</style>

<div class="cursos-container">
    <div style="margin-bottom: 20px;">
        <a href="javascript:history.back()" class="link-volver">← Volver atrás</a>
    </div>
    
    <div class="header-seccion">
        <div class="header-info">
            <h2 style="color: #003a70; margin: 0; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
                🎓 Mis Cursos Realizados 
            </h2>
            <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-top: 5px;">
                <span style="background: #e2e8f0; color: #4a5568; padding: 4px 12px; border-radius: 20px; font-size: 0.95rem; font-weight: 600;">
                    <%= typeof cursos !== 'undefined' ? cursos.length : 0 %> / <%= typeof totalCursosActivos !== 'undefined' ? totalCursosActivos : 0 %> Cursos
                </span>
                <span style="background: #d4edda; color: #155724; padding: 4px 12px; border-radius: 20px; font-size: 0.95rem; font-weight: 700; border: 1px solid #c3e6cb;">
                    <%= typeof porcentajeAvance !== 'undefined' ? porcentajeAvance : 0 %>% de avance
                </span>
            </div>
        </div>
        
        <div class="puntaje-badge" title="Tus puntos se calculan en base a tu calificación más alta de cada curso">
          <div class="puntaje-valor">
              <%= typeof puntajeTotal !== 'undefined' && puntajeTotal !== null ? Math.round(puntajeTotal) : 0 %>
          </div>
          <div class="puntaje-label">
              <span>Puntos</span>
              <span style="font-size: 0.65rem; color: #a0c4ff;">Totales</span>
          </div>
        </div>
    </div>

    <% if (cursos && cursos.length > 0) { %>
        <% cursos.forEach(curso => { %>
            <div class="curso-card" style="cursor: pointer;" onclick="window.location.href='/cursos/evaluacion/<%= curso.course_id || curso.id %>'">
                <div class="curso-info">
                    <h3 class="curso-title"><%= curso.title %></h3>
                    <div class="curso-meta">
                        <span>Completado el: 
                            <strong>
                                <%= curso.completed_at ? new Date(curso.completed_at).toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' }) : 'N/A' %>
                            </strong>
                        </span>
                    </div>
                </div>
                <div class="curso-stats">
                    <div class="stat-box">
                        <p class="stat-value"><%= curso.attempts %></p>
                        <p class="stat-label">Intentos</p>
                    </div>
                    <div class="stat-box">
                        <p class="stat-value stat-nota"><%= Math.round(curso.score) %>%</p>
                        <p class="stat-label">Aprobación</p>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <div class="empty-state">
            <div style="font-size: 4rem; margin-bottom: 15px;">📚</div>
            <h3 style="color: #003a70; margin-bottom: 10px;">Aún no has completado ningún curso</h3>
            <p>Visita las áreas de la academia, estudia el material y aprueba las evaluaciones para que aparezcan aquí.</p>
            <a href="/cursos" class="btn-academia">Explorar la Academia</a>
        </div>
    <% } %>
</div>