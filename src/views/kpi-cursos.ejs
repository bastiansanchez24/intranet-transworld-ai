<style>
  .kpi-page {
    padding: 0 0 40px;
  }

  .kpi-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
    margin-bottom: 28px;
  }

  .kpi-stat-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 18px 20px;
    box-shadow: 0 2px 8px rgba(0, 58, 112, 0.05);
  }

  .kpi-stat-value {
    font-size: 1.8rem;
    font-weight: 800;
    color: #003a70;
    line-height: 1.1;
  }

  .kpi-stat-label {
    margin-top: 6px;
    font-size: 0.85rem;
    color: #64748b;
    font-weight: 600;
  }

  .main-kpi-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-bottom: 40px;
    align-items: start;
  }

  .kpi-card {
    background: #fff;
    border-radius: 12px;
    padding: 25px;
    box-shadow: 0 4px 20px rgba(0, 58, 112, 0.08);
    border: 1px solid #eef3f9;
  }

  .kpi-card h2 {
    color: #003a70;
    margin-top: 0;
    margin-bottom: 25px;
    font-size: 1.5rem;
    font-weight: 800;
    border-bottom: 2px solid #f0f4f8;
    padding-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .chart-container {
    position: relative;
    height: 350px;
    width: 100%;
    transition: height 0.3s ease;
  }

  .ranking-table-wrapper {
    max-height: 420px;
    overflow: auto;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    margin-top: 20px;
  }

  .ranking-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  .ranking-table th {
    background-color: #003a70;
    color: white;
    padding: 12px 14px;
    text-align: left;
    position: sticky;
    top: 0;
    z-index: 1;
    font-weight: 600;
  }

  .ranking-table td {
    padding: 11px 14px;
    border-bottom: 1px solid #eee;
    color: #444;
    vertical-align: middle;
  }

  .ranking-table tbody tr:hover {
    background-color: #f8fbff;
  }

  .btn-toggle-chart {
    background: none;
    border: none;
    color: #003a70;
    font-weight: bold;
    cursor: pointer;
    text-decoration: underline;
    font-size: 0.95rem;
    padding: 5px 10px;
    border-radius: 4px;
  }

  .btn-toggle-chart:hover {
    background: rgba(0, 58, 112, 0.1);
  }

  .integrante-search-wrap {
    position: relative;
  }

  .integrante-search-input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #cbd5e0;
    border-radius: 8px;
    font-size: 0.95rem;
    box-sizing: border-box;
  }

  .integrante-search-input:focus {
    outline: none;
    border-color: #003a70;
    box-shadow: 0 0 0 3px rgba(0, 58, 112, 0.12);
  }

  .integrante-suggestions {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.1);
    z-index: 20;
    max-height: 280px;
    overflow-y: auto;
    display: none;
  }

  .integrante-suggestions.is-open {
    display: block;
  }

  .integrante-suggestion {
    display: block;
    width: 100%;
    text-align: left;
    border: none;
    background: transparent;
    padding: 12px 14px;
    cursor: pointer;
    border-bottom: 1px solid #f1f5f9;
  }

  .integrante-suggestion:hover {
    background: #f8fbff;
  }

  .integrante-suggestion strong {
    display: block;
    color: #003a70;
    font-size: 0.95rem;
  }

  .integrante-suggestion span {
    color: #64748b;
    font-size: 0.82rem;
  }

  .integrante-panel {
    margin-top: 22px;
    display: none;
  }

  .integrante-panel.is-visible {
    display: block;
  }

  .integrante-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }

  .integrante-header h3 {
    margin: 0 0 4px;
    color: #003a70;
    font-size: 1.25rem;
  }

  .integrante-header p {
    margin: 0;
    color: #64748b;
    font-size: 0.9rem;
  }

  .integrante-summary {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .summary-pill {
    background: #f1f5f9;
    color: #334155;
    border-radius: 999px;
    padding: 6px 12px;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .summary-pill--ok { background: #dcfce7; color: #166534; }
  .summary-pill--warn { background: #fef3c7; color: #92400e; }
  .summary-pill--muted { background: #e2e8f0; color: #475569; }

  .integrante-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .integrante-table th {
    background: #f8fafc;
    color: #475569;
    text-align: left;
    padding: 10px 12px;
    border-bottom: 2px solid #e2e8f0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .integrante-table td {
    padding: 11px 12px;
    border-bottom: 1px solid #edf2f7;
    vertical-align: top;
  }

  .integrante-table tbody tr:hover {
    background: #f8fbff;
  }

  .status-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .status-badge--done { background: #dcfce7; color: #166534; }
  .status-badge--progress { background: #dbeafe; color: #1d4ed8; }
  .status-badge--pending { background: #f1f5f9; color: #64748b; }

  .filter-hint {
    margin: 0 0 14px;
    color: #64748b;
    font-size: 0.88rem;
  }

  .empty-msg {
    text-align: center;
    color: #64748b;
    padding: 24px 12px;
    font-size: 0.92rem;
  }

  @media (max-width: 900px) {
    .main-kpi-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>

<div class="kpi-page">
  <div class="page-header">
    <h2 class="page-title">Dashboard de Capacitaciones</h2>
    <p class="page-description">Ranking general, rendimiento por curso y seguimiento individual de integrantes.</p>
  </div>

  <div class="kpi-stats">
    <div class="kpi-stat-card">
      <div class="kpi-stat-value"><%= stats.total_cursos || 0 %></div>
      <div class="kpi-stat-label">Cursos activos</div>
    </div>
    <div class="kpi-stat-card">
      <div class="kpi-stat-value"><%= stats.integrantes_con_completados || 0 %></div>
      <div class="kpi-stat-label">Integrantes con cursos completados</div>
    </div>
    <div class="kpi-stat-card">
      <div class="kpi-stat-value"><%= stats.total_completados || 0 %></div>
      <div class="kpi-stat-label">Completados en total</div>
    </div>
    <div class="kpi-stat-card">
      <div class="kpi-stat-value"><%= stats.total_en_curso || 0 %></div>
      <div class="kpi-stat-label">En curso actualmente</div>
    </div>
  </div>

  <div class="kpi-card" style="margin-bottom: 30px;">
    <h2>Seguimiento por integrante</h2>
    <p class="filter-hint">Busca por nombre o correo para ver qué cursos inició, cuáles completó, notas e intentos.</p>

    <div class="integrante-search-wrap">
      <input
        type="search"
        id="integranteSearch"
        class="integrante-search-input"
        placeholder="Buscar integrante por nombre o correo..."
        autocomplete="off"
      >
      <div id="integranteSuggestions" class="integrante-suggestions"></div>
    </div>

    <div id="integrantePanel" class="integrante-panel">
      <div class="integrante-header">
        <div>
          <h3 id="integranteName">—</h3>
          <p id="integranteEmail">—</p>
        </div>
        <div class="integrante-summary" id="integranteSummary"></div>
      </div>

      <div class="ranking-table-wrapper">
        <table class="integrante-table">
          <thead>
            <tr>
              <th>Área</th>
              <th>Subárea</th>
              <th>Curso</th>
              <th>Estado</th>
              <th>Nota</th>
              <th>Intentos</th>
              <th>Progreso video</th>
              <th>Completado</th>
            </tr>
          </thead>
          <tbody id="integranteCoursesBody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="main-kpi-row">
    <div class="columna-izquierda" style="min-width: 0;">
      <div class="kpi-card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
          <h2 style="margin-bottom: 0; border: none; padding: 0;">Ranking: Cursos Realizados</h2>
          <button id="btnToggleChart" class="btn-toggle-chart" onclick="toggleRankingChart()">Ver más...</button>
        </div>
        <div id="mainChartContainer" class="chart-container">
          <canvas id="chartGeneral"></canvas>
        </div>

        <div class="ranking-table-wrapper">
          <table class="ranking-table" id="rankingTable">
            <thead>
              <tr>
                <th>#</th>
                <th>Integrante</th>
                <th>Correo</th>
                <th>Completados</th>
                <th>En curso</th>
                <th>Puntaje</th>
              </tr>
            </thead>
            <tbody id="rankingTableBody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="columna-derecha" style="min-width: 0; border-left: 5px solid #ff4500; padding-left: 30px;">
      <div class="kpi-card">
        <h2>Rendimiento por curso</h2>
        <p class="filter-hint">Área y subárea provienen de los campos <strong>section</strong> y <strong>subsection</strong> de cada curso en la base de datos.</p>

        <div style="display: flex; gap: 15px; flex-wrap: wrap; align-items: flex-end;">
          <div style="flex: 1; min-width: 120px;">
            <label style="font-weight: bold; color: #003a70; display: block; margin-bottom: 8px; font-size: 0.9rem;">1. Área</label>
            <select id="selectSeccion" style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #ccc; font-size: 0.9rem;">
              <option value="">-- Área --</option>
            </select>
          </div>

          <div style="flex: 1; min-width: 120px;">
            <label style="font-weight: bold; color: #003a70; display: block; margin-bottom: 8px; font-size: 0.9rem;">2. Subárea</label>
            <select id="selectSubseccion" disabled style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #ccc; font-size: 0.9rem;">
              <option value="">-- Subárea --</option>
            </select>
          </div>

          <div style="flex: 1.5; min-width: 180px;">
            <label style="font-weight: bold; color: #003a70; display: block; margin-bottom: 8px; font-size: 0.9rem;">3. Curso</label>
            <select id="selectCurso" disabled style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #ccc; font-size: 0.9rem;">
              <option value="">-- Curso --</option>
            </select>
          </div>
        </div>
      </div>

      <div class="kpi-card" id="cursoChartWrapper" style="display: none; margin-top: 20px;">
        <h2 id="tituloCursoSeleccionado" style="font-size: 1.1rem; margin-bottom: 15px; color: #003a70; border-bottom: 2px solid #f0f4f8; padding-bottom: 10px;">
          Seleccione un curso
        </h2>
        <p id="cursoChartEmpty" class="empty-msg" style="display: none;"></p>
        <div class="chart-container" id="cursoChartContainer">
          <canvas id="chartCursoUnico"></canvas>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const chartColors = {
    blue: 'rgba(0, 58, 112, 0.8)',
    blueBorder: 'rgba(0, 58, 112, 1)',
    green: 'rgba(40, 167, 69, 0.8)',
    greenBorder: 'rgba(40, 167, 69, 1)'
  };

  function formatMedalName(name, index) {
    if (index === 0) return '1° ' + name;
    if (index === 1) return '2° ' + name;
    if (index === 2) return '3° ' + name;
    return (index + 1) + '. ' + name;
  }

  function formatArea(value) {
    return value && String(value).trim() ? String(value).trim() : 'Sin área';
  }

  function formatSubarea(value) {
    return value && String(value).trim() ? String(value).trim() : 'Sin subárea';
  }

  function formatDate(value) {
    if (!value) return '—';
    return new Date(value).toLocaleDateString('es-CL', {
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    });
  }

  function formatWatchProgress(seconds, required) {
    const watched = Number(seconds || 0);
    const req = Number(required || 0);
    if (!req) return watched > 0 ? 'Visto' : '—';
    const pct = Math.min(100, Math.round((watched / req) * 100));
    return pct + '%';
  }

  const top10Data = <%- JSON.stringify(typeof top10Ranking !== 'undefined' ? top10Ranking : []) %>;
  const allRankingData = <%- JSON.stringify(typeof todosLosRanking !== 'undefined' ? todosLosRanking : []) %>;
  const catalogoCursos = <%- JSON.stringify(typeof catalogoCursos !== 'undefined' ? catalogoCursos : []) %>;
  const kpiPorCurso = <%- JSON.stringify(typeof kpiPorCurso !== 'undefined' ? kpiPorCurso : []) %>;

  let chartGeneralInstance = null;
  let isShowingAll = false;

  function renderRankingTable(data) {
    const tbody = document.getElementById('rankingTableBody');
    if (!tbody) return;
    tbody.innerHTML = data.map((u, i) => `
      <tr>
        <td>${i + 1}</td>
        <td><strong>${u.nombre_usuario}</strong></td>
        <td>${u.email || '—'}</td>
        <td>${u.cursos_completados || 0}</td>
        <td>${u.cursos_en_curso || 0}</td>
        <td><strong>${Math.round(u.puntaje_total || 0)}</strong></td>
      </tr>
    `).join('');
  }

  if (allRankingData.length > 0) {
    renderRankingTable(top10Data);

    const ctxGeneral = document.getElementById('chartGeneral').getContext('2d');
    Chart.register(ChartDataLabels);

    chartGeneralInstance = new Chart(ctxGeneral, {
      type: 'bar',
      data: {
        labels: top10Data.map((u, i) => formatMedalName(u.nombre_usuario, i)),
        datasets: [{
          label: 'Puntaje Total',
          data: top10Data.map(u => parseInt(u.puntaje_total || 0, 10)),
          backgroundColor: chartColors.blue,
          borderColor: chartColors.blueBorder,
          borderWidth: 2,
          borderRadius: 4
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          datalabels: {
            color: '#ffffff',
            anchor: 'end',
            align: 'start',
            offset: 10,
            font: { weight: 'bold', size: 13 },
            formatter: function(value, context) {
              const datasetToUse = isShowingAll ? allRankingData : top10Data;
              const cantidadCursos = datasetToUse[context.dataIndex].cursos_completados;
              if (!value) return '';
              return `${cantidadCursos} ${cantidadCursos === 1 ? 'curso' : 'cursos'}`;
            }
          }
        },
        scales: {
          x: { beginAtZero: true, ticks: { stepSize: 10 }, grid: { color: '#f0f0f0' }, grace: '5%' },
          y: { grid: { display: false }, ticks: { font: { size: 14, weight: 'bold' } } }
        }
      }
    });
  } else {
    document.getElementById('mainChartContainer').innerHTML = '<p class="empty-msg">Aún no hay integrantes con cursos completados.</p>';
    document.getElementById('rankingTableBody').innerHTML = '<tr><td colspan="6" class="empty-msg">Sin datos de ranking</td></tr>';
    document.getElementById('btnToggleChart').style.display = 'none';
  }

  function toggleRankingChart() {
    if (!chartGeneralInstance) return;

    isShowingAll = !isShowingAll;
    const dataToUse = isShowingAll ? allRankingData : top10Data;
    const container = document.getElementById('mainChartContainer');
    const btn = document.getElementById('btnToggleChart');

    if (isShowingAll) {
      container.style.height = Math.max(350, dataToUse.length * 35 + 50) + 'px';
      btn.innerText = 'Ver menos...';
    } else {
      container.style.height = '350px';
      btn.innerText = 'Ver más...';
    }

    chartGeneralInstance.data.labels = dataToUse.map((u, i) => formatMedalName(u.nombre_usuario, i));
    chartGeneralInstance.data.datasets[0].data = dataToUse.map(u => parseInt(u.puntaje_total || 0, 10));
    chartGeneralInstance.update();
    renderRankingTable(dataToUse);
  }

  // --- Filtros área / subárea / curso (catálogo completo) ---
  let chartCursoInstance = null;
  const selectSeccion = document.getElementById('selectSeccion');
  const selectSubseccion = document.getElementById('selectSubseccion');
  const selectCurso = document.getElementById('selectCurso');
  const chartWrapper = document.getElementById('cursoChartWrapper');
  const tituloCursoSeleccionado = document.getElementById('tituloCursoSeleccionado');

  const seccionesUnicas = [...new Set(catalogoCursos.map(c => formatArea(c.section)))];
  seccionesUnicas.forEach(sec => {
    selectSeccion.add(new Option(sec, sec));
  });

  selectSeccion.addEventListener('change', (e) => {
    const sec = e.target.value;
    selectSubseccion.innerHTML = '<option value="">-- Subárea --</option>';
    selectCurso.innerHTML = '<option value="">-- Curso --</option>';
    chartWrapper.style.display = 'none';
    selectCurso.disabled = true;

    if (!sec) {
      selectSubseccion.disabled = true;
      return;
    }

    const dataFiltrada = catalogoCursos.filter(c => formatArea(c.section) === sec);
    const subseccionesUnicas = [...new Set(dataFiltrada.map(c => formatSubarea(c.subsection)))];

    subseccionesUnicas.forEach(subsec => {
      selectSubseccion.add(new Option(subsec, subsec));
    });
    selectSubseccion.disabled = false;

    if (subseccionesUnicas.length === 1) {
      selectSubseccion.value = subseccionesUnicas[0];
      selectSubseccion.dispatchEvent(new Event('change'));
    }
  });

  selectSubseccion.addEventListener('change', (e) => {
    const subsec = e.target.value;
    const sec = selectSeccion.value;
    selectCurso.innerHTML = '<option value="">-- Curso --</option>';
    chartWrapper.style.display = 'none';

    if (!subsec) {
      selectCurso.disabled = true;
      return;
    }

    const dataFiltrada = catalogoCursos.filter(
      c => formatArea(c.section) === sec && formatSubarea(c.subsection) === subsec
    );
    cargarCursos(dataFiltrada);
  });

  function cargarCursos(data) {
    selectCurso.innerHTML = '<option value="">-- Curso --</option>';
    data.forEach(c => {
      selectCurso.add(new Option(c.title, String(c.id)));
    });
    selectCurso.disabled = false;
  }

  selectCurso.addEventListener('change', (e) => {
    const courseId = e.target.value;
    if (!courseId) {
      chartWrapper.style.display = 'none';
      return;
    }

    const cursoCatalogo = catalogoCursos.find(c => String(c.id) === String(courseId));
    const cursoKpi = kpiPorCurso.find(c => String(c.course_id) === String(courseId));

    if (cursoCatalogo) {
      tituloCursoSeleccionado.innerText = `${cursoCatalogo.title} (${formatArea(cursoCatalogo.section)} / ${formatSubarea(cursoCatalogo.subsection)})`;
    }

    if (cursoKpi && cursoKpi.top10 && cursoKpi.top10.length > 0) {
      document.getElementById('cursoChartEmpty').style.display = 'none';
      document.getElementById('cursoChartContainer').style.display = 'block';
      renderizarGraficoCurso(cursoKpi);
      chartWrapper.style.display = 'block';
    } else {
      if (chartCursoInstance) {
        chartCursoInstance.destroy();
        chartCursoInstance = null;
      }
      document.getElementById('cursoChartContainer').style.display = 'none';
      const emptyEl = document.getElementById('cursoChartEmpty');
      emptyEl.textContent = 'Este curso aún no tiene calificaciones registradas.';
      emptyEl.style.display = 'block';
      chartWrapper.style.display = 'block';
    }
  });

  function renderizarGraficoCurso(cursoInfo) {
    const canvas = document.getElementById('chartCursoUnico');
    const ctx = canvas.getContext('2d');

    if (chartCursoInstance) chartCursoInstance.destroy();

    chartCursoInstance = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: cursoInfo.top10.map(u => u.nombre_usuario),
        datasets: [{
          label: 'Nota',
          data: cursoInfo.top10.map(u => parseFloat(u.score)),
          backgroundColor: chartColors.green,
          borderColor: chartColors.greenBorder,
          borderWidth: 1,
          borderRadius: 4
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false }, datalabels: { display: false } },
        scales: {
          x: { beginAtZero: true, max: 100, grid: { color: '#f0f0f0' } },
          y: { grid: { display: false }, ticks: { font: { size: 12 } } }
        }
      }
    });
  }

  // --- Buscador de integrantes ---
  const integranteSearch = document.getElementById('integranteSearch');
  const integranteSuggestions = document.getElementById('integranteSuggestions');
  const integrantePanel = document.getElementById('integrantePanel');
  let searchTimer = null;

  integranteSearch.addEventListener('input', () => {
    clearTimeout(searchTimer);
    const q = integranteSearch.value.trim();
    if (q.length < 2) {
      integranteSuggestions.classList.remove('is-open');
      integranteSuggestions.innerHTML = '';
      return;
    }

    searchTimer = setTimeout(async () => {
      try {
        const res = await fetch('/kpi-cursos/api/integrantes?q=' + encodeURIComponent(q));
        const results = await res.json();
        if (!results.length) {
          integranteSuggestions.innerHTML = '<div class="empty-msg">Sin resultados</div>';
        } else {
          integranteSuggestions.innerHTML = results.map(user => `
            <button type="button" class="integrante-suggestion" data-id="${user.id}">
              <strong>${user.name}</strong>
              <span>${user.email || 'Sin correo'}</span>
            </button>
          `).join('');
        }
        integranteSuggestions.classList.add('is-open');
      } catch (err) {
        console.error(err);
      }
    }, 280);
  });

  integranteSuggestions.addEventListener('click', (e) => {
    const btn = e.target.closest('.integrante-suggestion');
    if (!btn) return;
    cargarIntegrante(btn.dataset.id);
    integranteSuggestions.classList.remove('is-open');
    integranteSearch.value = btn.querySelector('strong').textContent;
  });

  document.addEventListener('click', (e) => {
    if (!e.target.closest('.integrante-search-wrap')) {
      integranteSuggestions.classList.remove('is-open');
    }
  });

  async function cargarIntegrante(userId) {
    try {
      const res = await fetch('/kpi-cursos/api/integrantes/' + userId);
      if (!res.ok) throw new Error('No se pudo cargar el integrante');
      const data = await res.json();

      document.getElementById('integranteName').textContent = data.user.name;
      document.getElementById('integranteEmail').textContent = data.user.email || 'Sin correo';

      document.getElementById('integranteSummary').innerHTML = `
        <span class="summary-pill summary-pill--ok">${data.summary.completados} completados</span>
        <span class="summary-pill summary-pill--warn">${data.summary.en_curso} en curso</span>
        <span class="summary-pill summary-pill--muted">${data.summary.sin_iniciar} sin iniciar</span>
        <span class="summary-pill">${Math.round(data.summary.puntaje_total || 0)} pts</span>
      `;

      const tbody = document.getElementById('integranteCoursesBody');
      if (!data.courses.length) {
        tbody.innerHTML = '<tr><td colspan="8" class="empty-msg">No hay cursos activos en el catálogo.</td></tr>';
      } else {
        tbody.innerHTML = data.courses.map(course => {
          let badgeClass = 'status-badge--pending';
          if (course.status === 'evaluated') badgeClass = 'status-badge--done';
          else if (course.status === 'in_progress') badgeClass = 'status-badge--progress';

          return `
            <tr>
              <td>${formatArea(course.section)}</td>
              <td>${formatSubarea(course.subsection)}</td>
              <td><strong>${course.title}</strong></td>
              <td><span class="status-badge ${badgeClass}">${course.status_label}</span></td>
              <td>${course.score != null ? Math.round(course.score) + '%' : '—'}</td>
              <td>${course.attempts != null ? course.attempts : '—'}</td>
              <td>${formatWatchProgress(course.seconds_watched, course.required_watch_seconds)}</td>
              <td>${formatDate(course.completed_at)}</td>
            </tr>
          `;
        }).join('');
      }

      integrantePanel.classList.add('is-visible');
    } catch (err) {
      console.error(err);
      alert('No se pudo cargar el detalle del integrante.');
    }
  }
</script>
