          <p>Haz clic en tu foto para actualizar tus datos, teléfono y foto de perfil.</p>
        </div>
      </li>
      <li class="home-tutorial__step">
        <span class="home-tutorial__icon" aria-hidden="true">✨</span>
        <div>
          <strong>Asistente IA de Transworld</strong>
          <p>El botón flotante en la esquina inferior te ayuda con consultas sobre la intranet.</p>
        </div>
      </li>
    </ol>

    <div class="home-tutorial__actions">
      <button type="button" id="btnHomeTutorialCerrar" class="modal-button-primary home-tutorial__btn">Entendido, comenzar</button>
    </div>
  </div>
</div>
<% } %>

<% if (typeof isAdministrador !== 'undefined' && isAdministrador) { %>
<div id="modalPlatos" class="modal-overlay modal-editar-menu">
  <div class="modal-content2 modal-content2-large">
    <h3>Editar Menú Semanal</h3>
    <form action="/platos/editar" method="POST">
      <% const dias = ['Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes']; %>
      <% for (let i = 1; i <= 5; i++) { %>
        <% const platoDia = (typeof menuSemanal !== 'undefined' && menuSemanal) ? menuSemanal.find(p => p.day_number === i) : null; %>
        <div class="modal-form-group">
          <label class="modal-form-label"><%= dias[i - 1] %></label>
          <input type="text" name="plato_<%= i %>" value="<%= platoDia ? platoDia.dish_name : '' %>" required class="modal-form-input">
        </div>
      <% } %>
      <div class="modal-actions-row">
        <button type="button" onclick="IntranetModal.close('modalPlatos')" class="modal-button-secondary">Cancelar</button>
        <button type="submit" class="modal-button-primary">Guardar Menú</button>
      </div>
    </form>
  </div>
</div>
<% } %>

<div id="modalVerMenu" class="modal-overlay">
  <div class="modal-content2">
    <button type="button" onclick="IntranetModal.close('modalVerMenu')" class="modal-content2-close" aria-label="Cerrar">&times;</button>
    <h3>Menú de la Semana</h3>
    <div class="modal-list-stack">
      <% for (let i = 1; i <= 5; i++) { %>
        <% const pDia = (typeof menuSemanal !== 'undefined' && menuSemanal) ? menuSemanal.find(p => p.day_number === i) : null; %>
        <div class="modal-list-item">
          <span class="modal-item-label"><%= nombresDiasMenu[i - 1] %></span>
          <span class="modal-item-value"><%= pDia && pDia.dish_name ? pDia.dish_name : 'No definido' %></span>
        </div>
      <% } %>
    </div>
    <div class="modal-footer-center">
      <button type="button" onclick="IntranetModal.close('modalVerMenu')" class="modal-button-primary modal-button-primary-sm">Cerrar</button>
    </div>
  </div>
</div>

<script>
  function toggleCumpleanios() {
    const items = document.querySelectorAll('.item-cumple');
    const btn = document.getElementById('btn-ver-mas-cumple');
    const hayOcultos = Array.from(items).slice(3).some(el => el.classList.contains('is-hidden'));
    if (hayOcultos) {
      items.forEach(el => el.classList.remove('is-hidden'));
      btn.innerText = 'Ver menos...';
    } else {
      items.forEach((el, index) => { if (index >= 3) el.classList.add('is-hidden'); });
      btn.innerText = 'Ver más...';
    }
  }

  let linkedinIndex = 0;
  function moveLinkedin(n) {
    const slides = document.querySelectorAll('.home-comms__slide');
    if (slides.length <= 1) return;
    slides[linkedinIndex].classList.remove('is-active');
    linkedinIndex += n;
    if (linkedinIndex >= slides.length) linkedinIndex = 0;
    if (linkedinIndex < 0) linkedinIndex = slides.length - 1;
    slides[linkedinIndex].classList.add('is-active');
  }

  let homeGalleryIndex = 0;

  function preloadHomeGalleryImage(index) {
    const slides = document.querySelectorAll('.home-gallery__slide');
    if (!slides.length) return;

    const targetIndex = (index + slides.length) % slides.length;
    const img = slides[targetIndex].querySelector('.home-gallery__img');
    if (!img || img.dataset.preloaded === 'true') return;

    const preload = new Image();
    preload.src = img.currentSrc || img.src;
    img.dataset.preloaded = 'true';
  }

  function setHomeGallerySlide(nextIndex) {
    const slides = document.querySelectorAll('.home-gallery__slide');
    const dots = document.querySelectorAll('.home-gallery__dot');
    if (slides.length <= 1) return;

    slides[homeGalleryIndex]?.classList.remove('is-active');
    dots[homeGalleryIndex]?.classList.remove('is-active');

    homeGalleryIndex = (nextIndex + slides.length) % slides.length;

    slides[homeGalleryIndex].classList.add('is-active');
    dots[homeGalleryIndex]?.classList.add('is-active');
    preloadHomeGalleryImage(homeGalleryIndex + 1);
  }

  function moveHomeGallery(n) {
    setHomeGallerySlide(homeGalleryIndex + n);
  }

  function goHomeGallery(index) {
    setHomeGallerySlide(index);
  }

  document.addEventListener('DOMContentLoaded', function () {
    const gallery = document.getElementById('homeGalleryCarousel');
    const slides = document.querySelectorAll('.home-gallery__slide');
    if (!gallery || slides.length <= 1) return;

    gallery.querySelectorAll('.home-gallery__dot').forEach(function (dot) {
      dot.addEventListener('click', function () {
        goHomeGallery(Number(dot.dataset.galleryIndex || 0));
      });
    });
    preloadHomeGalleryImage(homeGalleryIndex + 1);

    let timer = window.setInterval(function () {
      moveHomeGallery(1);
    }, 6500);

    gallery.addEventListener('mouseenter', function () {
      window.clearInterval(timer);
    });

    gallery.addEventListener('mouseleave', function () {
      timer = window.setInterval(function () {
        moveHomeGallery(1);
      }, 6500);
    });
  });

  window.addEventListener('click', function (event) {
    if (event.target.id === 'modalPlatos') IntranetModal.close('modalPlatos');
    if (event.target.id === 'modalVerMenu') IntranetModal.close('modalVerMenu');
  });

  (function initHomeTutorial() {
    const modal = document.getElementById('modalHomeTutorial');
    const btn = document.getElementById('btnHomeTutorialCerrar');
    if (!modal || !btn) return;

    function cerrarTutorial() {
      IntranetModal.close('modalHomeTutorial');
      fetch('/home/tutorial-visto', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
      }).catch(function () {});
    }

    btn.addEventListener('click', cerrarTutorial);

    document.addEventListener('DOMContentLoaded', function () {
      IntranetModal.open('modalHomeTutorial');
    });
    if (document.readyState !== 'loading') {
      IntranetModal.open('modalHomeTutorial');
    }
  })();
</script>
