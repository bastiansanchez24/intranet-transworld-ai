          <span class="home-finance__label">Dólar USD</span>
          <span class="home-finance__value">
            <span><%= (finanzas.dolar && finanzas.dolar.valor) ? finanzas.dolar.valor : '---' %></span>
            <span class="home-finance__trend" aria-hidden="true"><%= financeTrendSymbol(finanzas.dolar.tendencia) %></span>
          </span>
        </a>
        <a href="https://si3.bcentral.cl/IndicadoresSiete/secure/Serie.aspx?gcode=PRE_EUR&param=cgBnAE8AOQBlAGcAIwBiAFUALQBsAEcAYgBOAEkASQBCAEcAegBFAFkAeABkADgASAA2AG8AdgB2AFMAUgBYADIAQwBzAEEARQBMAG8ASgBWADQATABrAGQAZAB1ADIAeQBBAFAAZwBhADIAbABWAHcAXwBXAGgATAAkAFIAVAB1AEIAbAB3AFoAdQBRAFgAZwA5AHgAdgAwACQATwBZADcAMwAuAGIARwBFAFIASwAuAHQA" target="_blank" rel="noopener noreferrer" class="home-finance__item <%= financeTrendClass(finanzas.euro.tendencia) %>" role="listitem">
          <span class="home-finance__label">Euro EUR</span>
          <span class="home-finance__value">
            <span><%= (finanzas.euro && finanzas.euro.valor) ? finanzas.euro.valor : '---' %></span>
            <span class="home-finance__trend" aria-hidden="true"><%= financeTrendSymbol(finanzas.euro.tendencia) %></span>
          </span>
        </a>
        <a href="https://si3.bcentral.cl/IndicadoresSiete/secure/Serie.aspx?gcode=UF&param=RABmAFYAWQB3AGYAaQBuAEkALQAzADUAbgBNAGgAaAAkADUAVwBQAC4AbQBYADAARwBOAGUAYwBjACMAQQBaAHAARgBhAGcAUABTAGUAYwBsAEMAMQA0AE0AawBLAF8AdQBDACQASABzAG0AXwA2AHQAawBvAFcAZwBKAEwAegBzAF8AbgBMAHIAYgBDAC4ARQA3AFUAVwB4AFIAWQBhAEEAOABkAHkAZwAxAEEARAA=" target="_blank" rel="noopener noreferrer" class="home-finance__item <%= financeTrendClass(finanzas.uf.tendencia) %>" role="listitem">
          <span class="home-finance__label">UF</span>
          <span class="home-finance__value">
            <span><%= (finanzas.uf && finanzas.uf.valor) ? finanzas.uf.valor : '---' %></span>
            <span class="home-finance__trend" aria-hidden="true"><%= financeTrendSymbol(finanzas.uf.tendencia) %></span>
          </span>
        </a>
      </div>

      <div class="home-widgets">
        <article class="home-glass home-glass--clickable home-widget home-widget--weather" onclick="window.open('https://www.meteored.cl/tiempo-en_Santiago+de+Chile-America+Sur-Chile-Region+Metropolitana+de+Santiago-SCEL-1-18578.html', '_blank')" title="Ver clima detallado">
          <div class="home-widget__icon" aria-hidden="true">
            <%= (typeof clima !== 'undefined' && clima) ? clima.icon : '☀️' %>
          </div>
          <div class="home-widget__body">
            <span class="home-widget__label">Clima · <%= (typeof clima !== 'undefined' && clima && clima.ubicacion) ? clima.ubicacion : 'Huechuraba' %></span>
            <div class="home-widget__headline">
              <div class="home-widget__value"><%= (typeof clima !== 'undefined' && clima) ? clima.temp : '--' %>°C</div>
              <% if (typeof clima !== 'undefined' && clima && clima.tempMin != null && clima.tempMax != null) { %>
                <span class="home-widget__range"><%= clima.tempMin %>° / <%= clima.tempMax %>°</span>
              <% } %>
            </div>
            <div class="home-widget__sub"><%= (typeof clima !== 'undefined' && clima && clima.desc) ? clima.desc : 'Santiago' %></div>
            <% if (typeof clima !== 'undefined' && clima) { %>
              <div class="home-widget__details">
                <% if (clima.feelsLike != null) { %>
                  <span class="home-widget__detail">Sensación <%= clima.feelsLike %>°</span>
                <% } %>
                <% if (clima.humidity != null) { %>
                  <span class="home-widget__detail">💧 <%= clima.humidity %>%</span>
                <% } %>
                <% if (clima.wind != null) { %>
                  <span class="home-widget__detail">💨 <%= clima.wind %> km/h</span>
                <% } %>
                <% if (clima.lluvia != null) { %>
                  <span class="home-widget__detail">☔ <%= clima.lluvia %>%</span>
                <% } %>
              </div>
              <% if (clima.sunrise || clima.sunset) { %>
                <div class="home-widget__extras home-widget__extras--inline">
                  <% if (clima.sunrise) { %>
                    <span class="home-widget__extra">🌄 <%= clima.sunrise %></span>
                  <% } %>
                  <% if (clima.sunset) { %>
                    <span class="home-widget__extra">🌅 <%= clima.sunset %></span>
                  <% } %>
                </div>
              <% } %>
              <% if (clima.semana && clima.semana.length > 1) { %>
                <ul class="home-widget__forecast" aria-label="Pronóstico semanal">
                  <% clima.semana.slice(1, 6).forEach((dia) => { %>
                    <li class="home-widget__forecast-day">
                      <span class="home-widget__forecast-label"><%= dia.dia %></span>
                      <span class="home-widget__forecast-icon" aria-hidden="true"><%= dia.icon %></span>
                      <span class="home-widget__forecast-temp"><%= dia.tempMin %>°/<%= dia.tempMax %>°</span>
                    </li>
                  <% }); %>
                </ul>
              <% } %>
            <% } %>
          </div>
        </article>

        <article class="home-glass home-widget home-widget--menu">
          <% if (typeof isAdministrador !== 'undefined' && isAdministrador) { %>
            <button type="button" onclick="IntranetModal.open('modalPlatos')" class="home-widget__edit" title="Editar menú semanal" aria-label="Editar menú semanal">✏️</button>
          <% } %>
          <div class="home-widget__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
          </div>
          <div class="home-widget__body">
            <span class="home-widget__label">Menú semanal</span>
            <ul class="home-menu-week" aria-label="Menú de la semana">
              <% for (let i = 1; i <= 5; i++) { %>
                <% const platoDia = (typeof menuSemanal !== 'undefined' && menuSemanal) ? menuSemanal.find(p => p.day_number === i) : null; %>
                <li class="home-menu-week__day<%= i === diaActualMenu ? ' home-menu-week__day--today' : '' %>">
                  <span class="home-menu-week__label"><%= nombresDiasMenu[i - 1] %></span>
                  <span class="home-menu-week__dish"><%= platoDia && platoDia.dish_name ? platoDia.dish_name : 'No definido' %></span>
                </li>
              <% } %>
            </ul>
          </div>
        </article>
      </div>
    </div>

    <aside class="home-quick" aria-label="Accesos rápidos">
      <a href="https://www.transworld.cl/" target="_blank" rel="noopener noreferrer" class="home-glass home-glass--clickable home-quick__card">
        <img src="/img/trw_logohor.png" alt="Transworld">
        <span class="home-quick__title">Sitio Web</span>
        <span class="home-quick__sub">transworld.cl</span>
      </a>
      <a href="/cursos" class="home-glass home-glass--clickable home-quick__card home-quick__card--academy">
        <img src="/img/LOGO-TRANSWORLD-ACADEMY.png" alt="Transworld Academy">
        <span class="home-quick__title">Cursos</span>
        <span class="home-quick__sub">Capacitaciones</span>
      </a>
    </aside>
  </section>

  <!-- Fila inferior: noticias, cumpleaños y comunicaciones -->
  <section class="home-dash home-dash--bottom" aria-label="Noticias y comunicaciones">

    <div class="home-dash__col">
      <!-- Noticias -->
      <section class="home-section home-news" aria-labelledby="home-news-title">
        <div class="home-section__head">
          <h2 class="home-section__title" id="home-news-title">Noticias internas</h2>
          <a href="/noticias" class="home-section__link">Ver todas →</a>
        </div>

        <div class="home-glass home-news__card">
          <% if (tieneDestacada) { %>
            <a href="<%= destacada.link %>" class="home-news__featured">
              <div class="home-news__featured-media">
                <img
                  src="<%= destacada.image || '/img/fondo-home.png' %>"
                  alt="<%= destacada.title %>"
                  class="home-news__featured-img"
                  loading="eager"
                  onerror="this.src='/img/fondo-home.png'"
                >
                <span class="home-news__featured-badge">Destacada</span>
                <div class="home-news__featured-body">
                  <time class="home-news__featured-date" datetime="<%= destacada.fecha.toISOString() %>">
                    <%= formatDateShort(destacada.fecha) %>
                  </time>
                  <h3 class="home-news__featured-title"><%= destacada.title %></h3>
                  <% if (destacada.subtitle) { %>
                    <p class="home-news__featured-sub"><%= destacada.subtitle %></p>
                  <% } %>
                </div>
              </div>
            </a>
          <% } %>

          <% if (listaNoticias.length > 0) { %>
            <ul class="home-news__list" aria-label="<%= tieneDestacada ? 'Más noticias' : 'Noticias recientes' %>">
              <% listaNoticias.forEach((news) => { %>
                <li class="home-news__list-item">
                  <a href="<%= news.link %>" class="home-news__list-link">
                    <% if (news.image) { %>
                      <span class="home-news__list-thumb">
                        <img src="<%= news.image %>" alt="" loading="lazy" onerror="this.parentElement.style.display='none'">
                      </span>
                    <% } %>
                    <span class="home-news__list-date"><%= formatDateShort(news.fecha).toUpperCase() %></span>
                    <span class="home-news__list-title" title="<%= news.title %>"><%= news.title %></span>
                  </a>
                </li>
              <% }); %>
            </ul>
          <% } else if (!tieneDestacada) { %>
            <p class="home-news__empty">No hay noticias recientes.</p>
          <% } %>
        </div>
      </section>

      <!-- Cumpleaños -->
      <section class="home-section home-birthdays" aria-labelledby="home-birthdays-title">
        <div class="home-section__head">
          <h2 class="home-section__title" id="home-birthdays-title">Cumpleaños <%= (typeof mesNombre !== 'undefined') ? mesNombre : '' %></h2>
        </div>

        <div class="home-glass home-birthdays__card">
          <% if (!cumpleaniosOrdenados || cumpleaniosOrdenados.length === 0) { %>
            <p class="home-birthdays__empty">No hay cumpleaños registrados.</p>
          <% } else { %>
            <% const hoyDia = new Date().getDate(); %>
            <div id="lista-cumpleanos" class="home-birthdays__list">
              <% cumpleaniosOrdenados.forEach((p, index) => {
                const ocultoClass = (index >= 3) ? 'is-hidden' : '';
                const esHoy = (Number(p.dia) === hoyDia);
                const iniciales = getInitials(p.nombre);
              %>
                <article class="home-birthday item-cumple<%= esHoy ? ' home-birthday--today' : '' %> <%= ocultoClass %>" aria-label="Cumpleaños de <%= titleCase(p.nombre) %>">
                  <div class="home-birthday__avatar-wrap">
                    <% if (p.photo || p.foto) { %>
                      <img src="<%= p.photo || p.foto %>" alt="" class="home-birthday__avatar" loading="lazy">
                    <% } else { %>
                      <div class="home-birthday__avatar home-birthday__avatar--initials" aria-hidden="true"><%= iniciales %></div>
                    <% } %>
                    <% if (esHoy) { %><span class="home-birthday__dot" title="¡Cumpleaños hoy!"></span><% } %>
                  </div>
                  <div class="home-birthday__info">
                    <h3 class="home-birthday__name"><%= titleCase(p.nombre) %></h3>
                    <p class="home-birthday__area"><%= titleCase(p.area) %></p>
                  </div>
                  <div class="home-birthday__date" aria-label="<%= p.dia %> de <%= mesCorto %>">
                    <span class="home-birthday__date-day"><%= p.dia %></span>
                    <span class="home-birthday__date-month"><%= mesCorto %></span>
                  </div>
                </article>
              <% }); %>
            </div>
            <% if (cumpleaniosOrdenados.length > 3) { %>
              <button type="button" id="btn-ver-mas-cumple" class="home-birthdays__more" onclick="toggleCumpleanios()">Ver más...</button>
            <% } %>
          <% } %>
        </div>
      </section>
    </div>

    <div class="home-dash__col">
      <!-- Galería Transworld -->
      <section class="home-section home-gallery" aria-labelledby="home-gallery-title">
        <div class="home-section__head">
          <div>
            <h2 class="home-section__title" id="home-gallery-title">Galería Transworld</h2>
            <p class="home-section__sub">Disfruta de los momentos más especiales de nuestra empresa</p>
          </div>
          <a href="/marketing/eventos" class="home-section__link">Ver galería →</a>
        </div>

        <div class="home-glass home-gallery__card" id="homeGalleryCarousel">
          <% if (imagenesGaleria.length > 0) { %>
            <% if (imagenesGaleria.length > 1) { %>
              <button type="button" class="home-gallery__nav home-gallery__nav--prev" onclick="moveHomeGallery(-1)" aria-label="Imagen anterior">&#10094;</button>
              <button type="button" class="home-gallery__nav home-gallery__nav--next" onclick="moveHomeGallery(1)" aria-label="Imagen siguiente">&#10095;</button>
            <% } %>

            <div class="home-gallery__viewport">
              <% imagenesGaleria.forEach((item, index) => { %>
                <article class="home-gallery__slide<%= index === 0 ? ' is-active' : '' %>">
                  <a href="/marketing/eventos/<%= item.slug %>" class="home-gallery__link" title="Ver galería de <%= item.name %>">
                    <img
                      src="<%= item.image %>"
                      alt="Imagen de la galería de <%= item.name %>"
                      class="home-gallery__img"
                      loading="<%= index === 0 ? 'eager' : 'lazy' %>"
                      onerror="this.src='/img/fondo-home.png'"
                    >
                    <div class="home-gallery__overlay">
                      <span class="home-gallery__eyebrow">Galería de eventos</span>
                      <h3 class="home-gallery__title"><%= item.name %></h3>
                      <span class="home-gallery__cta">Ver fotos</span>
                    </div>
                  </a>
                </article>
              <% }); %>
            </div>

            <% if (imagenesGaleria.length > 1) { %>
              <div class="home-gallery__dots" aria-label="Paginación de galería">
                <% imagenesGaleria.forEach((item, index) => { %>
                  <button type="button" class="home-gallery__dot<%= index === 0 ? ' is-active' : '' %>" data-gallery-index="<%= index %>" aria-label="Ver imagen <%= index + 1 %>"></button>
                <% }); %>
              </div>
            <% } %>
          <% } else { %>
            <div class="home-gallery__empty">
              <span class="home-gallery__empty-icon" aria-hidden="true">🖼️</span>
              <span>No hay imágenes disponibles en la galería por ahora.</span>
            </div>
          <% } %>
        </div>
      </section>

      <!-- Comunicaciones -->
      <section class="home-section home-comms" aria-labelledby="home-comms-title">
        <div class="home-section__head">
          <h2 class="home-section__title" id="home-comms-title">Comunicaciones</h2>
        </div>

        <div class="home-glass home-comms__frame" id="homeCommsCarousel">
          <button type="button" class="home-comms__nav home-comms__nav--prev" onclick="moveLinkedin(-1)" aria-label="Anterior">&#10094;</button>
          <button type="button" class="home-comms__nav home-comms__nav--next" onclick="moveLinkedin(1)" aria-label="Siguiente">&#10095;</button>

          <% if (typeof linkedinFeed !== 'undefined' && linkedinFeed.length > 0) { %>
            <% linkedinFeed.forEach((post, index) => { %>
              <div class="home-comms__slide<%= index === 0 ? ' is-active' : '' %>">
                <a href="<%= post.link_url %>" target="_blank" rel="noopener noreferrer" class="home-comms__link" title="<%= post.text %>">
                  <% if (post.image_url === '/img/fondo-home.png') { %>
                    <% const parrafos = (post.text || '').split('\n').filter(p => p.trim().length > 0); %>
                    <% const textoResumen = parrafos.slice(0, 2).join('<br><br>'); %>
                    <div class="home-comms__text-card">
                      <div class="home-comms__text-summary"><%- textoResumen %></div>
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="56" height="56" fill="#0a66c2" class="home-comms__linkedin-icon" aria-hidden="true">
                        <path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"></path>
                      </svg>
                      <p class="home-comms__cta">Haga click para ver más...</p>
                    </div>
                  <% } else { %>
                    <img src="<%= post.image_url %>" alt="Publicación LinkedIn" class="home-comms__img<%= post.image_url === '/img/linkedin_off.jpg' ? ' home-comms__img--cover' : '' %>" onerror="this.src='/img/fondo-home.png'">
                  <% } %>
                </a>
              </div>
            <% }); %>
          <% } else { %>
            <div class="home-comms__slide is-active">
              <div class="home-comms__empty">Actualizando comunicaciones...</div>
            </div>
          <% } %>
        </div>
      </section>
    </div>
  </section>

</div>

