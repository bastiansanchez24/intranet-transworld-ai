<div
  id="changePasswordModal"
  class="modal-overlay modal-change-password"
  aria-hidden="true"
>
  <div
    class="modal-content2 modal-content2-large change-password-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="changePasswordTitle"
  >
    <button type="button" class="modal-content2-close" id="changePasswordClose" aria-label="Cerrar">&times;</button>
    <h3 id="changePasswordTitle">Cambiar contraseña</h3>

    <form id="changePasswordForm" class="change-password-form" novalidate>
      <p id="changePasswordError" class="change-password-error" role="alert" hidden></p>

      <div class="change-password-field">
        <label for="old_password">Contraseña actual</label>
        <div class="change-password-wrapper">
          <input type="password" id="old_password" name="old_password" required autocomplete="current-password">
          <button type="button" class="change-password-toggle" data-toggle-password="old_password" aria-label="Mostrar u ocultar contraseña">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
          </button>
        </div>
      </div>

      <div class="change-password-field">
        <label for="new_password">Nueva contraseña</label>
        <div class="change-password-wrapper">
          <input type="password" id="new_password" name="new_password" required minlength="6" autocomplete="new-password">
          <button type="button" class="change-password-toggle" data-toggle-password="new_password" aria-label="Mostrar u ocultar contraseña">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
          </button>
        </div>
      </div>

      <div class="change-password-field">
        <label for="confirm_password">Repetir nueva contraseña</label>
        <div class="change-password-wrapper">
          <input type="password" id="confirm_password" name="confirm_password" required minlength="6" autocomplete="new-password">
          <button type="button" class="change-password-toggle" data-toggle-password="confirm_password" aria-label="Mostrar u ocultar contraseña">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
          </button>
        </div>
      </div>

      <div class="change-password-actions">
        <button type="button" class="btn-perfil" id="changePasswordCancel">Cancelar</button>
        <button type="submit" class="btn-perfil btn-perfil--primary" id="changePasswordSubmit">Actualizar contraseña</button>
      </div>
    </form>
  </div>
</div>
