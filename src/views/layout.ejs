      <a href="/procesos/reglamento">Reglamento interno</a>
      <a href="/procesos/procedimientos">Procedimientos</a>
      <a href="/procesos/otros">Otros documentos</a>
    </div>

    <div class="footer-col">
       <strong>Empresa</strong>
       <a href="https://www.transworld.cl/nosotros/" target="_blank" rel="noopener noreferrer">Nosotros</a>
       <a href="/marketing/eventos">Eventos</a>
       <a href="/noticias">Noticias internas</a>
    </div>

    <div class="footer-col">
      <strong>Ayuda</strong>
      <a href="/sistemas/tickets">Ticketera de Soporte</a>
    </div>

    <div class="footer-col">
      <strong class="footer-heading-accent">Links Externos</strong>
      <a href="https://transworld.mirexmas.com/" target="_blank" rel="noopener noreferrer">Rex+</a>
      <a href="https://www.achs.cl/" target="_blank" rel="noopener noreferrer">ACHS</a>
      <a href="https://www.cajalosandes.cl/" target="_blank" rel="noopener noreferrer">Caja los Andes</a>
      <a href="https://clientes.bciseguros.cl/HomePrivado/LinkLogin" target="_blank" rel="noopener noreferrer">BCI Seguros</a>
      <a href="https://login.salesforce.com/" target="_blank" rel="noopener noreferrer">Salesforce</a>
    </div>

  </div>
</footer>

<% if (currentUser && typeof titulo === 'string' && titulo.toLowerCase().includes('home')) { %>
  <%- include('partials/claude-fab') %>
  <%- include('partials/claude-modal') %>
  <script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.11/dist/purify.min.js"></script>
  <script src="/js/claude-chat.js"></script>
  <script src="/js/claude-modal.js"></script>
<% } %>

<script>
  document.addEventListener('DOMContentLoaded', async function() {
    
    // --- LÓGICA DE MENÚ MÓVIL PRINCIPAL ---
    const menuToggle = document.getElementById('menu-toggle');
    const closeMenu = document.getElementById('close-menu');
    const mobileSidebar = document.getElementById('mobile-sidebar');
    const mobileOverlay = document.getElementById('mobile-overlay');

    function toggleMenu() {
      mobileSidebar.classList.toggle('open');
      mobileOverlay.classList.toggle('open');
    }

    menuToggle.addEventListener('click', toggleMenu);
    closeMenu.addEventListener('click', toggleMenu);
    mobileOverlay.addEventListener('click', toggleMenu);

    // --- LÓGICA DE SUBMENÚS DESPLEGABLES (MÓVIL) ---
    const submenuToggles = document.querySelectorAll('.submenu-toggle');
    submenuToggles.forEach(toggle => {
      toggle.addEventListener('click', function(e) {
        e.preventDefault(); // Evita que la página salte
        
        this.classList.toggle('active');
        
        const submenu = this.nextElementSibling;
        if (submenu && submenu.classList.contains('sub-menu')) {
          submenu.classList.toggle('open');
        }
      });
    });

    // --- MENÚ DE USUARIO EN NAVBAR ---
    const userMenus = document.querySelectorAll('.nav-user-menu');

    function closeUserMenus(exceptMenu) {
      userMenus.forEach((menu) => {
        if (menu === exceptMenu) return;
        menu.classList.remove('is-open');
        const trigger = menu.querySelector('.nav-user-trigger');
        if (trigger) trigger.setAttribute('aria-expanded', 'false');
      });
    }

    userMenus.forEach((menu) => {
      const trigger = menu.querySelector('.nav-user-trigger');
      if (!trigger) return;

      trigger.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        const willOpen = !menu.classList.contains('is-open');
        closeUserMenus(menu);
        menu.classList.toggle('is-open', willOpen);
        trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
      });
    });

    document.addEventListener('click', () => closeUserMenus());
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeUserMenus();
    });


    // --- CÓDIGO EXISTENTE DEL TOAST ---
    const urlParams = new URLSearchParams(window.location.search);
    const okMsg = urlParams.get('ok');
    const flashMsg = urlParams.get('msg');
    // ok=1&msg=... lo maneja la vista (p. ej. listado de personal); evita toast duplicado
    if (okMsg && !(okMsg === '1' && flashMsg)) {
      const toastContainer = document.getElementById('toast-container');
      const toastMessage = document.getElementById('toast-message');
      toastMessage.textContent = decodeURIComponent(okMsg.replace(/\+/g, ' '));
      toastContainer.classList.add('is-visible');

      setTimeout(() => {
        toastContainer.classList.remove('is-visible');
        window.history.replaceState({}, document.title, window.location.pathname);
      }, 4000);
    }

    // --- BURBUJA DE NOTIFICACIONES ---
    function renderTicketBadges(count) {
      const btnsTicket = document.querySelectorAll('.ticket-notif-target');
      btnsTicket.forEach(btn => {
        btn.querySelectorAll('.badge-notif').forEach(badge => badge.remove());

        if (count > 0) {
          const badge = document.createElement('span');
          badge.className = 'badge-notif';
          badge.innerText = count > 99 ? '99+' : count;
          btn.appendChild(badge);
        }
      });
    }

    async function refreshTicketNotifications() {
      if (document.hidden) return;

      try {
        const res = await fetch('/sistemas/tickets/notificaciones/count', {
          cache: 'no-store',
          headers: { 'Accept': 'application/json' }
        });
        const data = await res.json();
        renderTicketBadges(Number(data.count) || 0);
      } catch (error) {
        console.error('Error al cargar notificaciones de tickets:', error);
      }
    }

    refreshTicketNotifications();
    setInterval(refreshTicketNotifications, 30000);
    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) refreshTicketNotifications();
    });

    // --- MODAL ABRIR TICKET DESDE NAVBAR ---
    const ticketModalId = 'modalNuevoTicketNavbar';
    const ticketModal = document.getElementById(ticketModalId);
    const openTicketModalLinks = document.querySelectorAll('.js-open-ticket-modal');
    const closeTicketModalButtons = document.querySelectorAll('[data-ticket-modal-close]');
    const ticketForm = document.getElementById('formCrearTicketNavbar');

    function resetTicketModalStatus() {
      const statusDiv = document.getElementById('ticketModalStatusUpload');
      const hiddenInput = document.getElementById('ticketModalAdjuntosData');
      const fileInput = document.getElementById('ticketModalFileInput');
      if (statusDiv) {
        statusDiv.textContent = 'Sin archivos seleccionados';
        statusDiv.style.color = '#666';
      }
      if (hiddenInput) hiddenInput.value = '[]';
      if (fileInput) fileInput.value = '';
    }

    function prepareTicketModal() {
      if (!ticketForm) return;
      ticketForm.reset();
      resetTicketModalStatus();
      const counter = document.getElementById('ticketModalCounter');
      if (counter) {
        counter.innerText = '0 / 2000';
        counter.style.color = '#666';
        counter.style.fontWeight = 'normal';
      }
      const btnSubmit = document.getElementById('ticketModalSubmit');
      if (btnSubmit) {
        btnSubmit.disabled = false;
        btnSubmit.innerText = 'Enviar Requerimiento';
      }
    }

    openTicketModalLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        if (!window.IntranetModal || !ticketModal) return;
        e.preventDefault();
        prepareTicketModal();
        IntranetModal.open(ticketModalId);
      });
    });

    closeTicketModalButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (!window.IntranetModal || !ticketModal) return;
        resetTicketModalStatus();
        IntranetModal.close(ticketModalId);
      });
    });

    if (ticketForm) {
      const fileInput = document.getElementById('ticketModalFileInput');
      const hiddenInput = document.getElementById('ticketModalAdjuntosData');
      const statusDiv = document.getElementById('ticketModalStatusUpload');
      const btnSubmit = document.getElementById('ticketModalSubmit');
      const btnSelectFiles = document.getElementById('ticketModalSelectFiles');
      const descInput = document.getElementById('ticketModalDescripcion');
      const counter = document.getElementById('ticketModalCounter');

      if (btnSelectFiles && fileInput) {
        btnSelectFiles.addEventListener('click', () => fileInput.click());
      }

      if (fileInput && statusDiv) {
        fileInput.addEventListener('change', () => {
          statusDiv.style.color = '#666';
          statusDiv.textContent = fileInput.files.length
            ? `${fileInput.files.length} archivos listos para subir.`
            : 'Sin archivos seleccionados';
        });
      }

      if (descInput && counter) {
        const refreshCounter = () => {
          const currentLength = descInput.value.length;
          counter.innerText = `${currentLength} / 2000`;
          counter.style.color = currentLength >= 2000 ? '#dc3545' : '#666';
          counter.style.fontWeight = currentLength >= 2000 ? 'bold' : 'normal';
        };
        descInput.addEventListener('input', refreshCounter);
        refreshCounter();
      }

      ticketForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const files = fileInput ? Array.from(fileInput.files || []) : [];
        if (files.length === 0) {
          ticketForm.submit();
          return;
        }

        for (const f of files) {
          const isVideo = f.type.startsWith('video/');
          const limit = isVideo ? 100 * 1024 * 1024 : 10 * 1024 * 1024;
          if (f.size > limit) {
            alert(`Archivo muy pesado: ${f.name}`);
            return;
          }
        }

        try {
          btnSubmit.disabled = true;
          btnSubmit.innerText = 'Subiendo archivos...';
          statusDiv.style.color = '#e67e22';
          statusDiv.innerHTML = 'Iniciando subida...';

          const uploadedList = [];
          for (const file of files) {
            const formData = new FormData();
            formData.append('file', file);

            let dbType = 'doc';
            if (file.type.startsWith('video/')) dbType = 'video';
            else if (file.type.startsWith('image/')) dbType = 'image';
            else if (file.type === 'application/pdf') dbType = 'pdf';

            const resUp = await fetch('/sistemas/tickets/upload', { method: 'POST', body: formData });
            if (!resUp.ok) throw new Error('Fallo subida');
            const data = await resUp.json();

            uploadedList.push({ url: data.secure_url, nombre: file.name, tipo: dbType });
          }

          hiddenInput.value = JSON.stringify(uploadedList);
          statusDiv.style.color = 'green';
          statusDiv.innerHTML = 'Listo. Creando ticket...';
          ticketForm.submit();
        } catch (err) {
          console.error(err);
          statusDiv.style.color = 'red';
          statusDiv.innerHTML = 'Error';
          btnSubmit.disabled = false;
          btnSubmit.innerText = 'Enviar Requerimiento';
        }
      });

      if (ticketModal) {
        ticketModal.addEventListener('transitionend', () => {
          if (!ticketModal.classList.contains('is-open')) {
            resetTicketModalStatus();
            btnSubmit.disabled = false;
            btnSubmit.innerText = 'Enviar Requerimiento';
          }
        });
      }
    }
  });
</script>

</body>
</html>