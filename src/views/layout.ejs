<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/theme-head') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= formatPageTitle(titulo) %></title>
    <link rel="stylesheet" href="/css/intranet.css">
    <link rel="stylesheet" href="/css/home.css">
    <% if (typeof usuario !== 'undefined' && usuario) { %>
    <link rel="stylesheet" href="/css/claude-fab.css">
    <link rel="stylesheet" href="/css/claude-chat.css">
    <% } %>
    <script src="/js/modal.js"></script>
</head>

<body>

  <div id="toast-container">
    <div class="toast-success">
      <span>✓</span>
      <span id="toast-message">Operación exitosa</span>
    </div>
  </div>

  <% 
    const currentUser = (typeof usuario !== 'undefined' && usuario) ?
    usuario : ((typeof user !== 'undefined' && user) ? user : null);
    let displayName = 'Usuario';
    if (currentUser) {
      if (currentUser.username) displayName = currentUser.username;
      else if (currentUser.first_name) displayName = currentUser.first_name + (currentUser.last_name ? ' ' + currentUser.last_name : '');
      else if (currentUser.name) displayName = currentUser.name;
    }
  %>

<div class="mobile-overlay" id="mobile-overlay"></div>
<nav class="mobile-sidebar" id="mobile-sidebar">
  <span class="close-btn" id="close-menu">&times;</span>

  <a href="/sistemas/tickets/nuevo" class="btn-ticket-mobile js-open-ticket-modal" title="Abrir nuevo ticket de soporte">ABRIR TICKET</a>

  <a href="/noticias">NOTICIAS</a>
  
  <a href="#" class="submenu-toggle">PROCESOS Y DOCUMENTOS <span class="arrow">▾</span></a>
  <div class="sub-menu">
    <a href="/procesos/procedimientos">Procedimientos</a>
    <a href="/procesos/protocolos">Protocolos</a>
    <a href="/procesos/reglamento">Reglamento interno</a>
    <a href="/procesos/otros">Otros documentos</a>
  </div>

  <a href="#" class="submenu-toggle">RRHH <span class="arrow">▾</span></a>
  <div class="sub-menu">
    <a href="/RRHH/organigrama">Organigrama</a>
    <a href="/RRHH/personal">Personal</a>
    <a href="https://transworld.mirexmas.com/" target="_blank">Rex+</a>
    <a href="https://www.achs.cl/" target="_blank">ACHS</a>
    <a href="https://www.cajalosandes.cl/" target="_blank">Caja los Andes</a>
  </div>

  <a href="/marketing/eventos">GALERÍA</a>

  <a href="/apps">APLICACIONES</a>
  <a href="/sistemas/tickets" class="ticket-notif-target">SOPORTE</a>

  <% if (currentUser) { %>
    <div class="nav-user-menu nav-user-menu--mobile">
      <button type="button" class="user-name nav-user-link nav-user-trigger" aria-expanded="false" aria-haspopup="true" aria-label="Abrir menú de usuario">
        <% if (currentUser.photo || currentUser.foto) { %>
          <img src="<%= currentUser.photo || currentUser.foto %>" alt="Foto" class="nav-user-photo">
        <% } else { %>
          <div class="nav-user-avatar">
            <%= displayName.charAt(0).toUpperCase() %>
          </div>
        <% } %>
      </button>
      <div class="nav-user-dropdown" role="menu">
        <a href="/perfil" role="menuitem">Mi Perfil</a>
        <a href="/logout" role="menuitem">Cerrar Sesión</a>
      </div>
    </div>
  <% } %>
</nav>

<header>
  <div class="header-inner">
    
    <div class="header-left">
      <button class="menu-toggle" id="menu-toggle">☰</button>
      
      <div class="logo-container">
        <a href="/" title="Ir al Inicio">
          <img src="/img/PNG-LOGO-TW-2.png" alt="Transworld" class="logo-tw">
        </a>
      </div>
    </div>

    <nav class="main-nav">      
      <div class="nav-item"><a href="/noticias">NOTICIAS</a></div>
      <div class="nav-item">
        <a href="/procesos">PROCESOS Y DOCUMENTOS</a>
        <div class="dropdown-menu">
          <a href="/procesos/procedimientos">Procedimientos</a>
          <a href="/procesos/protocolos">Protocolos</a>
          <a href="/procesos/reglamento">Reglamento interno</a>
          <a href="/procesos/otros">Otros documentos</a>
        </div>
      </div>
      <div class="nav-item">
        <a href="/RRHH">RRHH</a>
        <div class="dropdown-menu">
          <a href="/RRHH/organigrama">Organigrama</a>
          <a href="/RRHH/personal">Personal</a>
          <a href="https://transworld.mirexmas.com/" target="_blank" rel="noopener noreferrer">Rex+</a>
          <a href="https://www.achs.cl/" target="_blank" rel="noopener noreferrer">ACHS</a>
          <a href="https://www.cajalosandes.cl/" target="_blank" rel="noopener noreferrer">Caja los Andes</a>
        </div>
      </div>
      <div class="nav-item"><a href="/marketing/eventos">GALERÍA</a></div>
      <div class="nav-item"><a href="/apps">APPS</a></div>
      <div class="nav-item"><a href="/sistemas/tickets" class="ticket-notif-target">SOPORTE</a></div>

    </nav>
    
    <div class="header-right">
      <a href="/sistemas/tickets/nuevo" class="btn-ticket-nav js-open-ticket-modal" title="Abrir nuevo ticket de soporte">Abrir Ticket</a>

      <div class="social-nav">
        <a href="https://www.linkedin.com/company/transworldpowerandtelecom" target="_blank" title="LinkedIn">
           <svg class="social-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="40" height="40" rx="4" fill="#0077B5"/>
            <path d="M12.5 30H8.5V16H12.5V30ZM10.5 14.4C9.2 14.4 8.2 13.4 8.2 12.2C8.2 11 9.2 10 10.5 10C11.8 10 12.8 11 12.8 12.2C12.8 13.4 11.8 14.4 10.5 14.4ZM31.5 30H27.5V22.8C27.5 21 26.8 19.8 25.2 19.8C24 19.8 23.3 20.6 23 21.4C22.9 21.7 22.9 22.1 22.9 22.5V30H18.9C18.9 30 19 17.1 18.9 16H22.9V18.2C23.4 17.3 24.6 16 26.8 16C29.6 16 31.5 17.9 31.5 22.1V30Z" fill="white"/>
           </svg>
        </a>
        <a href="https://www.youtube.com/@transworld-tv" target="_blank" title="YouTube">
          <svg class="social-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="40" height="40" rx="4" fill="#FF0000"/>
            <g transform="translate(20, 20) scale(1.5) translate(-20, -20)">
              <path d="M29.2 14.2C29 13.5 28.5 13 27.8 12.8C26.5 12.5 21.5 12.5 21.5 12.5C21.5 12.5 16.5 12.5 15.2 12.8C14.5 13 14 13.5 13.8 14.2C13.5 15.5 13.5 18.2 13.5 18.2C13.5 18.2 13.5 21 13.8 22.2C14 22.9 14.5 23.4 15.2 23.6C16.5 24 21.5 24 21.5 24C21.5 24 26.5 24 27.8 23.6C28.5 23.4 29 22.9 29.2 22.2C29.5 21 29.5 18.2 29.5 18.2C29.5 18.2 29.5 15.5 29.2 14.2ZM19.8 20.7V15.7L24.2 18.2L19.8 20.7Z" fill="white"/>
            </g>
          </svg>
        </a>
        <a href="https://login.salesforce.com/" target="_blank" class="nav-social-icon" title="Salesforce">
          <img src="https://upload.wikimedia.org/wikipedia/commons/f/f9/Salesforce.com_logo.svg" alt="Salesforce" class="salesforce-logo">
        </a>
      </div>

      <% if (currentUser) { %>
        <div class="nav-user nav-user-menu">
          <button type="button" class="user-name nav-user-link nav-user-trigger" aria-expanded="false" aria-haspopup="true" aria-label="Abrir menú de usuario">
            <% if (currentUser.photo || currentUser.foto) { %>
              <img src="<%= currentUser.photo || currentUser.foto %>" alt="Foto" class="nav-user-photo">
            <% } else { %>
              <div class="nav-user-avatar">
                <%= displayName.charAt(0).toUpperCase() %>
              </div>
            <% } %>
          </button>
          <div class="nav-user-dropdown" role="menu">
            <a href="/perfil" role="menuitem">Mi Perfil</a>
            <a href="/logout" role="menuitem">Cerrar Sesión</a>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</header>

<main>
    <div class="contenedor-principal">
        <%- body %>
    </div>
</main>

<% if (currentUser) { %>
<div id="modalNuevoTicketNavbar" class="modal-overlay modal-ticket-navbar" role="dialog" aria-modal="true" aria-labelledby="ticket-modal-title" aria-hidden="true">
  <div class="modal-content modal-ticket-navbar-content">
    <button type="button" class="ticket-modal-close" aria-label="Cerrar modal de ticket" data-ticket-modal-close>&times;</button>
    <h3 id="ticket-modal-title" class="ticket-modal-title">Abrir Nuevo Ticket de Soporte</h3>
    <p class="ticket-modal-description">Describe tu problema o requerimiento tecnico a continuacion.</p>

    <div class="ticket-modal-user-box">
      <p>
        <strong>Solicitante:</strong>
        <%= currentUser ? (currentUser.username || displayName) : 'Usuario' %>
        <span>(<%= currentUser && currentUser.email ? currentUser.email : 'Sin correo' %>)</span>
      </p>
    </div>

    <form id="formCrearTicketNavbar" action="/sistemas/tickets/crear" method="POST" class="ticket-modal-form">
      <label for="ticketModalTitulo">Resumen del problema (Titulo)</label>
      <input type="text" id="ticketModalTitulo" name="title" placeholder="Ej: No puedo acceder a la carpeta compartida de Ventas" required>

      <div class="ticket-modal-row">
        <div>
          <label for="ticketModalCategoria">Categoria</label>
          <select id="ticketModalCategoria" name="category">
            <option value="SAP">Soporte Tecnico</option>
            <option value="Salesforce">Software / ERP</option>
            <option value="Intranet">Infraestructura / Red</option>
            <option value="Hardware">Hardware (Impresoras, PC, etc.)</option>
            <option value="Otro" selected>Otro</option>
          </select>
        </div>
        <div>
          <label for="ticketModalPrioridad">Prioridad sugerida</label>
          <select id="ticketModalPrioridad" name="priority">
            <option value="low">Baja (No impide trabajar)</option>
            <option value="medium" selected>Media (Dificulta el trabajo)</option>
            <option value="high">Alta (Urgente / Operacion detenida)</option>
          </select>
        </div>
      </div>

      <label for="ticketModalDescripcion">Descripcion detallada</label>
      <textarea id="ticketModalDescripcion" name="description" placeholder="Explica detalladamente que sucede..." required maxlength="2000"></textarea>
      <div id="ticketModalCounter" class="ticket-modal-counter">0 / 2000</div>

      <label class="ticket-modal-files-label">Adjuntar archivos (Opcional)</label>
      <input type="hidden" name="adjuntos_data" id="ticketModalAdjuntosData" value="[]">
      <div class="ticket-modal-upload-row">
        <button type="button" class="btn-secundario" id="ticketModalSelectFiles">Seleccionar archivos</button>
        <span id="ticketModalStatusUpload" class="ticket-modal-upload-status">Sin archivos seleccionados</span>
      </div>
      <input type="file" id="ticketModalFileInput" multiple accept="image/*,video/*,.pdf,.doc,.docx" hidden>

      <div class="ticket-modal-actions">
        <button type="button" class="btn-secundario" data-ticket-modal-close>Cancelar</button>
        <button type="submit" class="btn-primario" id="ticketModalSubmit">Enviar Requerimiento</button>
      </div>
    </form>
  </div>
</div>
<% } %>

