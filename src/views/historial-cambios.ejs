<style>
  /* --- ESTILOS BASE EJECUTIVOS PARA TABLAS Y LISTADOS --- */
  .contenedor { max-width: 1100px; margin: 0 auto; padding: 20px; font-family: system-ui, -apple-system, sans-serif; }
  .page-title, h2 { color: #003a70; font-size: 1.8rem; font-weight: 800; margin: 0 0 10px 0; border-bottom: 2px solid #003a70; padding-bottom: 10px; }
  .page-description, p { color: #4a5568; font-size: 1rem; margin-bottom: 25px; }

  .link-volver { display: inline-flex; align-items: center; gap: 6px; background: #f8fafc; border: 1px solid #cbd5e0; color: #4a5568; padding: 8px 15px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; margin-bottom: 20px;}
  .link-volver:hover { background: #edf2f7; color: #1a202c; }

  .panel { background: #fff; border: 1px solid #e0e6ed; border-radius: 8px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); margin-bottom: 25px; overflow-x: auto; }

  table, .tabla, .tabla-simple { width: 100% !important; border-collapse: collapse !important; font-size: 0.95rem; text-align: left; }
  th { background-color: #f8fafc !important; color: #4a5568 !important; font-weight: 700 !important; text-transform: uppercase; font-size: 0.8rem; padding: 14px 15px !important; border-bottom: 2px solid #e2e8f0 !important; }
  td { padding: 14px 15px !important; border-bottom: 1px solid #edf2f7 !important; color: #2d3748 !important; vertical-align: middle; }
  tr:hover td { background-color: #f1f5f9 !important; }

  /* Botones generales */
  .btn-primario, .boton-opcion { background: #003a70 !important; color: #fff !important; border: none; padding: 10px 20px; border-radius: 6px; font-weight: bold; cursor: pointer; transition: background 0.2s, transform 0.1s; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-size: 0.95rem;}
  .btn-primario:hover, .boton-opcion:hover { background: #002a52 !important; transform: translateY(-1px); }
</style>
<div class="contenedor">
  <div style="margin-bottom: 20px;">
    <a href="/RRHH/personal" class="link-volver" style="text-decoration: none; color: #555;">← Volver a Gestión de Usuarios</a>
  </div>

  <h2 class="page-title">Historial de Cambios</h2>
  <p class="page-description">Últimos 100 movimientos registrados en la plataforma.</p>

  <div class="panel">
    <table class="tabla" style="width: 100%; border-collapse: collapse;">
      <thead>
        <tr style="background-color: #f4f6f9; text-align: left;">
          <th style="padding: 12px; border-bottom: 2px solid #ddd;">Fecha</th>
          <th style="padding: 12px; border-bottom: 2px solid #ddd;">Usuario</th>
          <th style="padding: 12px; border-bottom: 2px solid #ddd;">Acción</th>
          <th style="padding: 12px; border-bottom: 2px solid #ddd;">Sección</th>
          <th style="padding: 12px; border-bottom: 2px solid #ddd;">Enlace</th>
        </tr>
      </thead>
      <tbody>
        <% if (!historial || historial.length === 0) { %>
          <tr>
            <td colspan="5" style="padding: 20px; text-align: center; color: #777;">No hay registros en el historial.</td>
          </tr>
        <% } else { %>

          <% historial.forEach(h => { %>
            <tr style="border-bottom: 1px solid #eee;">
              <td style="padding: 12px; color: #555;">
                <% if (h.created_at) { %>
                  <%= new Date(h.created_at).toLocaleString('es-CL', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                <% } else { %>
                  -
                <% } %>
              </td>

              <td style="padding: 12px; font-weight: bold; color: #003a70;">
                <% if (h.first_name) { %>
                  <%= h.first_name %> <%= h.last_name %>
                <% } else { %>
                  <span style="color: #999; font-style: italic;">Usuario eliminado (ID: <%= h.user_id %>)</span>
                <% } %>
              </td>

              <td style="padding: 12px;">
                <% 
                  let color = '#777';
                  let bg = '#eee';
                  const accion = (h.action || '').toLowerCase();
                  
                  if (accion.includes('crear') || accion.includes('subió') || accion.includes('publicó')) { 
                      color = '#155724'; bg = '#d4edda'; // Verde
                  } else if (accion.includes('eliminar') || accion.includes('eliminó')) { 
                      color = '#721c24'; bg = '#f8d7da'; // Rojo
                  } else if (accion.includes('editar') || accion.includes('actualizó') || accion.includes('cerrar')) { 
                      color = '#856404'; bg = '#fff3cd'; // Amarillo
                  }
                %>
                <span style="background-color: <%= bg %>; color: <%= color %>; padding: 4px 8px; border-radius: 4px; font-size: 0.85rem; font-weight: 600;">
                  <%= h.action || 'Acción desconocida' %>
                </span>
              </td>

              <td style="padding: 12px; color: #333;">
                <%= h.section || '-' %>
              </td>

              <td style="padding: 12px;">
                <% if (h.link_path && h.link_path !== '#' && h.link_path.trim() !== '') { %>
                  <a href="<%= h.link_path %>" target="_blank" style="color: #003a70; text-decoration: none;">Ver</a>
                <% } else { %>
                  <span style="color: #ccc;">-</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
          
        <% } %>
      </tbody>
    </table>
  </div>
</div>