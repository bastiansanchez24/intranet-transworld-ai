<style>
  .contenedor { max-width: 800px; margin: 0 auto; padding: 20px; font-family: system-ui, -apple-system, sans-serif; }
  .page-title, h2 { color: #003a70; font-size: 1.8rem; font-weight: 800; margin: 0 0 10px 0; border-bottom: 2px solid #003a70; padding-bottom: 10px; }
  .page-description { color: #4a5568; font-size: 1rem; margin-bottom: 25px; }
  
  .link-volver { display: inline-block; background: #f8fafc; border: 1px solid #cbd5e0; color: #4a5568; padding: 8px 15px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; margin-bottom: 20px;}
  .link-volver:hover { background: #edf2f7; color: #1a202c; }
  
  .panel { background: #fff; border: 1px solid #e0e6ed; border-radius: 8px; padding: 25px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); margin-bottom: 25px; }
  
  .form-ticket label { font-weight: 700; color: #4a5568; display: block; margin-bottom: 6px; font-size: 0.95rem; }
  .form-ticket input[type="text"], .form-ticket textarea { width: 100%; padding: 12px; border: 1px solid #cbd5e0; border-radius: 6px; font-size: 0.95rem; background: #f8fafc; box-sizing: border-box; transition: all 0.2s; font-family: inherit;}
  .form-ticket input:focus, .form-ticket textarea:focus { border-color: #003a70; outline: none; background: #fff; box-shadow: 0 0 0 3px rgba(0, 58, 112, 0.1);}
  
  .btn-primario { background: #003a70; color: #fff; border: none; padding: 12px 24px; border-radius: 6px; font-weight: bold; cursor: pointer; transition: background 0.2s; font-size: 1rem; }
  .btn-primario:hover { background: #002a52; }
  .mensaje-error { color: #e53e3e; background: #fff5f5; border: 1px solid #feb2b2; padding: 12px; border-radius: 6px; font-weight: 600; margin-bottom: 20px;}
</style>

<div class="contenedor" style="max-width: 600px; margin: 0 auto;">
  <div style="margin-bottom: 20px;">
    <a href="/marketing/eventos/<%= evento.slug %>" class="link-volver">← Cancelar y volver</a>
  </div>

  <h2 class="page-title">Editar Evento</h2>
  <p class="page-description">Modifica el nombre o la descripción del evento.</p>

  <div class="panel">
    <form action="/marketing/eventos/<%= evento.slug %>/editar" method="POST" class="form-ticket">
      
      <label for="nombre" style="font-weight: bold; display: block; margin-bottom: 5px;">Nombre del Evento</label>
      <input type="text" id="nombre" name="name" value="<%= evento.name %>" required 
             style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 1rem;">

      <label for="descripcion" style="font-weight: bold; display: block; margin-bottom: 5px;">Descripción</label>
      <textarea id="descripcion" name="description" rows="4" 
                style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-family: inherit; resize: none;"><%= evento.description %></textarea>

      <div style="margin-top: 25px; text-align: right;">
        <button type="submit" class="btn btn-primario">Guardar Cambios</button>
      </div>
    </form>
  </div>
</div>