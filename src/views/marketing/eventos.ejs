<style>

  .contenedor { max-width: 1200px; margin: 0 auto; padding: 20px; font-family: system-ui, -apple-system, sans-serif; }
  .page-title { color: #003a70; font-size: 1.8rem; font-weight: 800; margin: 0 0 10px 0; border-bottom: 2px solid #003a70; padding-bottom: 10px; }
  .page-description { color: #4a5568; font-size: 1rem; margin-bottom: 25px; }
  .no-data { text-align: center; padding: 40px; color: #718096; background: #f8fafc; border-radius: 8px; border: 1px dashed #cbd5e0; }
  .boton-opcion {
    background-color: var(--color-surface, #ffffff);
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 10px;
    padding: 15px 20px;
    text-decoration: none;
    color: var(--color-heading, #003a70);
    font-size: 1.1rem;
    font-weight: 800;
    display: inline-flex;
    flex-direction: column;
    transition: all 0.2s;
    box-shadow: var(--shadow-card, 0 2px 4px rgba(0,0,0,0.02));
  }
  .boton-opcion:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-lg, 0 8px 15px rgba(0,0,0,0.06));
    border-color: var(--color-border-strong, #cbd5e0);
    background: var(--color-surface-muted, #f8fafc);
  }
  .boton-opcion span { margin-top: 6px; font-size: 0.85rem; color: var(--color-text-muted, #718096); font-weight: 600; }
  .eventos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 25px; margin-top: 25px; }
  .card-evento-modern { background: var(--color-surface, #fff); border-radius: 8px; overflow: hidden; box-shadow: var(--shadow-card, 0 2px 5px rgba(0,0,0,0.04)); transition: transform 0.2s, box-shadow 0.2s; border: 1px solid var(--color-border, #e0e6ed); display: flex; flex-direction: column; position: relative; }
  .card-evento-modern:hover { transform: translateY(-5px); box-shadow: 0 8px 15px rgba(0,0,0,0.1); }
  .evento-link { text-decoration: none; color: inherit; display: flex; flex-direction: column; flex-grow: 1; }
  .evento-img-container { width: 100%; height: 180px; background-color: var(--color-surface-muted, #f8fafc); overflow: hidden; display: flex; align-items: center; justify-content: center; border-bottom: 1px solid var(--color-border, #e0e6ed); }
  .evento-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .card-evento-modern:hover .evento-img { transform: scale(1.05); }
  .folder-icon-placeholder { font-size: 3.5rem; color: #cbd5e0; }
  .evento-info { padding: 15px; background: var(--color-surface, #fff); }
  .evento-titulo { font-size: 1.1rem; font-weight: 800; color: var(--color-heading, #003a70); margin-bottom: 5px; line-height: 1.3; }
  .evento-desc { font-size: 0.85rem; color: var(--color-text-muted, #4a5568); margin-top: 5px; }
  .evento-actions { padding: 10px 15px; background-color: var(--color-surface-muted, #f8fafc); border-top: 1px solid var(--color-border, #e0e6ed); text-align: right; }
  .btn-delete { background: none; border: none; color: #e53e3e; font-size: 0.85rem; font-weight: 700; cursor: pointer; padding: 0; }
  .btn-delete:hover { text-decoration: underline; color: #c53030; }
</style>

<div class="contenedor">
  <h2 class="page-title">Eventos y Galerías</h2>
  <p class="page-description">Selecciona un evento para ver su galería de fotos.</p>

  <% if (can.eventos_write) { %>
    <div style="margin-bottom: 20px;">
      <a class="boton-opcion" href="/marketing/eventos/nuevo">
        + Crear nuevo evento
        <span>Generar una nueva carpeta para subir fotos.</span>
      </a>
    </div>
  <% } %>

  <% if (!eventos || eventos.length === 0) { %>
    <p class="no-data">No hay eventos creados por el momento.</p>
  <% } else { %>
    
    <div class="eventos-grid">
      <% eventos.forEach(function(ev) { %>
        <div class="card-evento-modern">
          
          <a href="/marketing/eventos/<%= ev.slug %>" class="evento-link" title="Ver galería de <%= ev.name %>">
            <div class="evento-img-container">
              <% if (ev.image) { %>
                <img src="<%= ev.image %>" alt="<%= ev.name %>" class="evento-img">
              <% } else { %>
                <div class="folder-icon-placeholder">📁</div>
              <% } %>
            </div>
            
            <div class="evento-info">
              <div class="evento-titulo"><%= ev.name %></div>
              <% if (ev.description) { %>
                <div class="evento-desc">
                  <%= ev.description.length > 60 ? ev.description.substring(0, 60) + '...' : ev.description %>
                </div>
              <% } %>
            </div>
          </a>

          <% if (can.eventos_write) { %>
            <div class="evento-actions">
              <form action="/marketing/eventos/<%= ev.slug %>/eliminar" method="POST" onsubmit="return confirm('¿Estás seguro? Se eliminará el evento y TODAS sus fotos.');" style="margin:0;">
                <button type="submit" class="btn-delete">Eliminar evento</button>
              </form>
            </div>
          <% } %>

        </div>
      <% }) %>
    </div>

  <% } %>
</div>