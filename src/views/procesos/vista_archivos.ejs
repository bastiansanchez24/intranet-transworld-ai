<link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
<style>
  /* ESTILO EJECUTIVO */
  .header-navegacion { margin-bottom: 20px; }
  
  .boton-volver {
    display: inline-block; background: #f8fafc; border: 1px solid #cbd5e0;
    color: #4a5568; padding: 8px 15px; border-radius: 6px; text-decoration: none;
    font-weight: 600; font-size: 0.9rem; transition: all 0.2s;
  }
  .boton-volver:hover { background: #edf2f7; color: #1a202c; }

  .page-title {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
  }

  .file-count-badge {
    background: #003a70; color: #ffffff; font-size: 0.9rem; padding: 4px 12px;
    border-radius: 20px; font-weight: bold;
  }

  .btn-upload {
    background-color: #003a70; color: white; border: none; padding: 10px 20px;
    border-radius: 6px; font-weight: bold; cursor: pointer; display: flex;
    align-items: center; gap: 8px; transition: background 0.2s;
  }
  .btn-upload:hover { background-color: #002a52; }

  /* TABLA DE ARCHIVOS */
  .tabla-archivos-contenedor {
    background: #fff; border: 1px solid #e2e8f0; border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.02); overflow: hidden;
  }
  
  .tabla-archivos {
    width: 100%; border-collapse: collapse; text-align: left;
  }
  .tabla-archivos th {
    background: #f8fafc; color: #475569; font-weight: 700; padding: 15px 20px;
    border-bottom: 2px solid #e2e8f0; font-size: 0.95rem; text-transform: uppercase;
  }
  .tabla-archivos td {
    padding: 15px 20px; border-bottom: 1px solid #e2e8f0; color: #334155; vertical-align: middle;
  }
  .tabla-archivos tr:last-child td { border-bottom: none; }
  .tabla-archivos tr:hover { background: #f8fbff; }

  .archivo-icono {
    font-size: 1.5rem; margin-right: 12px; vertical-align: middle;
  }
  .archivo-link {
    color: #003a70; text-decoration: none; font-weight: 600; font-size: 1.05rem;
    transition: color 0.2s;
  }
  .archivo-link:hover { color: #175cd3; text-decoration: underline; }

  .archivo-tipo {
    display: inline-block; background: #e2e8f0; color: #475569; font-size: 0.8rem;
    font-weight: 700; padding: 4px 10px; border-radius: 4px; text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* BOTONES DE ACCIÓN EN TABLA */
  .acciones-cell { text-align: right; white-space: nowrap; }
  .btn-accion {
    background: transparent; border: none; cursor: pointer; padding: 6px 10px;
    border-radius: 4px; transition: background 0.2s; font-size: 1rem;
  }
  .btn-accion:hover { background: #e2e8f0; }
  .btn-edit { color: #d97706; }
  .btn-delete { color: #dc2626; }

  /* MODALES */
  .modal-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.5); display: none; align-items: center; justify-content: center;
    z-index: 1000;
  }
  .modal-content {
    background: #fff; padding: 30px; border-radius: 10px; width: 100%; max-width: 500px; box-sizing: border-box;
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
  }
  .modal-title { color: #003a70; margin-top: 0; margin-bottom: 20px; font-size: 1.4rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px; }
  
  .form-group { margin-bottom: 20px; }
  .form-label { display: block; margin-bottom: 8px; font-weight: 600; color: #475569; }
  .form-control {
    width: 100%; padding: 10px 15px; border: 1px solid #cbd5e0; border-radius: 6px;
    box-sizing: border-box; transition: border 0.2s; font-family: inherit;
  }
  .form-control:focus { border-color: #003a70; outline: none; }
  
  .modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 30px; }
  
  .btn-cancelar {
    background: #f1f5f9; border: 1px solid #cbd5e0; color: #475569; padding: 10px 20px;
    border-radius: 6px; cursor: pointer; font-weight: 600;
  }
  .btn-cancelar:hover { background: #e2e8f0; }

  .upload-status {
    margin-top: 15px; font-size: 0.95rem; font-weight: 600; color: #003a70; text-align: center; display: none;
  }
  .upload-spinner {
    display: inline-block; width: 16px; height: 16px; border: 2px solid #003a70;
    border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite;
    vertical-align: middle; margin-right: 8px;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .empty-state { text-align: center; padding: 50px 20px; color: #718096; }
  .empty-state-icon { font-size: 3rem; margin-bottom: 15px; opacity: 0.5; }
</style>

<div class="contenedor">
  
  <div class="header-navegacion">
    <a href="/procesos" class="boton-volver">← Volver al Menú Principal</a>
    <% if (seccionBase !== 'otros' && seccionBase !== 'reglamento') { %>
      <a href="/procesos/<%= seccionBase %>" class="boton-volver" style="margin-left: 10px;">← Volver a <%= tituloSeccion %></a>
    <% } %>
  </div>

  <div class="page-header page-header--toolbar">
    <div class="page-header__text">
      <h2 class="page-title">
        <%= titulo %>
        <span class="file-count-badge"><%= archivos.length %> Documento(s)</span>
      </h2>
    </div>

    <% if (can[seccionBase + '_write']) { %>
    <div class="page-header-actions">
      <button class="btn-upload" onclick="abrirModal('modalSubir')">
        <span style="font-size: 1.2rem;">+</span> Subir Documento
      </button>
    </div>
    <% } %>
  </div>

  <% if (archivos.length === 0) { %>
    <div class="tabla-archivos-contenedor">
      <div class="empty-state">
        <div class="empty-state-icon"><%- include('../partials/icon', { name: 'folder' }) %></div>
        <h3>No hay documentos</h3>
        <p>Aún no se han subido archivos a esta sección.</p>
      </div>
    </div>
  <% } else { %>
    <div class="tabla-archivos-contenedor">
      <table class="tabla-archivos">
        <thead>
          <tr>
            <th>Nombre del Documento</th>
            <th style="width: 100px;">Tipo</th>
            <% if (can[seccionBase + '_write']) { %>
              <th style="width: 120px; text-align: right;">Acciones</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% archivos.forEach(a => { %>
            <tr>
              <td style="vertical-align: middle;">
                <% 
                  // Normalizamos el formato limpiando puntos y pasando a minúsculas
                  const fmt = (a.format || '').toLowerCase().replace('.', ''); 
                  
                  let iconName = 'insert_drive_file'; // Icono genérico gris por defecto
                  let iconColor = '#757575'; 
                  
                  if (fmt === 'pdf') {
                    iconName = 'picture_as_pdf';
                    iconColor = '#F44336'; // Rojo Adobe
                  } else if (fmt.includes('doc') || fmt.includes('word')) {
                    iconName = 'description'; 
                    iconColor = '#2196F3'; // Azul Word
                  } else if (fmt.includes('xls') || fmt.includes('excel') || fmt === 'csv') {
                    iconName = 'table_chart'; 
                    iconColor = '#4CAF50'; // Verde Excel
                  }
                %>
                <span class="archivo-icono" style="display: inline-flex; align-items: center; margin-right: 8px; vertical-align: middle;">
                  <!-- Icono nativo de Google Fonts -->
                  <i class="material-icons" style="font-size: 22px; color: <%= iconColor %>;"><%= iconName %></i>
                </span>
                <a href="<%= a.url %>" target="_blank" class="archivo-link" style="vertical-align: middle; text-decoration: none; font-weight: 500;"><%= a.name %></a>
              </td>
              <td>
                <% const tipoArchivo = (a.format || '').toUpperCase(); %>
                <span class="archivo-tipo"><%= tipoArchivo || '—' %></span>
              </td>
              
              <% if (can[seccionBase + '_write']) { %>
                <td class="acciones-cell">
                  <button class="btn-accion btn-edit" title="Editar nombre" onclick="abrirModalEditar('<%= a.id %>', '<%= a.name.replace(/'/g, "\\'") %>')"><i class="material-icons" style="font-size: 18px; vertical-align: middle;">edit</i></button>
                  <button class="btn-accion btn-delete" title="Eliminar" onclick="confirmarEliminar('<%= a.id %>', '<%= a.public_id %>', '<%= a.name.replace(/'/g, "\\'") %>')"><i class="material-icons" style="font-size: 18px; vertical-align: middle;">delete</i></button>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

</div>

<div id="modalSubir" class="modal-overlay">
  <div class="modal-content">
    <h3 class="modal-title">Subir Nuevo Documento</h3>
    
    <form id="formSubir" action="/procesos/<%= seccionBase %>/<%= slugArea %>/subir" method="POST">
      <div class="form-group">
        <label class="form-label">Nombre del Documento</label>
        <input type="text" id="nombreInput" class="form-control" placeholder="Ej: Procedimiento de Ventas V2" required>
      </div>
      
      <div class="form-group">
        <label class="form-label">Archivo</label>
        <input type="file" id="fileInput" class="form-control" required style="background: #f8fafc;">
      </div>

      <div id="uploadStatus" class="upload-status">
        <span class="upload-spinner" id="uploadSpinner"></span>
        <span id="uploadText">Preparando...</span>
      </div>

      <div class="modal-actions" id="modalActions">
        <button type="button" class="btn-cancelar" onclick="cerrarModal('modalSubir')">Cancelar</button>
        <button type="submit" class="btn-upload" id="btnSubmit">Subir Archivo</button>
      </div>
    </form>
  </div>
</div>

<div id="modalEditar" class="modal-overlay">
  <div class="modal-content">
    <h3 class="modal-title">Editar Nombre del Documento</h3>
    
    <% const editAction = (seccionBase === 'otros') ? '/procesos/otros/editar' : '/procesos/documento/editar'; %>
    
    <form action="<%= editAction %>" method="POST">
      <input type="hidden" name="id" id="editId">
      <input type="hidden" name="return_to" value="/procesos/<%= seccionBase %>/<%= slugArea %>">
      <input type="hidden" name="seccion_base" value="<%= seccionBase %>">
      
      <div class="form-group">
        <label class="form-label">Nuevo Nombre</label>
        <input type="text" name="nuevo_nombre" id="editNombre" class="form-control" required>
      </div>

      <div class="modal-actions">
        <button type="button" class="btn-cancelar" onclick="cerrarModal('modalEditar')">Cancelar</button>
        <button type="submit" class="btn-upload">Guardar Cambios</button>
      </div>
    </form>
  </div>
</div>

<% const deleteAction = (seccionBase === 'otros') ? '/procesos/otros/eliminar' : '/procesos/eliminar'; %>
<form id="formEliminar" action="<%= deleteAction %>" method="POST" style="display: none;">
  <input type="hidden" name="db_id" id="deleteDbId">
  <input type="hidden" name="id" id="deleteIdOtros">
  <input type="hidden" name="public_id" id="deletePublicId">
  <input type="hidden" name="return_to" value="/procesos/<%= seccionBase %>/<%= slugArea %>">
  <input type="hidden" name="seccion_base" value="<%= seccionBase %>">
</form>

<script>
  function abrirModal(id) { IntranetModal.open(id); }
  function cerrarModal(id) { IntranetModal.close(id); }

  function abrirModalEditar(id, nombreActual) {
    document.getElementById('editId').value = id;
    document.getElementById('editNombre').value = nombreActual;
    abrirModal('modalEditar');
  }

  function confirmarEliminar(id, publicId, nombre) {
    if (confirm(`¿Estás seguro de que deseas eliminar permanentemente el documento:\n"${nombre}"?`)) {
      document.getElementById('deleteDbId').value = id;
      document.getElementById('deleteIdOtros').value = id; 
      document.getElementById('deletePublicId').value = publicId;
      document.getElementById('formEliminar').submit();
    }
  }

  window.addEventListener('click', e => {
    if (e.target.classList.contains('modal-overlay')) {
      cerrarModal('modalSubir');
      cerrarModal('modalEditar');
    }
  });

  // LÓGICA DE SUBIDA A ALMACENAMIENTO LOCAL
  const formSubir = document.getElementById('formSubir');
  if (formSubir) {
    formSubir.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const fileInput = document.getElementById('fileInput');
      const nameInput = document.getElementById('nombreInput');
      const btnSubmit = document.getElementById('btnSubmit');
      const statusDiv = document.getElementById('uploadStatus');
      const statusText = document.getElementById('uploadText');
      const spinner = document.getElementById('uploadSpinner');
      const actions = document.getElementById('modalActions');

      if (!fileInput.files.length) return alert('Selecciona un archivo.');
      const file = fileInput.files[0];

      if (file.size > 20 * 1024 * 1024) {
          return alert('El archivo excede el límite de 20MB.');
      }

      function setStatus(msg, isUploading = false) {
          statusText.textContent = msg;
          statusDiv.style.display = 'block';
          if (isUploading) {
              spinner.style.display = 'inline-block';
              actions.style.display = 'none';
          } else {
              spinner.style.display = 'none';
              actions.style.display = 'flex';
          }
      }

      try {
        setStatus('Subiendo documento a SharePoint...', true);
        
        const form = e.target;
        const formData = new FormData();
        formData.append('archivo', file);
        
        const uploadPath = form.action.replace('/subir', '/upload');
        const upRes = await fetch(uploadPath, { 
          method: 'POST',
          body: formData,
          credentials: 'same-origin'
        });
        
        const upData = await upRes.json().catch(() => ({}));
        if (!upRes.ok) {
          throw new Error(upData.error || 'Error al subir el archivo a SharePoint.');
        }
        
        setStatus('Registrando en el sistema...', true);
        const saveRes = await fetch(form.action, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            credentials: 'same-origin',
            body: JSON.stringify({
                nombre_archivo: nameInput.value || file.name,
                secure_url: upData.secure_url,
                public_id: upData.public_id
            })
        });
        const saveData = await saveRes.json().catch(() => ({}));
        if (!saveRes.ok) {
          throw new Error(saveData.error || 'Error al guardar el registro en la base de datos.');
        }
        
        location.reload();
      } catch(err) {
        console.error(err);
        alert(err.message);
        setStatus('Error en la subida', false);
      }
    });
  }
</script>