<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/theme-head') %>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= formatPageTitle(titulo || "Registro") %></title>
  <link rel="stylesheet" href="/css/intranet.css">
  <link rel="stylesheet" href="/css/horizontal-forms.css">
  <link rel="stylesheet" href="/css/profile-photo-crop.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">
  
  <style>
      html, body {
        height: 100%; margin: 0; padding: 0; width: 100%;
      }

      body {
        background: url('/img/fondo-home.png') no-repeat center center fixed !important;
        background-size: cover !important;
        display: flex; justify-content: center; align-items: center;
        font-family: system-ui, -apple-system, sans-serif;
      }

      .login-page {
        width: 100%; display: flex; justify-content: center; align-items: center;
        padding: 20px 0;
      }

      /* --- TARJETA AZUL OSCURA (Estilo corporativo original) --- */
      .card-login {
        background: #00203e; 
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        width: 100%;
        max-width: 500px;
        box-sizing: border-box;
      }

      .card-login h2 {
        text-align: center; color: #ffffff; margin-top: 0; margin-bottom: 25px;
        font-size: 1.8rem; font-weight: 800;
      }

      .card-login label {
        display: block; font-weight: 700; color: #ffffff; margin-bottom: 6px; font-size: 0.95rem;
      }

      /* Inputs unificados con el Datepicker incluido */
      .card-login input[type="text"], 
      .card-login input[type="email"], 
      .card-login input[type="password"],
      .card-login input[type="date"] {
        width: 100%; padding: 12px 15px; border: none; border-radius: 6px;
        font-size: 1rem; margin-bottom: 20px; background: #ffffff; color: #1a202c;
        box-sizing: border-box; outline: none; font-family: inherit;
        height: 45px;
      }

      .card-login input[type="tel"] {
        width: 100%; padding: 12px 15px; border: none; border-radius: 6px;
        font-size: 1rem; margin-bottom: 20px; background: #ffffff; color: #1a202c;
        box-sizing: border-box; outline: none; font-family: inherit;
        height: 45px;
      }

      .card-login input:focus {
        box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.3);
      }

      /* Botón Blanco Original */
      .card-login button[type="submit"] {
        width: 100%; padding: 14px; background: #ffffff; color: #003a70;
        border: none; border-radius: 6px; font-size: 1.1rem; font-weight: 800;
        cursor: pointer; transition: background 0.2s, transform 0.1s; margin-top: 10px;
      }
      .card-login button[type="submit"]:hover { background: #f1f5f9; transform: translateY(-1px); }
      .card-login button[type="submit"]:active { transform: translateY(1px); }

      .login-links { text-align: center; margin-top: 25px; }
      .login-links a { color: #e2e8f0; text-decoration: none; font-size: 0.95rem; font-weight: 600; transition: color 0.2s;}
      .login-links a:hover { color: #ffffff; text-decoration: underline; }

      .mensaje-error { background: #e53e3e; color: white; padding: 12px; border-radius: 6px; text-align: center; margin-bottom: 20px; font-weight: 600; }

      /* --- CONTENEDOR CONTRASEÑA Y OJO --- */
      .password-wrapper { position: relative; display: block; width: 100%; margin-bottom: 20px; }
      .password-wrapper input { margin-bottom: 0 !important; padding-right: 40px !important; }
      .toggle-password {
        position: absolute; right: 12px; top: 0; bottom: 0; margin: auto; cursor: pointer;
        color: #718096; display: flex; align-items: center; justify-content: center;
        width: 22px; height: 22px; transition: color 0.2s; z-index: 10;
      }
      .toggle-password:hover { color: #1a202c; }
      .toggle-password svg { width: 100%; height: 100%; }

      .password-strength {
        margin: -12px 0 20px;
      }

      .password-strength-bar {
        display: flex;
        gap: 4px;
        margin-bottom: 8px;
      }

      .password-strength-segment {
        flex: 1;
        height: 6px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.18);
        transition: background 0.2s ease;
      }

      .password-strength-label {
        font-size: 0.85rem;
        font-weight: 700;
        margin-bottom: 10px;
        color: #e2e8f0;
      }

      .password-strength-label.weak { color: #fc8181; }
      .password-strength-label.fair { color: #f6ad55; }
      .password-strength-label.good { color: #faf089; }
      .password-strength-label.strong { color: #68d391; }

      .password-strength-segment.active-1 { background: #e53e3e; }
      .password-strength-segment.active-2 { background: #dd6b20; }
      .password-strength-segment.active-3 { background: #d69e2e; }
      .password-strength-segment.active-4 { background: #38a169; }
      .password-strength-segment.active-5 { background: #2f855a; }

      .password-rules {
        list-style: none;
        padding: 0;
        margin: 0 0 20px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px 12px;
      }

      .password-rules li {
        font-size: 0.8rem;
        color: #cbd5e0;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .password-rules li::before {
        content: "○";
        font-size: 0.75rem;
        color: #718096;
      }

      .password-rules li.valid {
        color: #9ae6b4;
      }

      .password-rules li.valid::before {
        content: "●";
        color: #68d391;
      }

      .password-match-msg {
        font-size: 0.85rem;
        margin: -12px 0 20px;
        font-weight: 600;
      }

      .password-match-msg.ok { color: #68d391; }
      .password-match-msg.bad { color: #fc8181; }

      .card-login button[type="submit"]:disabled {
        opacity: 0.55;
        cursor: not-allowed;
        transform: none;
      }

  </style>
</head>
<body>

<div class="login-page"> 
    <div class="card-login layout-horizontal-auth"> 
      <aside class="auth-aside">
        <h2>Crear cuenta</h2>
        <p>Completa tus datos para unirte a la intranet</p>
        <div class="profile-photo-upload">
          <label for="foto_file">Foto de perfil <span style="font-weight:400; opacity:0.85;">(opcional)</span></label>
          <div class="profile-photo-preview-wrap">
            <div class="profile-photo-preview profile-photo-preview--dark" id="photo-preview">
              <img id="photo-preview-img" alt="Vista previa de tu foto" hidden>
              <div class="profile-photo-placeholder" id="photo-placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                  <circle cx="12" cy="7" r="4"></circle>
                </svg>
              </div>
            </div>
            <div class="profile-photo-actions">
              <button type="button" class="btn-photo-select btn-photo-select--dark" id="btn-select-photo">Seleccionar foto</button>
              <span class="profile-photo-hint profile-photo-hint--dark">Recorta tu imagen en formato circular · JPG, PNG o WebP · Máx. 5 MB</span>
            </div>
          </div>
          <input type="file" id="foto_file" name="foto_file" accept="image/*" hidden>
        </div>
      </aside>

      <main class="auth-main">
      <% if (locals.error) { %>
        <div class="mensaje-error"><%= error %></div>
      <% } %>

      <form action="/register" method="POST" class="form-login" enctype="multipart/form-data">
        
        <div class="form-grid-2">
          <div>
            <label for="first_name">Nombre</label>
            <input type="text" id="first_name" name="first_name" required>
          </div>
          <div>
            <label for="last_name">Apellido</label>
            <input type="text" id="last_name" name="last_name" required>
          </div>
        </div>

        <label for="username">Usuario</label>
        <div style="display:flex; align-items:center; margin-bottom:20px;">
          <input type="text" id="username" name="username" required
                 placeholder="Ejemplo: 'mgonzalez'"
                 title="Ingresa solo el usuario, sin dominio"
                 style="margin-bottom:0; border-top-right-radius:0; border-bottom-right-radius:0;">
          <div style="display:flex; align-items:center; background:#e2e8f0; color:#1a202c; padding:0 0 0 10px; border-top-right-radius:6px; border-bottom-right-radius:6px; font-weight:600; height:45px;">
            <span style="margin-right:6px;">@</span>
            <select name="domain" aria-label="Dominio de correo" style="border:none; background:transparent; color:#1a202c; font-weight:600; outline:none; padding-right:8px;">
            <option value="transworld.cl" selected>transworld.cl</option>
            <option value="gmail.com">gmail.com</option>
            <option value="icloud.com">icloud.com</option>
            <option value="outlook.com">outlook.com</option>
            <option value="outlook.cl">outlook.cl</option>
            <option value="hotmail.com">hotmail.com</option>
            <option value="hotmail.cl">hotmail.cl</option>
            <option value="yahoo.com">yahoo.com</option>
            <option value="yahoo.cl">yahoo.cl</option>
            </select>
          </div>
        </div>

        <div class="form-grid-2">
          <div>
            <label for="password">Contraseña</label>
            <div class="password-wrapper">
              <input type="password" id="password" name="password" required minlength="8" autocomplete="new-password">
              <span class="toggle-password" onclick="toggleVisibility('password', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
              </span>
            </div>
          </div>
          
          <div>
            <label for="password2">Repetir contraseña</label>
            <div class="password-wrapper">
              <input type="password" id="password2" name="password2" required minlength="8" autocomplete="new-password">
              <span class="toggle-password" onclick="toggleVisibility('password2', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
              </span>
            </div>
          </div>
        </div>

        <div class="password-strength" id="password-strength" hidden>
          <div class="password-strength-bar" aria-hidden="true">
            <span class="password-strength-segment" data-segment="1"></span>
            <span class="password-strength-segment" data-segment="2"></span>
            <span class="password-strength-segment" data-segment="3"></span>
            <span class="password-strength-segment" data-segment="4"></span>
            <span class="password-strength-segment" data-segment="5"></span>
          </div>
          <div class="password-strength-label" id="password-strength-label"></div>
          <ul class="password-rules" id="password-rules">
            <li data-rule="length">Mínimo 8 caracteres</li>
            <li data-rule="lowercase">Una minúscula</li>
            <li data-rule="uppercase">Una mayúscula</li>
            <li data-rule="number">Un número</li>
            <li data-rule="symbol">Un símbolo</li>
          </ul>
        </div>

        <div class="password-match-msg" id="password-match-msg" hidden></div>

        <div class="form-grid-2">
          <div>
            <label for="telefono">Teléfono</label>
            <input type="tel" id="telefono" name="phone" required placeholder="+56 9 1234 5678">
          </div>
          <div>
            <label for="fecha_nacimiento">Fecha de nacimiento</label>
            <input type="date" id="fecha_nacimiento" name="birth_date" required>
          </div>
        </div>

        <button type="submit" id="submit-btn" disabled>Registrarse</button>
      </form>

      <div class="login-links">
        <a href="/login">¿Ya tienes cuenta? Inicia sesión</a>
      </div>
      </main>
    </div>
</div>

<div class="foto-crop-overlay" id="fotoCropOverlay" role="dialog" aria-modal="true" aria-labelledby="fotoCropTitle" hidden>
  <div class="foto-crop-modal">
    <div class="foto-crop-header">
      <h3 id="fotoCropTitle">Recortar foto de perfil</h3>
      <button type="button" class="foto-crop-close" id="fotoCropClose" aria-label="Cerrar">&times;</button>
    </div>
    <p class="foto-crop-hint">Arrastra y ajusta el encuadre. La foto se verá circular en tu perfil.</p>
    <div class="foto-crop-body">
      <div class="foto-crop-stage">
        <img id="fotoCropImage" src="" alt="Vista previa para recortar">
      </div>
    </div>
    <p id="fotoCropError" class="foto-crop-error" role="alert"></p>
    <div class="foto-crop-footer">
      <button type="button" class="btn-crop-cancel" id="fotoCropCancel">Cancelar</button>
      <button type="button" class="btn-crop-save" id="fotoCropSave">Aplicar recorte</button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="/js/profile-photo-cropper.js"></script>
<script src="/js/password-strength.js"></script>
<script>
  const passwordInput = document.getElementById('password');
  const password2Input = document.getElementById('password2');
  const telefonoInput = document.getElementById('telefono');
  const submitBtn = document.getElementById('submit-btn');
  const strengthBox = document.getElementById('password-strength');
  const strengthLabel = document.getElementById('password-strength-label');
  const strengthSegments = document.querySelectorAll('.password-strength-segment');
  const ruleItems = document.querySelectorAll('#password-rules li');
  const matchMsg = document.getElementById('password-match-msg');

  const photoCropper = ProfilePhotoCropper.init({
    fileInputId: 'foto_file',
    previewImgId: 'photo-preview-img',
    previewPlaceholderId: 'photo-placeholder',
    selectBtnId: 'btn-select-photo',
    overlayId: 'fotoCropOverlay',
    cropImgId: 'fotoCropImage',
    closeBtnId: 'fotoCropClose',
    cancelBtnId: 'fotoCropCancel',
    saveBtnId: 'fotoCropSave',
    errorElId: 'fotoCropError',
    maxSizeMb: 5,
    outputSize: 400,
    outputFilename: 'foto-perfil.jpg',
    saveLabel: 'Aplicar recorte',
    onCropped: function () {
      updateSubmitState();
    }
  });

  function updateStrengthUI() {
    const result = PasswordStrength.analyzePasswordStrength(passwordInput.value);
    const hasValue = passwordInput.value.length > 0;

    strengthBox.hidden = !hasValue;
    if (!hasValue) {
      strengthLabel.textContent = '';
      strengthLabel.className = 'password-strength-label';
      strengthSegments.forEach((seg) => {
        seg.className = 'password-strength-segment';
      });
      ruleItems.forEach((item) => item.classList.remove('valid'));
      return;
    }

    strengthLabel.textContent = result.label;
    strengthLabel.className = 'password-strength-label ' + (result.level === 'empty' ? '' : result.level);

    strengthSegments.forEach((seg) => {
      const idx = Number(seg.dataset.segment);
      seg.className = 'password-strength-segment' + (idx <= result.score ? ' active-' + result.score : '');
    });

    ruleItems.forEach((item) => {
      const rule = item.dataset.rule;
      item.classList.toggle('valid', Boolean(result.checks[rule]));
    });
  }

  function updateMatchUI() {
    const p1 = passwordInput.value;
    const p2 = password2Input.value;

    if (!p2.length) {
      matchMsg.hidden = true;
      matchMsg.textContent = '';
      return;
    }

    matchMsg.hidden = false;
    if (p1 === p2) {
      matchMsg.textContent = 'Las contraseñas coinciden';
      matchMsg.className = 'password-match-msg ok';
    } else {
      matchMsg.textContent = 'Las contraseñas no coinciden';
      matchMsg.className = 'password-match-msg bad';
    }
  }

  function updateSubmitState() {
    const strongEnough = PasswordStrength.isPasswordStrongEnough(passwordInput.value);
    const passwordsMatch = passwordInput.value === password2Input.value && password2Input.value.length > 0;
    const hasTelefono = telefonoInput.value.trim().length > 0;
    submitBtn.disabled = !(strongEnough && passwordsMatch && hasTelefono);
  }

  function onPasswordChange() {
    updateStrengthUI();
    updateMatchUI();
    updateSubmitState();
  }

  passwordInput.addEventListener('input', onPasswordChange);
  password2Input.addEventListener('input', onPasswordChange);
  telefonoInput.addEventListener('input', updateSubmitState);

  function toggleVisibility(inputId, iconSpan) {
    const input = document.getElementById(inputId);
    if (input.type === 'password') {
      input.type = 'text';
      iconSpan.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
    } else {
      input.type = 'password';
      iconSpan.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
    }
  }
</script>

</body>
</html>