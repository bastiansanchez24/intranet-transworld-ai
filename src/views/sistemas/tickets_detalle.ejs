<div class="contenedor contenedor--narrow ticket-detail-view <%= (typeof isModal !== 'undefined' && isModal) ? 'ticket-detail-view--modal' : '' %>">
  <% if (typeof isModal === 'undefined' || !isModal) { %>
  <div class="ticket-detail-back">
    <a href="/sistemas/tickets" class="link-volver">← Volver al Listado</a>
  </div>
  <% } %>

<div class="ticket-container">

  <% 
    const estadoLabels = { open: 'Abierto', in_progress: 'En curso', pending_close: 'Pendiente de cierre', closed: 'Cerrado' };
    const prioridadLabels = { low: 'Baja', medium: 'Media', high: 'Alta' };

    let badgeEstado = 'bg-secondary';
    if (ticket.status === 'open') badgeEstado = 'bg-primary';
    else if (ticket.status === 'in_progress') badgeEstado = 'bg-warning';
    else if (ticket.status === 'pending_close') badgeEstado = 'bg-success';
    else if (ticket.status === 'closed') badgeEstado = 'bg-secondary';

    let badgePrioridad = 'bg-secondary';
    if (ticket.priority === 'high') badgePrioridad = 'bg-danger';
    else if (ticket.priority === 'medium') badgePrioridad = 'bg-success';
    else if (ticket.priority === 'low') badgePrioridad = 'bg-primary';
  %>

  <div class="cabecera-detalle">
    <div>
      <div class="ticket-header-main">
        <h2 class="ticket-detail-heading">Ticket #<%= ticket.id %></h2>
        <span class="badge <%= badgeEstado %>"><%= estadoLabels[ticket.status] || ticket.status %></span>
        
        <% if (user && typeof isAdministrador !== 'undefined' && isAdministrador) { %>
            <button
              id="btnTomarTicket"
              type="button"
              data-take-ticket="<%= ticket.id %>"
              class="btn-tomar-ticket <%= ticket.assigned_to ? 'is-assigned' : '' %>"
            >
                <%= ticket.assigned_to ? 'Ticket tomado por ' + ticket.assigned_to : 'Tomar Ticket' %>
            </button>
        <% } %>

      </div>
      <h3 class="ticket-detail-subtitle"><%= ticket.title %></h3>
    </div>
    <div class="ticket-detail-meta">
      <p><strong>Creado:</strong> <%= new Date(ticket.created_at).toLocaleString('es-CL') %></p>
      <% if (ticket.fecha_resolucion) { %>
        <p><strong>Pendiente de cierre:</strong> <%= new Date(ticket.fecha_resolucion).toLocaleString('es-CL') %></p>
      <% } %>
      <% if (ticket.fecha_cierre) { %>
        <p><strong>Cerrado:</strong> <%= new Date(ticket.fecha_cierre).toLocaleString('es-CL') %></p>
      <% } %>
    </div>
  </div>

  <div class="seccion-info">
    <p><strong>Solicitante:</strong> <%= ticket.requester_name %> (<%= ticket.requester_email %>)</p>
    <p>
      <strong>Categoría:</strong> <%= ticket.category || 'Sin clasificar' %> | 
      <strong>Prioridad:</strong> <span class="badge <%= badgePrioridad %>"><%= prioridadLabels[ticket.priority] || ticket.priority %></span>
    </p>
    <div class="ticket-description-box">
      <strong class="ticket-description-label">Descripción del requerimiento:</strong>
      <p class="ticket-description-text"><%= ticket.description %></p>
      
      <% 
        let ticketAdjuntos = [];
        try { if(ticket.attachments) ticketAdjuntos = JSON.parse(ticket.attachments); } catch(e) {}
      %>
      <% if(ticketAdjuntos && ticketAdjuntos.length > 0) { %>
        <div class="adjuntos-wrapper">
          
          <% const imagenesOrig = ticketAdjuntos.filter(a => a.tipo === 'image'); %>
          <% if(imagenesOrig.length > 0) { %>
            <div class="seccion-adjunto">
              <div class="titulo-adjunto">Imágenes adjuntas</div>
              <div class="grid-imagenes">
                <% imagenesOrig.forEach(img => { %>
                  <a href="<%= img.url %>" target="_blank" title="<%= img.nombre %>">
                    <img src="<%= img.url %>" alt="Adjunto" class="thumb-imagen">
                  </a>
                <% }) %>
              </div>
            </div>
          <% } %>

          <% const otrosOrig = ticketAdjuntos.filter(a => a.tipo !== 'image'); %>
          <% if(otrosOrig.length > 0) { %>
            <div class="seccion-adjunto">
              <div class="titulo-adjunto">Otros archivos adjuntos</div>
              <ul class="lista-archivos">
                <% otrosOrig.forEach(arc => { %>
                  <li>
                    <a href="<%= arc.url %>" target="_blank">
                      <%= arc.nombre %>
                    </a>
                  </li>
                <% }) %>
              </ul>
            </div>
          <% } %>

        </div>
      <% } %>

    </div>
  </div>

  <div class="historial-container">
    <h3 class="ticket-section-title">Historial de Mensajes</h3>
    
    <% if (respuestas && respuestas.length > 0) { %>
      <% respuestas.forEach(r => { 
           const esSoporte = r.remitente === 'Soporte' || r.remitente === 'Sistema';
      %>
        <div class="mensaje-card <%= esSoporte ? 'soporte' : 'usuario' %>">
          <div class="mensaje-header">
            <strong><%= r.remitente %></strong>
            <span><%= new Date(r.fecha).toLocaleString('es-CL') %></span>
          </div>
          <p class="ticket-message-text"><%= r.mensaje %></p>
          
          <% 
            let respAdjuntos = [];
            try { if(r.attachments) respAdjuntos = JSON.parse(r.attachments); } catch(e) {}
            if(r.file_url && respAdjuntos.length === 0) {
                respAdjuntos.push({ url: r.file_url, nombre: r.archivo_nombre || 'Archivo adjunto', tipo: r.archivo_tipo || 'doc' });
            }
          %>
          <% if(respAdjuntos && respAdjuntos.length > 0) { %>
            <div class="adjuntos-wrapper adjuntos-wrapper--reply">
              
              <% const imagenes = respAdjuntos.filter(a => a.tipo === 'image'); %>
              <% if(imagenes.length > 0) { %>
                <div class="seccion-adjunto">
                  <div class="titulo-adjunto">Imágenes:</div>
                  <div class="grid-imagenes">
                    <% imagenes.forEach(img => { %>
                      <a href="<%= img.url %>" target="_blank" title="<%= img.nombre %>">
                        <img src="<%= img.url %>" alt="Adjunto" class="thumb-imagen thumb-imagen--small">
                      </a>
                    <% }) %>
                  </div>
                </div>
              <% } %>

              <% const otros = respAdjuntos.filter(a => a.tipo !== 'image'); %>
              <% if(otros.length > 0) { %>
                <div class="seccion-adjunto">
                  <div class="titulo-adjunto">Archivos:</div>
                  <ul class="lista-archivos">
                    <% otros.forEach(arc => { %>
                      <li>
                        <a href="<%= arc.url %>" target="_blank">
                          <%= arc.nombre %>
                        </a>
                      </li>
                    <% }) %>
                  </ul>
                </div>
              <% } %>

            </div>
          <% } %>

        </div>
      <% }) %>
    <% } else { %>
      <p class="ticket-empty-message">Aún no hay respuestas en este ticket.</p>
    <% } %>
  </div>

  <% if (ticket.status === 'pending_close' && user.email === ticket.requester_email) { %>
    <div class="acciones-rapidas">
      <div class="acciones-rapidas__body">
        <h4 class="acciones-rapidas__title">El equipo de TI ha marcado este ticket como Pendiente de cierre.</h4>
        <p class="acciones-rapidas__text">Por favor, confirma si tu problema fue solucionado para cerrar el ticket, o recházalo si aún necesitas ayuda.</p>
        <div class="acciones-rapidas__forms">
          <form action="/sistemas/tickets/<%= ticket.id %>/confirmar" method="POST">
            <button type="submit" class="btn btn-success">Confirmar Solución</button>
          </form>
          <form action="/sistemas/tickets/<%= ticket.id %>/rechazar" method="POST">
            <button type="submit" class="btn btn-danger" data-confirm-message="¿Estás seguro de reabrir el ticket?">Aún tengo problemas</button>
          </form>
        </div>
      </div>
    </div>
  <% } %>

  <% if (ticket.status !== 'closed') { %>
    
    <% if (typeof isAdministrador !== 'undefined' && isAdministrador) { %>
      <div class="form-respuesta form-respuesta--admin">
        <h3 class="ticket-detail-subtitle">Panel de Gestión (TI)</h3>
        
        <form id="form-upload-admin" action="/sistemas/tickets/<%= ticket.id %>/actualizar" method="POST">
          <div class="ticket-form-grid">
            <div>
              <label>Categoría:</label>
              <select name="category">
                <option value="SAP" <%= ticket.category==='SAP'?'selected':'' %>>SAP</option>
                <option value="Salesforce" <%= ticket.category==='Salesforce'?'selected':'' %>>Salesforce</option>
                <option value="Intranet" <%= ticket.category==='Intranet'?'selected':'' %>>Intranet</option>
                <option value="Hardware" <%= ticket.category==='Hardware'?'selected':'' %>>Hardware </option>
                <option value="Otro" <%= ticket.category==='Otro'?'selected':'' %>>Otro</option>
              </select>
            </div>
            <div>
              <label>Prioridad:</label>
              <select name="priority">
                <option value="low" <%= ticket.priority==='low'?'selected':'' %>>Baja</option>
                <option value="medium" <%= ticket.priority==='medium'?'selected':'' %>>Media</option>
                <option value="high" <%= ticket.priority==='high'?'selected':'' %>>Alta</option>
              </select>
            </div>
            <div>
              <label>Estado:</label>
              <select name="status" class="ticket-status-select">
                <option value="open" <%= ticket.status==='open'?'selected':'' %>>Abierto</option>
                <option value="in_progress" <%= ticket.status==='in_progress'?'selected':'' %>>En curso</option>
                <option value="pending_close" <%= ticket.status==='pending_close'?'selected':'' %>>Marcar como Pendiente de cierre</option>
                <option value="closed" <%= ticket.status==='closed'?'selected':'' %>>Cerrar directamente</option>
              </select>
            </div>
          </div>
          
          <label>Mensaje al usuario (Opcional):</label>
          <textarea id="mensajeAdmin" name="mensaje_respuesta" rows="4" placeholder="Escribe aquí para notificar al usuario..." maxlength="2000"></textarea>
          <div id="charCountAdmin" class="char-counter">0 / 2000 caracteres</div>

          <label class="ticket-files-label">Adjuntar archivos (opcional):</label>
          <input type="file" id="archivos_admin" class="ticket-file-input" multiple accept="image/*,video/*,.pdf,.doc,.docx,.xls,.xlsx,.txt">
          <input type="hidden" name="adjuntos_data" id="adjuntos_data_admin">
          <div id="upload-status-admin" class="ticket-upload-status"></div>

          <button type="submit" class="btn btn-primario ticket-submit-full" id="btn-submit-admin">Actualizar Ticket</button>
        </form>
      </div>

    <% } else { %>
      
      <div class="form-respuesta">
        <h3 class="ticket-detail-subtitle">Añadir un comentario</h3>
        <form id="form-upload-user" action="/sistemas/tickets/<%= ticket.id %>/responder" method="POST">
          <textarea id="mensajeUser" name="mensaje_respuesta" rows="4" placeholder="Escribe tu mensaje aquí..." required maxlength="2000"></textarea>
          <div id="charCountUser" class="char-counter">0 / 2000 caracteres</div>
          
          <label class="ticket-files-label">Adjuntar archivos (opcional):</label>
          <input type="file" id="archivos_user" class="ticket-file-input" multiple accept="image/*,video/*,.pdf,.doc,.docx,.xls,.xlsx,.txt">
          <input type="hidden" name="adjuntos_data" id="adjuntos_data_user">
          <div id="upload-status-user" class="ticket-upload-status"></div>

          <button type="submit" class="btn btn-primario" id="btn-submit-user">Enviar Mensaje</button>
        </form>
      </div>
    <% } %>

  <% } else { %>
    <div class="ticket-closed-box">
      <h3>Este ticket se encuentra cerrado.</h3>
      <p>Si tienes un problema similar, por favor abre un nuevo ticket.</p>
    </div>
  <% } %>

</div>
</div>
