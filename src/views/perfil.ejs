<%
  const tieneFoto = Boolean(usuario.photo);
  const sinDato = '—';
  const rolFmt = usuario.role || 'Usuario';
  const correoVerificado = usuario.email_confirmed ? 'Verificado' : 'Pendiente de verificación';
  const errorPerfil = typeof error !== 'undefined' ? error : null;
%>
<link rel="stylesheet" href="/css/horizontal-forms.css">
<link rel="stylesheet" href="/css/phone-chile.css">
<link rel="stylesheet" href="/css/profile-photo-crop.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">

<div class="contenedor-formulario perfil-container">

  <a href="/" class="link-volver">← Volver al inicio</a>

  <div class="form-card layout-horizontal-form">
    <aside class="form-aside">
      <h2 class="perfil-title">Mi Perfil</h2>
      <p class="form-aside-desc">Administra tu foto y revisa todos tus datos de cuenta.</p>
      <div class="profile-photo-upload">
        <label for="foto">Foto de perfil</label>
        <div class="profile-photo-preview-wrap">
          <div class="profile-photo-preview profile-photo-preview--light" id="photo-preview">
            <img id="photo-preview-img" <% if (tieneFoto) { %>src="<%= usuario.photo %>"<% } else { %>hidden<% } %>>
            <div class="profile-photo-placeholder" id="photo-placeholder" <%= tieneFoto ? 'hidden' : '' %>>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
          </div>
          <div class="profile-photo-actions">
            <button type="button" class="btn-photo-select btn-photo-select--light" id="btn-select-photo">
              <%= tieneFoto ? 'Cambiar foto' : 'Seleccionar foto' %>
            </button>
            <button type="button" class="btn-photo-remove" id="btn-remove-photo" <%= tieneFoto ? '' : 'hidden' %>>Quitar foto</button>
            <span class="profile-photo-hint profile-photo-hint--light">Recorta la imagen en formato circular · JPG, PNG o WebP · Máx. 5 MB</span>
          </div>
        </div>
        <input type="file" id="foto" name="foto" accept="image/*" hidden>
      </div>
    </aside>

    <main class="form-main">
      <h1 class="perfil-nombre">
        <%= usuario.first_name %> <%= usuario.last_name %>
      </h1>

      <span class="perfil-rol"><%= rolFmt.toUpperCase() %></span>

      <% if (errorPerfil) { %>
        <div class="perfil-alert perfil-alert--error"><%= errorPerfil %></div>
      <% } %>

      <form action="/perfil" method="POST" class="perfil-form">
        <div class="perfil-datos">
          <div class="form-grid-2">
            <div class="perfil-field">
              <label for="first_name">Nombre</label>
              <input type="text" id="first_name" name="first_name" value="<%= usuario.first_name || '' %>" required autocomplete="given-name">
            </div>
            <div class="perfil-field">
              <label for="last_name">Apellido</label>
              <input type="text" id="last_name" name="last_name" value="<%= usuario.last_name || '' %>" required autocomplete="family-name">
            </div>
          </div>

          <div class="form-grid-2">
            <div class="perfil-field">
              <label for="email">Correo electrónico</label>
              <input type="text" id="email" value="<%= usuario.email || sinDato %>" readonly class="perfil-input-readonly" aria-readonly="true">
            </div>
            <div class="perfil-field">
              <label for="telefono_local">Teléfono</label>
              <div class="phone-field" data-phone-chile>
                <span class="phone-field__prefix" aria-hidden="true">+56</span>
                <input type="tel" id="telefono_local" class="phone-field__local" required placeholder="9 1234 5678" maxlength="11" inputmode="numeric" autocomplete="tel-national" aria-label="Número celular sin código de país">
                <input type="hidden" name="phone" id="telefono" value="<%= usuario.phone || '' %>">
              </div>
            </div>
          </div>

          <div class="form-grid-2">
            <div class="perfil-field">
              <label for="area">Área de trabajo</label>
              <input type="text" id="area" value="<%= usuario.area || sinDato %>" readonly class="perfil-input-readonly" aria-readonly="true">
            </div>
            <div class="perfil-field">
              <label for="fecha_nacimiento">Fecha de nacimiento</label>
              <input type="date" id="fecha_nacimiento" name="birth_date" value="<%= usuario.birth_date_input || '' %>" required autocomplete="bday">
            </div>
          </div>

          <div class="form-grid-2">
            <div class="perfil-field">
              <label for="role">Rol en intranet</label>
              <input type="text" id="role" value="<%= rolFmt %>" readonly class="perfil-input-readonly" aria-readonly="true">
            </div>
            <div class="perfil-field">
              <label for="email_confirmed">Estado del correo</label>
              <input type="text" id="email_confirmed" value="<%= correoVerificado %>" readonly class="perfil-input-readonly" aria-readonly="true">
            </div>
          </div>
        </div>

        <div class="perfil-form-actions">
          <button type="submit" class="btn-guardar-perfil">Guardar cambios</button>
        </div>
      </form>

      <div class="perfil-acciones">
        <a href="/change-password" class="link-cambiar-pass">Cambiar contraseña</a>
        <a href="/perfil/cursos" class="btn-ver-cursos">🎓 Mis cursos</a>
      </div>

      <a href="/logout" class="btn-logout-card">
        Cerrar Sesión
      </a>
    </main>
  </div>
</div>

<div class="foto-crop-overlay" id="fotoCropOverlay" role="dialog" aria-modal="true" aria-labelledby="fotoCropTitle" hidden>
  <div class="foto-crop-modal">
    <div class="foto-crop-header">
      <h3 id="fotoCropTitle">Recortar foto de perfil</h3>
      <button type="button" class="foto-crop-close" id="fotoCropClose" aria-label="Cerrar">&times;</button>
    </div>
    <p class="foto-crop-hint">Arrastra y ajusta el encuadre. La foto se verá circular en el perfil.</p>
    <div class="foto-crop-body">
      <div class="foto-crop-stage">
        <img id="fotoCropImage" src="" alt="Vista previa para recortar">
      </div>
    </div>
    <p id="fotoCropError" class="foto-crop-error" role="alert"></p>
    <div class="foto-crop-footer">
      <button type="button" class="btn-crop-cancel" id="fotoCropCancel">Cancelar</button>
      <button type="button" class="btn-crop-save" id="fotoCropSave">Aplicar recorte</button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="/js/phone-chile.js"></script>
<script src="/js/profile-photo-cropper.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btnRemove = document.getElementById('btn-remove-photo');
    const telefonoField = document.querySelector('[data-phone-chile]');

    PhoneChile.initField(telefonoField);

    ProfilePhotoCropper.init({
      fileInputId: 'foto',
      previewImgId: 'photo-preview-img',
      previewPlaceholderId: 'photo-placeholder',
      selectBtnId: 'btn-select-photo',
      overlayId: 'fotoCropOverlay',
      cropImgId: 'fotoCropImage',
      closeBtnId: 'fotoCropClose',
      cancelBtnId: 'fotoCropCancel',
      saveBtnId: 'fotoCropSave',
      errorElId: 'fotoCropError',
      maxSizeMb: 5,
      outputSize: 400,
      outputFilename: 'foto-perfil.jpg',
      saveLabel: 'Aplicar recorte',
      onSave: function (blob, helpers) {
        const formData = new FormData();
        formData.append('foto_perfil', blob, 'foto-perfil.jpg');

        fetch('/perfil/foto', {
          method: 'POST',
          body: formData,
          credentials: 'same-origin',
          redirect: 'follow'
        })
          .then(function (res) {
            if (res.ok) {
              window.location.href = '/perfil';
              return;
            }
            throw new Error('Error del servidor');
          })
          .catch(function () {
            helpers.showError('No se pudo guardar la foto. Intenta de nuevo.');
            helpers.resetSaveButton();
          });
      }
    });

    btnRemove.addEventListener('click', function () {
      if (!confirm('¿Quitar tu foto de perfil?')) return;

      fetch('/perfil/foto/eliminar', {
        method: 'POST',
        credentials: 'same-origin',
        redirect: 'follow'
      })
        .then(function (res) {
          if (res.ok) {
            window.location.href = '/perfil';
            return;
          }
          throw new Error('Error del servidor');
        })
        .catch(function () {
          alert('No se pudo quitar la foto. Intenta de nuevo.');
        });
    });
  });
</script>
