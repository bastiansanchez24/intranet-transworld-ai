<style>
  .modal-crear-noticia {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 2100;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 15px;
    box-sizing: border-box;
  }

  .modal-crear-noticia .modal-content {
    background: #fff;
    color: #1a202c;
    width: 100%;
    max-width: var(--layout-content-max-width, 1200px);
    height: 95vh;
    max-height: 95vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 0;
    border-radius: 14px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.25);
    position: relative;
    margin: auto;
  }

  .modal-crear-noticia .modal-crear-scroll {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 24px 28px 20px;
    scrollbar-width: none;
    -ms-overflow-style: none;
    display: flex;
    flex-direction: column;
  }

  .modal-crear-noticia .modal-crear-scroll::-webkit-scrollbar { display: none; }

  .modal-crear-noticia .modal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 3;
    background: none;
    border: none;
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    color: #94a3b8;
  }

  .modal-crear-noticia .modal-close:hover { color: #475569; }

  .modal-crear-noticia h2 {
    margin: 0 0 6px;
    color: #003a70;
    font-size: 1.35rem;
    border: none;
    padding: 0;
    flex-shrink: 0;
  }

  .modal-crear-desc { margin: 0 0 14px; color: #6b7280; font-size: 0.9rem; line-height: 1.45; flex-shrink: 0; }

  .noticia-form {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  .noticia-form .campo { margin-bottom: 16px; }

  .noticia-form label {
    display: block;
    margin-bottom: 6px;
    font-weight: 700;
    font-size: 0.9rem;
    color: #374151;
  }

  .noticia-form input[type="text"],
  .noticia-form textarea {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.95rem;
    color: #1f2937;
    box-sizing: border-box;
    font-family: inherit;
  }

  .noticia-form input[type="text"]:focus,
  .noticia-form textarea:focus {
    outline: none;
    border-color: #003a70;
    box-shadow: 0 0 0 3px rgba(0, 58, 112, 0.12);
  }

  .noticia-form .hint-modal { font-size: 0.8rem; color: #6b7280; margin-top: 4px; display: block; }
  .required-mark { color: #dc2626; margin-left: 2px; }

  .noticia-form-layout {
    flex: 1;
    min-height: 0;
    display: grid;
    grid-template-columns: minmax(300px, 0.85fr) minmax(0, 1.35fr);
    gap: 20px 28px;
    align-items: stretch;
  }

  .noticia-form-col { min-width: 0; }

  .noticia-form-col-meta {
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-right: 4px;
  }

  .noticia-form-col-meta::-webkit-scrollbar { display: none; }

  .noticia-form-col-content {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .noticia-form-col-content .campo {
    display: flex;
    flex-direction: column;
    margin-bottom: 0;
  }

  .noticia-form-col-content .campo label { flex-shrink: 0; }

  .noticia-editor-host {
    min-height: 520px;
    width: 100%;
  }

  .noticia-editor-host .tox-tinymce { border-radius: 8px !important; }

  .noticia-cover-actions { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }

  .noticia-cover-preview {
    position: relative;
    margin-top: 10px;
    max-width: 220px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #e2e8f0;
    aspect-ratio: 16 / 9;
    background: #f8fafc;
  }

  .noticia-cover-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .btn-preview-quitar {
    position: absolute;
    top: 6px;
    right: 6px;
    width: 24px;
    height: 24px;
    border: none;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-preview-quitar:hover { background: rgba(185, 28, 28, 0.9); }

  .galeria-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(76px, 1fr));
    gap: 8px;
    margin-top: 10px;
    max-width: 100%;
  }

  .galeria-preview-item {
    position: relative;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
  }

  .galeria-preview-item img,
  .galeria-preview-item video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .galeria-preview-doc {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 6px 4px;
    gap: 4px;
    text-align: center;
  }

  .galeria-preview-doc-icon { font-size: 1.5rem; line-height: 1; }

  .galeria-preview-doc-ext {
    font-size: 0.62rem;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
  }

  .galeria-preview-nombre {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
    color: #fff;
    font-size: 0.62rem;
    font-weight: 600;
    padding: 12px 4px 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .galeria-preview-item .btn-galeria-quitar {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 20px;
    height: 20px;
    font-size: 0.85rem;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
  }

  .galeria-preview-item .btn-galeria-quitar:hover { background: rgba(185, 28, 28, 0.9); }

  .galeria-preview-vacio {
    margin-top: 8px;
    font-size: 0.8rem;
    color: #94a3b8;
    font-style: italic;
  }

  .btn-modal-secundario {
    background: #f1f5f9;
    color: #334155;
    border: 1px solid #cbd5e0;
    padding: 9px 16px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.88rem;
    cursor: pointer;
  }

  .btn-modal-secundario:hover { background: #e2e8f0; }

  .galeria-lista { display: none; }

  .modal-form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid #e2e8f0;
    flex-shrink: 0;
  }

  .btn-modal-cancelar, .btn-modal-guardar {
    padding: 11px 18px;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    border: none;
  }

  .btn-modal-cancelar { background: #f1f5f9; color: #475569; }
  .btn-modal-guardar { background: linear-gradient(135deg, #003a70 0%, #0069c2 100%); color: #fff; }
  .btn-modal-guardar:disabled { opacity: 0.6; cursor: not-allowed; }

  #noticiaUploadStatus { margin-top: 12px; font-weight: 700; color: #003a70; font-size: 0.9rem; display: none; }

  .tox-tinymce-aux { z-index: 3000 !important; }

  @media (max-width: 768px) {
    .noticia-form-layout { grid-template-columns: 1fr; gap: 0; flex: none; }
    .noticia-form-col-meta { overflow: visible; padding-right: 0; }
    .noticia-form-col-content .campo { flex: none; display: block; margin-bottom: 16px; }
    .noticia-editor-host { min-height: 360px; }
    .modal-crear-noticia .modal-content {
      display: flex;
      flex-direction: column;
      overflow: hidden !important;
      height: 100% !important;
      max-height: none !important;
    }
    .modal-crear-noticia .modal-crear-scroll {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      display: block;
    }
    .noticia-form { display: block; }
    .modal-crear-noticia { padding: 0; }
  }
</style>

<link rel="stylesheet" href="/css/profile-photo-crop.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">

<div id="modalCrearNoticia" class="modal-overlay modal-crear-noticia" aria-hidden="true">
  <div class="modal-content modal-content--layout">
    <button type="button" class="modal-close" onclick="cerrarModalNoticia()" aria-label="Cerrar">&times;</button>
    <div class="modal-crear-scroll">
      <h2 id="modalNoticiaTitulo">Publicar Nueva Noticia</h2>
      <p class="modal-crear-desc" id="modalNoticiaDesc">Comparte un comunicado con el equipo de Transworld.</p>

      <form id="formNoticia" action="/noticias/crear" method="POST" class="noticia-form">
        <div class="noticia-form-layout">
          <div class="noticia-form-col noticia-form-col-meta">
            <div class="campo">
              <label for="noticia_titulo">Título <span class="required-mark">*</span></label>
              <input type="text" id="noticia_titulo" name="titulo" required placeholder="Titular principal">
            </div>

            <div class="campo">
              <label for="noticia_subtitulo">Subtítulo (opcional)</label>
              <input type="text" id="noticia_subtitulo" name="subtitulo" placeholder="Bajada o resumen corto">
            </div>

            <div class="campo">
              <label>Imagen de Portada (opcional)</label>
              <div class="noticia-cover-actions">
                <button type="button" class="btn-modal-secundario" id="btn-select-cover">Seleccionar Portada</button>
                <span class="hint-modal" id="hintPortada">JPG, PNG o WebP · Máx. 8 MB</span>
              </div>
              <input type="file" id="filePortada" accept="image/*" hidden>
              <input type="hidden" name="imagen_portada" id="url_portada">
              <div class="noticia-cover-preview" id="cover-preview-wrap" hidden>
                <img id="cover-preview-img" alt="Vista previa de portada">
                <button type="button" class="btn-preview-quitar" id="btn-quitar-portada" title="Quitar portada">&times;</button>
              </div>
            </div>

            <div class="campo">
              <label>Galería Multimedia (documentos, imágenes y videos)</label>
              <input type="hidden" name="adjuntos_data" id="adjuntos_data" value="[]">
              <div class="noticia-cover-actions">
                <button type="button" class="btn-modal-secundario" onclick="document.getElementById('fileGaleria').click()">Adjuntar Archivos</button>
                <span class="hint-modal" id="statusGaleria">0 archivos seleccionados</span>
              </div>
              <input type="file" id="fileGaleria" multiple
                     accept="image/*,video/*,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.csv"
                     style="display:none;">
              <div class="galeria-preview-grid" id="galeriaPreview"></div>
              <p class="galeria-preview-vacio" id="galeriaPreviewVacio">Sin archivos adjuntos</p>
              <ul class="galeria-lista" id="galeriaLista" aria-hidden="true"></ul>
            </div>
          </div>

          <div class="noticia-form-col noticia-form-col-content">
            <div class="campo">
              <label for="noticia_contenido">Contenido <span class="required-mark">*</span></label>
              <div class="noticia-editor-host">
                <textarea name="contenido" id="noticia_contenido" rows="10" placeholder="Escribe aquí el cuerpo de la noticia..."></textarea>
              </div>
            </div>
          </div>
        </div>

        <div id="noticiaUploadStatus"></div>

        <div class="modal-form-actions">
          <button type="button" class="btn-modal-cancelar" onclick="cerrarModalNoticia()">Cancelar</button>
          <button type="submit" class="btn-modal-guardar" id="btnGuardarNoticia">Publicar Noticia</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div class="foto-crop-overlay" id="coverCropOverlay" role="dialog" aria-modal="true" aria-labelledby="coverCropTitle" hidden>
  <div class="foto-crop-modal">
    <div class="foto-crop-header">
      <h3 id="coverCropTitle">Recortar portada</h3>
      <button type="button" class="foto-crop-close" id="coverCropClose" aria-label="Cerrar">&times;</button>
    </div>
    <p class="foto-crop-hint">Arrastra y ajusta el encuadre. La portada se recorta en formato 16:9.</p>
    <div class="foto-crop-body">
      <div class="foto-crop-stage">
        <img id="coverCropImage" src="" alt="Vista previa para recortar">
      </div>
    </div>
    <p id="coverCropError" class="foto-crop-error" role="alert"></p>
    <div class="foto-crop-footer">
      <button type="button" class="btn-crop-cancel" id="coverCropCancel">Cancelar</button>
      <button type="button" class="btn-crop-save" id="coverCropSave">Aplicar recorte</button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="/js/profile-photo-cropper.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.8.2/tinymce.min.js" referrerpolicy="origin"></script>
<script>
  (function () {
    let coverApi = null;
    let galeriaActual = [];
    let modalMode = 'create';
    let pendingGaleriaUrls = [];

    const form = document.getElementById('formNoticia');
    const hiddenPortada = document.getElementById('url_portada');
    const hiddenGaleria = document.getElementById('adjuntos_data');
    const statusDiv = document.getElementById('noticiaUploadStatus');
    const btnSubmit = document.getElementById('btnGuardarNoticia');
    const filePortada = document.getElementById('filePortada');
    const fileGaleria = document.getElementById('fileGaleria');
    const statusGaleria = document.getElementById('statusGaleria');
    const galeriaPreview = document.getElementById('galeriaPreview');
    const galeriaPreviewVacio = document.getElementById('galeriaPreviewVacio');
    const btnSelectCover = document.getElementById('btn-select-cover');
    const coverPreviewWrap = document.getElementById('cover-preview-wrap');
    const coverPreviewImg = document.getElementById('cover-preview-img');
    const btnQuitarPortada = document.getElementById('btn-quitar-portada');
    const modalTitulo = document.getElementById('modalNoticiaTitulo');
    const modalDesc = document.getElementById('modalNoticiaDesc');

    function escapeHtml(str) {
      return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function esVideo(item) {
      return item.tipo === 'video' || item.resource_type === 'video';
    }

    function esDocumento(item) {
      return item.tipo === 'document' || item.resource_type === 'raw';
    }

    function extensionArchivo(nombre) {
      const part = (nombre || '').split('.').pop();
      return part && part.length <= 5 ? part.toUpperCase() : 'DOC';
    }

    function revocarPendingUrls() {
      pendingGaleriaUrls.forEach(function (url) {
        try { URL.revokeObjectURL(url); } catch (e) {}
      });
      pendingGaleriaUrls = [];
    }

    function actualizarPreviewPortada(url) {
      if (url) {
        coverPreviewImg.src = url;
        coverPreviewWrap.hidden = false;
        if (btnSelectCover) btnSelectCover.textContent = 'Cambiar Portada';
      } else {
        coverPreviewImg.removeAttribute('src');
        coverPreviewWrap.hidden = true;
        if (btnSelectCover) btnSelectCover.textContent = 'Seleccionar Portada';
      }
    }

    function quitarPortada() {
      hiddenPortada.value = '';
      filePortada.value = '';
      if (coverApi && coverApi.clearPhoto) coverApi.clearPhoto();
      actualizarPreviewPortada('');
    }

    function mediaPreviewHtml(item) {
      const nombre = escapeHtml(item.nombre || 'Archivo');
      if (esVideo(item)) {
        return '<video src="' + escapeHtml(item.url) + '" muted playsinline preload="metadata"></video>' +
          '<span class="galeria-preview-nombre">' + nombre + '</span>';
      }
      if (esDocumento(item)) {
        return '<div class="galeria-preview-doc">' +
          '<span class="galeria-preview-doc-icon"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></span>' +
          '<span class="galeria-preview-doc-ext">' + extensionArchivo(item.nombre) + '</span>' +
          '</div><span class="galeria-preview-nombre">' + nombre + '</span>';
      }
      return '<img src="' + escapeHtml(item.url) + '" alt="' + nombre + '">' +
        '<span class="galeria-preview-nombre">' + nombre + '</span>';
    }

    function pendingPreviewHtml(file, url) {
      const nombre = escapeHtml(file.name);
      if (file.type.startsWith('video/')) {
        return '<video src="' + url + '" muted playsinline preload="metadata"></video>' +
          '<span class="galeria-preview-nombre">' + nombre + '</span>';
      }
      if (file.type.startsWith('image/')) {
        return '<img src="' + url + '" alt="' + nombre + '">' +
          '<span class="galeria-preview-nombre">' + nombre + '</span>';
      }
      return '<div class="galeria-preview-doc">' +
        '<span class="galeria-preview-doc-icon"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></span>' +
        '<span class="galeria-preview-doc-ext">' + extensionArchivo(file.name) + '</span>' +
        '</div><span class="galeria-preview-nombre">' + nombre + '</span>';
    }

    function tipoDesdeRecurso(rt) {
      if (rt === 'image') return 'image';
      if (rt === 'video') return 'video';
      return 'document';
    }

    function parseAdjuntos(raw) {
      if (!raw) return [];
      try {
        const parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;
        if (typeof parsed === 'string') return JSON.parse(parsed);
        return Array.isArray(parsed) ? parsed : [];
      } catch (e) {
        return [];
      }
    }

    function actualizarContadorGaleria() {
      const nuevos = fileGaleria.files ? fileGaleria.files.length : 0;
      const total = galeriaActual.length + nuevos;
      statusGaleria.textContent = total === 0
        ? '0 archivos seleccionados'
        : total + ' archivo(s)';
      if (galeriaPreviewVacio) {
        galeriaPreviewVacio.hidden = total > 0;
      }
    }

    function renderGaleria() {
      hiddenGaleria.value = JSON.stringify(galeriaActual);
      revocarPendingUrls();

      let html = galeriaActual.map(function (item, index) {
        return '<div class="galeria-preview-item" data-source="saved" data-index="' + index + '">' +
          mediaPreviewHtml(item) +
          '<button type="button" class="btn-galeria-quitar" data-source="saved" data-index="' + index + '" title="Quitar">&times;</button></div>';
      }).join('');

      const pending = fileGaleria.files ? Array.from(fileGaleria.files) : [];
      pending.forEach(function (file, index) {
        const url = URL.createObjectURL(file);
        pendingGaleriaUrls.push(url);
        html += '<div class="galeria-preview-item" data-source="pending" data-index="' + index + '">' +
          pendingPreviewHtml(file, url) +
          '<button type="button" class="btn-galeria-quitar" data-source="pending" data-index="' + index + '" title="Quitar">&times;</button></div>';
      });

      galeriaPreview.innerHTML = html;

      galeriaPreview.querySelectorAll('.btn-galeria-quitar').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const source = btn.getAttribute('data-source');
          const idx = parseInt(btn.getAttribute('data-index'), 10);
          if (source === 'saved') {
            if (confirm('¿Quitar este archivo de la galería?')) {
              galeriaActual.splice(idx, 1);
              renderGaleria();
            }
          } else if (source === 'pending') {
            const dt = new DataTransfer();
            const files = Array.from(fileGaleria.files || []);
            files.forEach(function (f, i) {
              if (i !== idx) dt.items.add(f);
            });
            fileGaleria.files = dt.files;
            renderGaleria();
          }
        });
      });

      actualizarContadorGaleria();
    }

    function resetModalNoticia() {
      modalMode = 'create';
      form.action = '/noticias/crear';
      modalTitulo.textContent = 'Publicar Nueva Noticia';
      modalDesc.textContent = 'Comparte un comunicado con el equipo. La portada se recorta en formato 16:9.';
      btnSubmit.textContent = 'Publicar Noticia';
      btnSubmit.disabled = false;
      statusDiv.style.display = 'none';
      statusDiv.textContent = '';

      document.getElementById('noticia_titulo').value = '';
      document.getElementById('noticia_subtitulo').value = '';
      hiddenPortada.value = '';
      hiddenGaleria.value = '[]';
      galeriaActual = [];
      fileGaleria.value = '';
      filePortada.value = '';
      quitarPortada();
      revocarPendingUrls();
      renderGaleria();

      const ed = typeof tinymce !== 'undefined' ? tinymce.get('noticia_contenido') : null;
      if (ed) ed.setContent('');
      else document.getElementById('noticia_contenido').value = '';
    }

    function setContenidoEditor(html) {
      const ed = typeof tinymce !== 'undefined' ? tinymce.get('noticia_contenido') : null;
      if (ed) {
        ed.setContent(html || '');
      } else {
        document.getElementById('noticia_contenido').value = html || '';
      }
    }

    function initTinyMCE(callback) {
      if (typeof tinymce === 'undefined') return;
      if (tinymce.get('noticia_contenido')) {
        if (callback) callback();
        return;
      }

      tinymce.init({
        selector: '#noticia_contenido',
        plugins: 'lists link',
        toolbar: 'undo redo | bold italic underline | alignleft aligncenter alignright | bullist numlist | removeformat',
        promotion: false,
        branding: false,
        menubar: false,
        statusbar: false,
        height: 520,
        init_instance_callback: function () {
          if (callback) callback();
        },
      });
    }

    function abrirModal(conAfterOpen) {
      IntranetModal.open('modalCrearNoticia');
      setTimeout(function () {
        initTinyMCE(conAfterOpen);
      }, 320);
    }

    window.abrirModalCrearNoticia = function () {
      resetModalNoticia();
      abrirModal();
    };

    window.abrirModalEditarNoticia = function (noticia) {
      resetModalNoticia();
      modalMode = 'edit';
      form.action = '/noticias/editar/' + noticia.id;
      modalTitulo.textContent = 'Editar Noticia';
      modalDesc.textContent = 'Modifica los campos y guarda los cambios.';
      btnSubmit.textContent = 'Guardar Cambios';

      document.getElementById('noticia_titulo').value = noticia.title || '';
      document.getElementById('noticia_subtitulo').value = noticia.subtitle || '';
      hiddenPortada.value = noticia.image || '';
      actualizarPreviewPortada(noticia.image || '');

      galeriaActual = parseAdjuntos(noticia.attachments);
      renderGaleria();

      const contenido = noticia.content || '';
      abrirModal(function () {
        setContenidoEditor(contenido);
      });
    };

    window.cerrarModalNoticia = function () {
      IntranetModal.close('modalCrearNoticia');
    };

    window.cerrarModalCrearNoticia = window.cerrarModalNoticia;

    if (window.ProfilePhotoCropper) {
      coverApi = ProfilePhotoCropper.init({
        fileInputId: 'filePortada',
        previewImgId: 'cover-preview-img',
        previewPlaceholderId: null,
        selectBtnId: 'btn-select-cover',
        overlayId: 'coverCropOverlay',
        cropImgId: 'coverCropImage',
        closeBtnId: 'coverCropClose',
        cancelBtnId: 'coverCropCancel',
        saveBtnId: 'coverCropSave',
        errorElId: 'coverCropError',
        aspectRatio: 16 / 9,
        outputWidth: 1280,
        outputHeight: 720,
        maxSizeMb: 8,
        outputFilename: 'portada-noticia.jpg',
        selectLabel: 'Seleccionar Portada',
        changeLabel: 'Cambiar Portada',
        onCropped: function () {
          coverPreviewWrap.hidden = false;
        },
      });
    }

    if (btnQuitarPortada) {
      btnQuitarPortada.addEventListener('click', quitarPortada);
    }

    if (fileGaleria) {
      fileGaleria.addEventListener('change', renderGaleria);
    }

    function checkFileSize(files) {
      for (const f of files) {
        if (f.size > 50 * 1024 * 1024) return 'El archivo ' + f.name + ' supera 50 MB.';
      }
      return null;
    }

    async function uploadOne(file) {
      const fd = new FormData();
      fd.append('archivo', file);
      const res = await fetch('/noticias/upload', { method: 'POST', body: fd });
      if (!res.ok) throw new Error('Error subiendo ' + file.name);
      return res.json();
    }

    if (form) {
      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        if (tinymce.get('noticia_contenido')) tinymce.triggerSave();

        const filesP = filePortada.files ? Array.from(filePortada.files) : [];
        const filesG = fileGaleria.files ? Array.from(fileGaleria.files) : [];

        const errP = checkFileSize(filesP);
        if (errP) return alert('Portada: ' + errP);
        const errG = checkFileSize(filesG);
        if (errG) return alert('Galería: ' + errG);

        if (filesP.length === 0 && filesG.length === 0) {
          hiddenGaleria.value = JSON.stringify(galeriaActual);
          form.submit();
          return;
        }

        try {
          btnSubmit.disabled = true;
          btnSubmit.textContent = filesP.length + filesG.length > 0 ? 'Subiendo…' : btnSubmit.textContent;
          statusDiv.style.display = 'block';

          if (filesP.length > 0) {
            statusDiv.textContent = 'Subiendo portada…';
            const dataP = await uploadOne(filesP[0]);
            hiddenPortada.value = dataP.secure_url;
          }

          if (filesG.length > 0) {
            for (let i = 0; i < filesG.length; i++) {
              statusDiv.textContent = 'Subiendo galería (' + (i + 1) + '/' + filesG.length + ')…';
              const dataG = await uploadOne(filesG[i]);
              galeriaActual.push({
                url: dataG.secure_url,
                public_id: dataG.public_id,
                resource_type: dataG.resource_type,
                tipo: tipoDesdeRecurso(dataG.resource_type),
                nombre: filesG[i].name,
              });
            }
          }

          hiddenGaleria.value = JSON.stringify(galeriaActual);
          statusDiv.textContent = modalMode === 'edit' ? 'Guardando cambios…' : 'Subida completa. Guardando noticia…';
          form.submit();
        } catch (err) {
          console.error(err);
          statusDiv.innerHTML = '<span style="color:#dc2626">Error: ' + err.message + '</span>';
          btnSubmit.disabled = false;
          btnSubmit.textContent = modalMode === 'edit' ? 'Guardar Cambios' : 'Publicar Noticia';
        }
      });
    }
  })();
</script>
