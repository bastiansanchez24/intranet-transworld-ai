<style>
  .contenedor { max-width: 800px; margin: 0 auto; padding: 20px; font-family: system-ui, -apple-system, sans-serif; }
  .page-title, h2 { color: #003a70; font-size: 1.8rem; font-weight: 800; margin: 0 0 10px 0; border-bottom: 2px solid #003a70; padding-bottom: 10px; }

  .link-volver { display: inline-flex; align-items: center; gap: 6px; background: #f8fafc; border: 1px solid #cbd5e0; color: #4a5568; padding: 8px 15px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; margin-bottom: 20px;}
  .link-volver:hover { background: #edf2f7; color: #1a202c; }

  .panel { background: #fff; border: 1px solid #e0e6ed; border-radius: 8px; padding: 30px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); margin-bottom: 25px; }
  .form-ticket label { font-weight: 700; color: #4a5568; display: block; margin-bottom: 8px; font-size: 0.95rem; }
  .form-ticket input[type="text"], 
  .form-ticket textarea { width: 100%; padding: 12px 15px; border: 1px solid #cbd5e0; border-radius: 6px; font-size: 0.95rem; background: #f8fafc; box-sizing: border-box; transition: all 0.2s; font-family: inherit; margin-bottom: 20px;}
  .form-ticket input:focus, 
  .form-ticket textarea:focus { border-color: #003a70; outline: none; background: #fff; box-shadow: 0 0 0 3px rgba(0, 58, 112, 0.1);}
  .form-ticket textarea { resize: vertical; min-height: 150px; max-height: 500px; } /* Evita que se estire a los lados */

  /* Botones */
  .btn-primario { background: #003a70; color: #fff; border: none; padding: 14px 24px; border-radius: 6px; font-weight: bold; cursor: pointer; transition: background 0.2s; font-size: 1rem; width: 100%; margin-top: 10px;}
  .btn-primario:hover { background: #002a52; }
  .btn-secundario { background: #ffffff; color: #4a5568; border: 1px solid #cbd5e0; padding: 10px 15px; border-radius: 6px; font-weight: bold; cursor: pointer; transition: all 0.2s; font-size: 0.9rem; }
  .btn-secundario:hover { background: #f8fafc; color: #1a202c; border-color: #a0aec0;}
  .small-text { font-size: 0.85rem; color: #718096; font-style: italic;}
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.8.2/tinymce.min.js"></script>
<script>
  tinymce.init({
    selector: 'textarea[name="content"]',
    plugins: 'lists link',
    toolbar: 'undo redo | fontfamily fontsize forecolor backcolor | bold italic underline | alignleft aligncenter alignright | bullist numlist | removeformat',
    promotion: false,
    branding: false
  });
</script>

<div class="contenedor">
  <div style="margin-bottom: 20px;">
    <a href="/noticias" class="link-volver">← Volver a Noticias</a>
  </div>
  
  <h2>Publicar Nueva Noticia</h2>
  
  <div class="panel">
    <form id="formCrearNoticia" action="/noticias/crear" method="POST" class="form-ticket">
      
      <label>Título</label>
      <input type="text" name="title" required placeholder="Titular principal">

      <label>Subtítulo (Opcional)</label>
      <input type="text" name="subtitle" placeholder="Bajada o resumen corto">

      <label style="margin-top:15px;">Imagen de Portada (Opcional)</label>
      <input type="hidden" name="imagen_portada" id="url_portada">
   
      <div style="display:flex; gap:10px; align-items:center;">
        <button type="button" class="btn btn-secundario" onclick="document.getElementById('filePortada').click()">Seleccionar Portada</button>
        <span id="statusPortada" class="small-text">Sin archivo seleccionado</span>
      </div>
      <input type="file" id="filePortada" accept="image/*" style="display: none;" onchange="document.getElementById('statusPortada').textContent = this.files[0] ? this.files[0].name : 'Sin archivo'">
      
      <label style="margin-top:15px;">Galería Multimedia (Imágenes y Videos)</label>
      <input type="hidden" name="adjuntos_data" id="adjuntos_data" value="[]">
      
      <div style="display:flex; gap:10px; align-items:center;">
        <button type="button" class="btn btn-secundario" onclick="document.getElementById('fileGaleria').click()">Adjuntar Archivos (Múltiple)</button>
        <span id="statusGaleria" class="small-text">0 archivos seleccionados</span>
      </div>
      <input type="file" id="fileGaleria" multiple accept="image/*,video/*" style="display: none;" onchange="document.getElementById('statusGaleria').textContent = this.files.length + ' archivos seleccionados'">

      <label style="margin-top:15px;">Contenido</label>
      <textarea name="content" id="contenido" rows="10" placeholder="Escribe aquí el cuerpo de la noticia..."></textarea>

      <div id="uploadStatus" style="margin-top: 15px; display: none; font-weight: bold; color: #003a70;"></div>

      <button type="submit" id="btnPublicar" class="btn btn-primario" style="margin-top:20px;">Publicar Noticia</button>
    </form>
  </div>
</div>

<script>
  (function() {
    const form = document.getElementById('formCrearNoticia');
    const filePortada = document.getElementById('filePortada');
    const fileGaleria = document.getElementById('fileGaleria');
    const hiddenPortada = document.getElementById('url_portada');
    const hiddenGaleria = document.getElementById('adjuntos_data');
    const statusDiv = document.getElementById('uploadStatus');
    const btnSubmit = document.getElementById('btnPublicar');

    if (!form) return;

    function checkFileSize(files) {
      for (let f of files) {
        const limit = 50 * 1024 * 1024;
        if (f.size > limit) return `El archivo ${f.name} es muy pesado.`;
      }
      return null;
    }

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      tinymce.triggerSave();

      const filesP = filePortada.files ? Array.from(filePortada.files) : [];
      const filesG = fileGaleria.files ? Array.from(fileGaleria.files) : [];
      const totalFiles = filesP.length + filesG.length;
      if (totalFiles === 0) {
        form.submit();
        return;
      }

      const errP = checkFileSize(filesP);
      if (errP) return alert('Portada: ' + errP);
      const errG = checkFileSize(filesG);
      if (errG) return alert('Galería: ' + errG);
      try {
        btnSubmit.disabled = true;
        btnSubmit.innerText = 'Subiendo contenido...';
        statusDiv.style.display = 'block';
 
        const uploadOne = async (file) => {
          const fd = new FormData();
          fd.append('archivo', file);

          const res = await fetch('/noticias/upload', { method: 'POST', body: fd });
          if (!res.ok) throw new Error('Error subiendo ' + file.name);
          return await res.json();
        };

        if (filesP.length > 0) {
          statusDiv.innerHTML = 'Subiendo portada...';
          const dataP = await uploadOne(filesP[0]);
          hiddenPortada.value = dataP.secure_url;
        }

        if (filesG.length > 0) {
          let uploadedList = [];
          for (let i = 0; i < filesG.length; i++) {
            statusDiv.innerHTML = `Subiendo galería (${i + 1}/${filesG.length})...`;
            const dataG = await uploadOne(filesG[i]);
            
            uploadedList.push({
              url: dataG.secure_url,
              public_id: dataG.public_id,
              resource_type: 'image',
              tipo: 'image',
              nombre: filesG[i].name
            });
          }
          hiddenGaleria.value = JSON.stringify(uploadedList);
        }

        statusDiv.innerHTML = 'Subida completa. Guardando noticia...';
        form.submit();

      } catch (err) {
        console.error(err);
        statusDiv.innerHTML = `<span style="color:red">Error: ${err.message}</span>`;
        btnSubmit.disabled = false;
        btnSubmit.innerText = 'Intentar de nuevo';
      }
    });
  })();
</script>