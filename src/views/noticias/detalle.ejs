<style>
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap');

  /* CONTENEDOR PRINCIPAL */
  .detalle-contenedor {
    max-width: 900px;
    margin: 30px auto;
    padding: 0 20px;
    font-family: 'Montserrat', sans-serif;
  }

  /* BOTÓN VOLVER */
  .link-volver {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #003a70;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 25px;
    transition: transform 0.2s ease;
  }
  .link-volver:hover {
    transform: translateX(-5px);
    color: #002a52;
  }

  /* TARJETA DE LA NOTICIA */
  .noticia-card {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
    overflow: hidden;
    border: 1px solid #e2e8f0;
  }

  /* PORTADA */
  .noticia-portada-link {
    display: block;
    width: 100%;
    height: 420px;
    overflow: hidden;
    background-color: #f1f5f9;
  }
  .noticia-portada-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .noticia-portada-link:hover .noticia-portada-img {
    transform: scale(1.03);
  }

  /* CONTENIDO INTERIOR */
  .noticia-body {
    padding: 40px;
  }

  .noticia-titulo {
    color: #003a70;
    font-size: 2.4rem;
    font-weight: 800;
    margin: 0 0 12px 0;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }

  .noticia-subtitulo {
    color: #475569;
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0 0 20px 0;
    line-height: 1.5;
  }

  .noticia-fecha {
    display: inline-block;
    background: #f1f5f9;
    color: #64748b;
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 35px;
    border: 1px solid #e2e8f0;
  }

  .noticia-contenido {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #334155;
    white-space: pre-wrap;
  }

  /* MULTIMEDIA */
  .titulo-seccion {
    color: #003a70;
    font-size: 1.4rem;
    font-weight: 700;
    margin: 40px 0 20px 0;
    padding-bottom: 10px;
    border-bottom: 2px solid #e2e8f0;
  }

  .grid-imagenes {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 15px;
  }

  .media-item {
    display: block;
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    transition: all 0.3s ease;
    aspect-ratio: 4 / 3;
    background: #f8fafc;
  }
  .media-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    border: 1px solid #003a70;
  }
  .media-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .grid-videos {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }
  .media-video {
    width: 100%;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    background: #000;
    aspect-ratio: 16 / 9;
    outline: none;
  }

  /* BOTÓN ELIMINAR */
  .btn-eliminar {
    background-color: #ef4444;
    color: white;
    border: none;
    padding: 12px 20px;
    border-radius: 6px;
    font-weight: 600;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-eliminar:hover {
    background-color: #dc2626;
  }
  
  /* BOTONES DE ADMINISTRACIÓN */
  .admin-actions {
    display: flex;
    gap: 15px;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 25px;
  }
  
  .btn-editar {
    background-color: #f59e0b;
    color: white;
    text-decoration: none;
    padding: 12px 20px;
    border-radius: 6px;
    font-weight: 600;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.95rem;
    transition: background 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-editar:hover {
    background-color: #d97706;
  }

  .btn-correo {
    background-color: #28a745;
    color: white;
    border: none;
    padding: 12px 20px;
    border-radius: 6px;
    font-weight: 600;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-correo:hover {
    background-color: #218838;
  }

  .btn-destacar {
    background-color: #003a70;
    color: white;
    border: none;
    padding: 12px 20px;
    border-radius: 6px;
    font-weight: 600;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-destacar:hover {
    background-color: #002a52;
  }
  .btn-destacar--activa {
    background-color: #f59e0b;
  }
  .btn-destacar--activa:hover {
    background-color: #d97706;
  }

  .badge-destacada {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #fef3c7;
    color: #92400e;
    border: 1px solid #fcd34d;
    padding: 8px 14px;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.85rem;
    margin-bottom: 16px;
  }

  .alerta-flash {
    padding: 14px 18px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .alerta-flash--ok {
    background: #d1fae5;
    color: #065f46;
    border: 1px solid #6ee7b7;
  }
  .alerta-flash--error {
    background: #fee2e2;
    color: #991b1b;
    border: 1px solid #fca5a5;
  }

  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .modal-overlay.is-open {
    display: flex;
  }
  .modal-content {
    background: #fff;
    border-radius: 10px;
    padding: 28px;
    max-width: 480px;
    width: 100%;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    position: relative;
  }
  .modal-close {
    position: absolute;
    top: 12px;
    right: 14px;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #64748b;
    line-height: 1;
  }
  .modal-actions {
    display: flex;
    gap: 12px;
    margin-top: 22px;
  }
  .modal-actions form,
  .modal-actions button {
    flex: 1;
  }
  .btn-modal-secundario {
    background: #f1f5f9;
    color: #475569;
    border: 1px solid #cbd5e0;
    padding: 12px 16px;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    width: 100%;
    font-family: 'Montserrat', sans-serif;
  }
  .btn-modal-primario {
    background: #28a745;
    color: white;
    border: none;
    padding: 12px 16px;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    width: 100%;
    font-family: 'Montserrat', sans-serif;
  }
  .btn-modal-primario:hover {
    background: #218838;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .noticia-body {
      padding: 25px;
    }
    .noticia-portada-link {
      height: 250px;
    }
    .noticia-titulo {
      font-size: 1.9rem;
    }
  }
</style>

<div class="detalle-contenedor">
  <a href="/noticias" class="link-volver">← Volver a Noticias</a>

  <% if (typeof ok !== 'undefined' && ok === 'correo_enviado') { %>
    <div class="alerta-flash alerta-flash--ok">
      Aviso enviado por correo<%= destinatarios ? ' a ' + destinatarios + ' colaborador(es)' : '' %>.
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error === 'sin_destinatarios') { %>
    <div class="alerta-flash alerta-flash--error">
      No hay usuarios con correo registrado para enviar el aviso.
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error === 'correo_fallido') { %>
    <div class="alerta-flash alerta-flash--error">
      No se pudo enviar el aviso por correo. Inténtalo de nuevo.
    </div>
  <% } %>
  <% if (typeof ok !== 'undefined' && ok === 'destacada_marcada') { %>
    <div class="alerta-flash alerta-flash--ok">
      Esta noticia ahora aparece destacada en el inicio con su portada.
    </div>
  <% } %>
  <% if (typeof ok !== 'undefined' && ok === 'destacada_quitada') { %>
    <div class="alerta-flash alerta-flash--ok">
      La noticia ya no está destacada en el inicio.
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error === 'destacada_fallida') { %>
    <div class="alerta-flash alerta-flash--error">
      No se pudo actualizar la noticia destacada. Inténtalo de nuevo.
    </div>
  <% } %>

  <article class="noticia-card">
    
    <% if (noticia.imagen) { %>
      <a href="<%= noticia.imagen %>" target="_blank" class="noticia-portada-link" title="Ver portada completa">
        <img src="<%= noticia.imagen %>" class="noticia-portada-img" alt="Portada de la noticia">
      </a>
    <% } %>
    
    <div class="noticia-body">
      
      <h1 class="noticia-titulo"><%= noticia.titulo %></h1>

      <% if (noticia.destacada) { %>
        <div class="badge-destacada" aria-label="Noticia destacada en el inicio">★ Destacada en el inicio</div>
      <% } %>
      
      <% if (noticia.subtitulo) { %>
        <h3 class="noticia-subtitulo"><%= noticia.subtitulo %></h3>
      <% } %>
      
      <div class="noticia-fecha">
        Publicado el <%= new Date(noticia.fecha_creacion).toLocaleDateString('es-CL', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
      </div>

      <div class="noticia-contenido"><%- noticia.contenido %></div>

      <% 
         let adjuntos = [];
         try {
           if (typeof noticia.adjuntos === 'string') {
               adjuntos = JSON.parse(noticia.adjuntos);
           } else if (noticia.adjuntos) {
               adjuntos = noticia.adjuntos;
           }
         } catch(e) { 
             console.error("Error cargando adjuntos:", e); 
         }

         const imagenes = adjuntos.filter(a => a.tipo === 'image' || (a.resource_type === 'image' && a.tipo !== 'video'));
         const videos = adjuntos.filter(a => a.tipo === 'video' || a.resource_type === 'video');
      %>

      <% if (imagenes.length > 0 || videos.length > 0) { %>
        
        <% if (imagenes.length > 0) { %>
          <div class="titulo-seccion">Galería de Imágenes</div>
          <div class="grid-imagenes">
            <% imagenes.forEach(img => { %>
              <a href="<%= img.url %>" target="_blank" class="media-item" title="Ver imagen completa">
                <img src="<%= img.url %>" alt="<%= img.nombre %>">
              </a>
            <% }) %>
          </div>
        <% } %>

        <% if (videos.length > 0) { %>
          <div class="titulo-seccion">Videos adjuntos</div>
          <div class="grid-videos">
            <% videos.forEach(vid => { %>
              <video class="media-video" src="<%= vid.url %>" controls title="<%= vid.nombre %>"></video>
            <% }) %>
          </div>
        <% } %>

      <% } %>

      <% if (typeof can !== 'undefined' && can.noticias_write) { %>
        <hr style="margin: 45px 0 25px 0; border: 0; border-top: 1px solid #e2e8f0;">
        
        <div class="admin-actions">
          <a href="/noticias/editar/<%= noticia.id %>" class="btn-editar">
            Editar Noticia
          </a>

          <% if (noticia.destacada) { %>
            <form action="/noticias/destacar/<%= noticia.id %>" method="POST" style="margin: 0;">
              <input type="hidden" name="quitar" value="1">
              <button type="submit" class="btn-destacar btn-destacar--activa">
                Quitar destacada
              </button>
            </form>
          <% } else { %>
            <form action="/noticias/destacar/<%= noticia.id %>" method="POST"
                  onsubmit="return confirm('¿Marcar esta noticia como destacada en el inicio? Reemplazará la destacada actual.');"
                  style="margin: 0;">
              <button type="submit" class="btn-destacar">
                Marcar como destacada
              </button>
            </form>
          <% } %>

          <form action="/noticias/enviar-correo/<%= noticia.id %>" method="POST"
                onsubmit="return confirm('¿Enviar aviso de esta noticia por correo a todos los colaboradores?');"
                style="margin: 0;">
            <button type="submit" class="btn-correo">
              Avisar por correo
            </button>
          </form>

          <% if (typeof can !== 'undefined' && can.noticias_write) { %>
            <form action="/noticias/eliminar/<%= noticia.id %>" method="POST" onsubmit="return confirm('¿Seguro que deseas eliminar esta noticia de forma permanente?');" style="margin: 0;">
              <button type="submit" class="btn-eliminar">
                Eliminar Noticia
              </button>
            </form>
          <% } %>
        </div>
      <% } %>

    </div>
  </article>
</div>

<% if (typeof can !== 'undefined' && can.noticias_write && typeof publicada !== 'undefined' && publicada) { %>
<div class="modal-overlay" id="modal-correo-publicada">
  <div class="modal-content">
    <button type="button" class="modal-close" onclick="cerrarModalCorreo()" aria-label="Cerrar">&times;</button>
    <h3 style="color: #003a70; margin: 0 0 10px 0; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px;">
      Noticia publicada
    </h3>
    <p style="color: #475569; line-height: 1.6; margin: 0;">
      La noticia se guardó correctamente. ¿Deseas enviar un aviso por correo a todos los colaboradores?
    </p>
    <div class="modal-actions">
      <button type="button" class="btn-modal-secundario" onclick="cerrarModalCorreo()">
        No, gracias
      </button>
      <form action="/noticias/enviar-correo/<%= noticia.id %>" method="POST" style="margin: 0;">
        <button type="submit" class="btn-modal-primario">
          Sí, enviar aviso
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  function abrirModalCorreo() {
    const modal = document.getElementById('modal-correo-publicada');
    if (!modal) return;
    if (window.IntranetModal) {
      IntranetModal.open('modal-correo-publicada');
    } else {
      modal.classList.add('is-open');
    }
  }

  function cerrarModalCorreo() {
    const modal = document.getElementById('modal-correo-publicada');
    if (!modal) return;
    if (window.IntranetModal) {
      IntranetModal.close('modal-correo-publicada');
    } else {
      modal.classList.remove('is-open');
    }
    if (window.history && window.history.replaceState) {
      const url = new URL(window.location.href);
      url.searchParams.delete('publicada');
      window.history.replaceState({}, '', url.pathname + url.search);
    }
  }

  document.addEventListener('DOMContentLoaded', abrirModalCorreo);
</script>
<% } %>