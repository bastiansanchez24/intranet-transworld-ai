<style>
  .contenedor-noticias {
    padding-bottom: 80px;
  }

  .alerta-ok {
    background: #d4edda;
    color: #155724;
    padding: 14px 16px;
    border-radius: 8px;
    margin-bottom: 20px;
    border: 1px solid #c3e6cb;
    font-weight: 600;
  }

  .no-data {
    text-align: center;
    padding: 40px;
    color: #718096;
    background: #f8fafc;
    border-radius: 8px;
    border: 1px dashed #cbd5e0;
  }

  /* Grilla 2×2 — cards horizontales */
  .grid-noticias {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .card-noticia {
    background: var(--color-surface, #fff);
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: var(--shadow-card, 0 2px 5px rgba(0, 0, 0, 0.04));
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    text-decoration: none;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    min-height: 120px;
    color: inherit;
  }

  .card-noticia:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-lg, 0 8px 15px rgba(0, 0, 0, 0.08));
    border-color: var(--color-border-strong, #cbd5e0);
  }

  .card-thumb {
    flex: 0 0 120px;
    width: 120px;
    aspect-ratio: 1 / 1;
    background: var(--color-surface-muted, #f1f5f9);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--color-border, #e2e8f0);
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .card-noticia:hover .card-thumb img {
    transform: scale(1.06);
  }

  .card-thumb-placeholder {
    font-size: 2rem;
    opacity: 0.45;
    line-height: 1;
  }

  .card-body {
    flex: 1;
    min-width: 0;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    background: var(--color-surface, #fff);
  }

  .card-titulo {
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-heading, #003a70);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-subtitulo {
    font-size: 0.85rem;
    color: var(--color-text-muted, #64748b);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-fecha {
    font-size: 0.7rem;
    font-weight: 700;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-top: auto;
  }

  /* Botón flotante */
  .fab {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 1000;
    width: 58px;
    height: 58px;
    border: none;
    border-radius: 50%;
    background: linear-gradient(135deg, #003a70 0%, #0069c2 100%);
    color: #fff;
    font-size: 1.8rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-family: inherit;
    box-shadow: 0 6px 20px rgba(0, 58, 112, 0.45);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .fab:hover {
    transform: scale(1.1) rotate(10deg);
    box-shadow: 0 10px 28px rgba(0, 58, 112, 0.55);
    color: #fff;
  }

  .fab-tooltip {
    position: fixed;
    bottom: 34px;
    right: 100px;
    z-index: 999;
    background: #1a202c;
    color: #fff;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .fab:hover + .fab-tooltip { opacity: 1; }

  @media (max-width: 640px) {
    .grid-noticias { grid-template-columns: 1fr; }
    .contenedor-noticias { padding-bottom: 90px; }
    .fab { bottom: 22px; right: 22px; }
    .fab-tooltip { right: 88px; bottom: 26px; }
  }
</style>

<div class="contenedor contenedor-noticias">
  <div class="page-header">
    <h2 class="page-title">Noticias y Comunicados</h2>
    <p class="page-description">Entérate de las últimas novedades de Transworld.</p>
  </div>

  <% if (typeof ok !== 'undefined' && ok) { %>
    <div class="alerta-ok"><%= ok %></div>
  <% } %>

  <% if (!noticias || noticias.length === 0) { %>
    <p class="no-data">No hay noticias publicadas aún.</p>
  <% } else { %>
    <div class="grid-noticias">
      <% noticias.forEach(n => { %>
        <a href="/noticias/<%= n.id %>" class="card-noticia">
          <div class="card-thumb">
            <% if (n.image) { %>
              <img src="<%= n.image %>" alt="Portada de <%= n.title %>" loading="lazy">
            <% } else { %>
              <span class="card-thumb-placeholder" aria-hidden="true"><%- include('../partials/icon', { name: 'news' }) %></span>
            <% } %>
          </div>
          <div class="card-body">
            <div class="card-titulo"><%= n.title %></div>
            <% if (n.subtitle) { %>
              <div class="card-subtitulo"><%= n.subtitle %></div>
            <% } %>
            <div class="card-fecha">
              <%= new Date(n.created_at).toLocaleDateString('es-CL', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</div>

<% if (typeof can !== 'undefined' && can.noticias_write) { %>
  <button type="button" class="fab" title="Publicar noticia" onclick="abrirModalCrearNoticia()" aria-label="Publicar noticia">＋</button>
  <span class="fab-tooltip">Publicar noticia</span>
  <%- include('partials/modal-noticia') %>
<% } %>
