<!DOCTYPE html>
<html lang="es">
<head>
  <style>
    /* ESTILOS GRILLA Y TARJETAS */
    .grid-noticias {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 25px;
      margin-top: 30px;
    }

    .card-noticia {
      background-color: #002a52;
      color: white;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 4px 10px rgba(0,0,0,0.15);
      transition: transform 0.2s, box-shadow 0.2s, background-color 0.2s;
      text-decoration: none; 
      display: flex;
      flex-direction: column;
      height: 100%;
      position: relative;
    }

    .card-noticia:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.3);
      background-color: #003a70; 
    }

    .card-imagen {
      width: 100%;
      height: 200px;
      object-fit: cover;
      background-color: #001f3f; 
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .card-body {
      padding: 20px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .card-titulo {
      font-size: 1.25rem;
      font-weight: bold;
      margin-bottom: 10px;
      color: white;
      line-height: 1.3;
    }

    .card-subtitulo {
      font-size: 0.95rem;
      color: #b3d7ff;
      margin-bottom: 15px;
      flex-grow: 1;
    }

    .card-fecha {
      font-size: 0.8rem;
      color: #8bb9e8; 
      margin-top: auto;
      text-align: right;
    }

    /* ESTILOS BOTONES DE ACCIÓN */
    .botones-container {
      display: flex;
      gap: 20px; 
      margin-top: 20px; 
      margin-bottom: 10px;
      flex-wrap: wrap;
    }

    .boton-accion {
      display: inline-block;
      flex: 1;
      min-width: 250px;
      padding: 20px;
      text-align: center;
      text-decoration: none;
      color: white;
      border-radius: 8px;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    
    .boton-accion:hover {
      transform: translateY(-3px);
      box-shadow: 0 6px 12px rgba(0,0,0,0.2);
    }

    .btn-verde { background-color: #28a745; }
    .btn-verde:hover { background-color: #218838; }

    .btn-azul { background-color: #003a70; }
    .btn-azul:hover { background-color: #002a50; }

  </style>
</head>
<body>

  <h2>Noticias y Comunicados</h2>
  <p>Entérate de las últimas novedades de Transworld.</p>

  <% if (typeof ok !== 'undefined' && ok) { %>
    <div style="background: #d4edda; color: #155724; padding: 15px; border-radius: 5px; margin-bottom: 20px;">
      <%= ok %>
    </div>
  <% } %>

  <% if (typeof can !== 'undefined' && can.noticias_write) { %>
    <div class="botones-container">
      
      <a class="boton-accion btn-verde" href="/noticias/crear">
        <div style="font-size: 2rem; margin-bottom: 5px;">✍️</div>
        <strong style="font-size: 1.2rem; display: block; margin-bottom: 5px;">Publicar Nueva Noticia</strong>
        <span style="display:block; font-weight:normal; font-size:0.9rem; opacity: 0.9;">
          Comparte un comunicado con el equipo
        </span>
      </a>

    </div>
  <% } %>

  <% if (!noticias || noticias.length === 0) { %>
    <div style="margin-top: 40px; text-align: center; color: #666;">
      <p>No hay noticias publicadas aún.</p>
    </div>
  <% } else { %>
    <div class="grid-noticias">
      <% noticias.forEach(n => { %>
        <a href="/noticias/<%= n.id %>" class="card-noticia">
          
          <% if (n.image) { %>
            <img src="<%= n.image %>" alt="Portada" class="card-imagen">
          <% } else { %>
            <div class="card-imagen" style="display: flex; align-items: center; justify-content: center; opacity: 0.5;">
              <span style="font-size: 3rem;">📰</span>
            </div>
          <% } %>

          <div class="card-body">
            <div class="card-titulo"><%= n.title %></div>
            
            <% if (n.subtitle) { %>
              <div class="card-subtitulo"><%= n.subtitle %></div>
            <% } %>

            <div class="card-fecha">
              <%= new Date(n.created_at).toLocaleDateString('es-CL', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>

</body>
</html>