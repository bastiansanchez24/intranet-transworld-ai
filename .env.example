# Copia este archivo a .env y completa los valores reales.
# Nunca subas .env al repositorio.

# --- Aplicación ---
PORT=3000
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=cambiar-por-un-secreto-largo-y-aleatorio

# --- Base de datos (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
# DB_PASS=          # alias aceptado por db.js si DB_PASSWORD no está definido
DB_NAME=

# --- Correo (Brevo / SMTP) ---
MAIL_FROM=noreply@transworld.cl
BREVO_API_KEY=
# SMTP_PASS=        # fallback si no usas BREVO_API_KEY

# --- Notificaciones administrativas ---
ADMIN_NOTIFY_EMAIL=

# --- SharePoint / Microsoft Graph ---
MS_CLIENT_ID=
MS_TENANT_ID=
MS_CLIENT_SECRET=
SP_SITE_ID=

# --- LinkedIn (feed en inicio) ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=
LINKEDIN_ORG_ID=

# --- Email listener (IMAP, script email-listener) ---
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# --- Auth legacy (solo si aplica en tu entorno) ---
# AUTH_USER=
# AUTH_PASS=

# --- Claude AI Integration ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
CLAUDE_DEFAULT_MODEL=claude-haiku-4-5
CLAUDE_MAX_FILE_SIZE=10
# CLAUDE_MAX_DOC_CHARS=120000
